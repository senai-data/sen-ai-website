# Config Cloudflare R2 pour deploy/backup.sh — copier en deploy/backup.env (git-ignoré) et remplir.
# Token R2 créé dans Cloudflare → R2 → Manage R2 API Tokens → "Object Read & Write", scopé au seul bucket senai-backups.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Endpoint S3 du compte R2 : https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_BUCKET=senai-backups

# Optionnels (valeurs par défaut dans backup.sh) :
# SENAI_BACKUP_DIR=/opt/backups
# SENAI_BACKUP_RETENTION=14
# SENAI_BACKUP_ALERT_GB=5
