---
/**
 * AuditRequestModal — homepage modal for the "audit gratuit" CTA.
 *
 * Listens for the `open-audit-modal` window event (any element on the
 * page can dispatch it via `window.dispatchEvent(new CustomEvent('open-audit-modal'))`).
 *
 * UX laws applied:
 *  - Hick's: 3 required fields visible, 2 optional collapsed
 *  - Goal-Gradient: single step, no wizard
 *  - Doherty Threshold: spinner on submit
 *  - Peak-End: success state explains exactly what happens next
 *  - Aesthetic-Usability: clean card, soft shadow, smooth transitions
 *  - Postel's Law: tolerant URL/email handling on the server side
 *  - Jakob's Law: standard modal pattern (Esc, click outside, ✕)
 */
import site from '../content/site.json';
const f = site.audit_form;
---

<div
  x-data={`{
    open: false,
    showDetails: false,
    submitting: false,
    submitted: false,
    error: '',
    form: { website: '', email: '', topic_focus: '', first_name: '', message: '', honeypot: '' },
    submittedEmail: '',
    submittedTopic: '',
    reset() {
      this.form = { website: '', email: '', topic_focus: '', first_name: '', message: '', honeypot: '' };
      this.submitting = false;
      this.submitted = false;
      this.error = '';
      this.showDetails = false;
    },
    close() {
      this.open = false;
      // Reset only if submitted, so re-opening after error keeps the form
      if (this.submitted) setTimeout(() => this.reset(), 250);
    },
    async submit() {
      this.error = '';
      this.submitting = true;
      try {
        const res = await fetch('/api/audit-requests', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(this.form),
        });
        if (!res.ok) {
          if (res.status === 429) {
            this.error = 'Trop de demandes. Réessayez dans une heure.';
          } else {
            const err = await res.json().catch(() => ({}));
            this.error = err.detail || 'Une erreur est survenue. Réessayez.';
          }
          this.submitting = false;
          return;
        }
        this.submittedEmail = this.form.email;
        this.submittedTopic = this.form.topic_focus;
        this.submitted = true;
        this.submitting = false;
      } catch (e) {
        this.error = 'Erreur réseau. Réessayez.';
        this.submitting = false;
      }
    }
  }`}
  @open-audit-modal.window="open = true; reset()"
  @keydown.escape.window="open && close()"
  x-cloak
>
  <!-- Backdrop -->
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 bg-charcoal-dark/60 backdrop-blur-sm z-[100]"
    @click="close()"
  ></div>

  <!-- Modal -->
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 translate-y-4"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 translate-y-4"
    class="fixed inset-0 z-[101] flex items-end sm:items-center justify-center sm:p-4 overflow-y-auto"
    @click.self="close()"
  >
    <div class="relative w-full sm:max-w-lg bg-white rounded-t-2xl sm:rounded-2xl shadow-2xl p-6 sm:p-8 max-h-[95vh] overflow-y-auto">

      <!-- Close button -->
      <button
        @click="close()"
        class="absolute top-4 right-4 p-1.5 text-charcoal-light hover:text-charcoal-dark transition-colors"
        aria-label="Fermer"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <!-- ============================================== -->
      <!-- Pre-submission state: value pitch + form       -->
      <!-- ============================================== -->
      <div x-show="!submitted">
        <div class="mb-6">
          <span class="inline-block px-3 py-1 bg-coral/10 text-coral text-xs font-bold rounded-full uppercase tracking-wide mb-3">
            {f.badge}
          </span>
          <h2 class="text-2xl sm:text-3xl font-bold text-charcoal-dark mb-2">
            {f.title}
          </h2>
          <p class="text-sm text-charcoal-light">
            {f.subtitle}
          </p>
        </div>

        <!-- Value bullets -->
        <div class="bg-gray-50 rounded-xl p-4 mb-6">
          <p class="text-xs font-semibold text-charcoal-dark uppercase tracking-wide mb-2.5">
            {f.value_label}
          </p>
          <ul class="space-y-1.5 text-sm text-charcoal-light">
            {f.value_bullets.map((b) => (
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-coral mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Form -->
        <form @submit.prevent="submit()" class="space-y-4">
          <!-- Honeypot (off-screen, bots fill it, humans don't) -->
          <input
            type="text"
            x-model="form.honeypot"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
            style="position:absolute;left:-9999px;opacity:0;height:0;width:0;"
          />

          <!-- Website -->
          <div>
            <label for="audit-website" class="block text-sm font-medium text-charcoal-dark mb-1.5">
              {f.label_website}
            </label>
            <input
              id="audit-website"
              type="text"
              x-model="form.website"
              required
              minlength="3"
              maxlength="500"
              placeholder={f.placeholder_website}
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-coral/40 focus:border-coral text-base"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="audit-email" class="block text-sm font-medium text-charcoal-dark mb-1.5">
              {f.label_email}
            </label>
            <input
              id="audit-email"
              type="email"
              x-model="form.email"
              required
              maxlength="255"
              placeholder={f.placeholder_email}
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-coral/40 focus:border-coral text-base"
            />
          </div>

          <!-- Topic -->
          <div>
            <label for="audit-topic" class="block text-sm font-medium text-charcoal-dark mb-1.5">
              {f.label_topic}
            </label>
            <input
              id="audit-topic"
              type="text"
              x-model="form.topic_focus"
              required
              minlength="2"
              maxlength="500"
              placeholder={f.placeholder_topic}
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-coral/40 focus:border-coral text-base"
            />
            <p class="text-xs text-charcoal-light mt-1.5">{f.topic_hint}</p>
          </div>

          <!-- Optional details toggle -->
          <button
            type="button"
            @click="showDetails = !showDetails"
            class="flex items-center gap-1.5 text-sm text-charcoal-light hover:text-charcoal-dark transition-colors"
          >
            <svg class="w-4 h-4 transition-transform" :class="showDetails && 'rotate-90'" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
            {f.details_toggle}
          </button>

          <div x-show="showDetails" x-transition class="space-y-4 pl-4 border-l-2 border-gray-100">
            <div>
              <label for="audit-firstname" class="block text-sm font-medium text-charcoal-dark mb-1.5">
                {f.label_firstname}
              </label>
              <input
                id="audit-firstname"
                type="text"
                x-model="form.first_name"
                maxlength="100"
                placeholder={f.placeholder_firstname}
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-coral/40 focus:border-coral text-base"
              />
            </div>

            <div>
              <label for="audit-message" class="block text-sm font-medium text-charcoal-dark mb-1.5">
                {f.label_message}
              </label>
              <textarea
                id="audit-message"
                x-model="form.message"
                rows="3"
                maxlength="2000"
                placeholder={f.placeholder_message}
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-coral/40 focus:border-coral text-sm resize-none"
              ></textarea>
            </div>
          </div>

          <!-- Error message -->
          <div x-show="error" class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700" x-text="error"></div>

          <!-- Submit -->
          <button
            type="submit"
            :disabled="submitting"
            class="w-full inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark transition-colors text-base shadow-lg shadow-coral/20 disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <svg x-show="submitting" class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
            <span x-text="submitting ? f.submit_loading : f.submit_label"></span>
          </button>

          <!-- Trust signals -->
          <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-xs text-charcoal-light pt-2">
            {f.trust_signals.map((t) => (
              <span>{t}</span>
            ))}
          </div>

          <p class="text-[11px] text-charcoal-light text-center pt-1">
            En soumettant, vous acceptez notre <a href="/privacy" class="text-charcoal-dark hover:text-coral underline">politique de confidentialité</a>.
          </p>
        </form>
      </div>

      <!-- ============================================== -->
      <!-- Success state: Peak-End                        -->
      <!-- ============================================== -->
      <div x-show="submitted" class="text-center py-4">
        <div class="w-16 h-16 mx-auto mb-5 rounded-full bg-emerald/10 flex items-center justify-center">
          <svg class="w-8 h-8 text-emerald" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-charcoal-dark mb-2">{f.success_title}</h2>
        <p class="text-sm text-charcoal-light mb-1">
          {f.success_subtitle}
          <strong class="text-charcoal-dark" x-text="submittedEmail"></strong>
        </p>
        <p class="text-sm text-charcoal-light mb-6">
          {f.success_action}
        </p>

        <div class="bg-gray-50 rounded-xl p-4 text-left mb-6">
          <p class="text-xs text-charcoal-light">
            {f.success_summary_prefix} <strong class="text-charcoal-dark" x-text="submittedTopic"></strong>{f.success_summary_suffix}
          </p>
        </div>

        <button
          @click="close()"
          class="inline-block px-6 py-2.5 border-2 border-charcoal-light/30 text-charcoal hover:border-coral hover:text-coral font-medium rounded-lg transition-colors text-sm"
        >
          {f.success_close}
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  [x-cloak] { display: none !important; }
</style>
