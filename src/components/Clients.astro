---
import site from '../content/site.json';
const { clients } = site;
---

<section id="clients" class="py-16 sm:py-20 px-4 border-b border-gray-100">
  <div class="max-w-6xl mx-auto">
    <!-- Titre -->
    <p class="text-center text-charcoal-light text-sm font-medium uppercase tracking-wide mb-10">
      {clients.title}
    </p>

    <!-- Logos -->
    <div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-9 items-center gap-8 lg:gap-6">
      {clients.brands.map((brand) => (
        <div class="flex items-center justify-center group" title={brand.name}>
          <img
            src={brand.logo}
            alt={brand.name}
            class="h-10 sm:h-12 w-auto object-contain grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
