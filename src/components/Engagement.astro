---
import site from '../content/site.json';
const { engagement } = site;
---

<section id="engagement" class="py-20 sm:py-28 px-4 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <!-- Titre -->
    <h2 class="text-3xl sm:text-4xl font-bold text-charcoal-dark text-center mb-4">
      {engagement.title}
    </h2>
    <p class="text-lg text-charcoal-light text-center max-w-2xl mx-auto mb-16">
      {engagement.subtitle}
    </p>

    <!-- Étapes -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {engagement.steps.map((step) => (
        <div class="bg-white rounded-2xl p-8 border border-gray-200 hover:border-coral/30 hover:shadow-lg transition-all duration-300 group">
          <!-- Numéro -->
          <div class="w-10 h-10 rounded-full bg-coral/10 text-coral flex items-center justify-center text-lg font-bold mb-5 group-hover:bg-coral group-hover:text-white transition-colors duration-300">
            {step.number}
          </div>

          <!-- Titre -->
          <h3 class="text-lg font-bold text-charcoal-dark mb-3 group-hover:text-coral transition-colors">
            {step.title}
          </h3>

          <!-- Description -->
          <p class="text-sm text-charcoal-light leading-relaxed">
            {step.description}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a
        href="https://wa.me/33671738273?text=Bonjour%2C%20je%20souhaite%20r%C3%A9server%20un%20audit%20gratuit%20avec%20sen-ai.fr."
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-8 py-3.5 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark transition-colors text-lg shadow-lg shadow-coral/20"
      >
        {engagement.cta}
      </a>
    </div>
  </div>
</section>
