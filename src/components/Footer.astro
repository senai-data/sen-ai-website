---
import site from '../content/site.json';
const { footer } = site;
---

<!-- Langue : labels FR partout, meme sur les pages au corps anglais.
     Meme raison que Nav.astro - les destinations sont francaises. -->
<footer lang="fr" class="bg-charcoal-dark text-white py-12 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Brand lockup (docs/DESIGN_TOKENS.md) : lotus glyph + wordmark -->
      <div class="flex flex-col items-center md:items-start gap-2">
        <span class="flex items-center gap-2">
          <img src="/logo-mark.svg" alt="" class="h-7 w-7" />
          <span class="text-[15px] font-bold tracking-tight text-white">sen-ai<span class="text-gray-400 font-medium">.fr</span></span>
        </span>
        <p class="text-coral-light text-sm italic tracking-wide">
          {footer.tagline}
        </p>
      </div>

      <!-- Liens -->
      <div class="flex flex-col items-center md:items-end gap-2 text-sm">
        <a href={`mailto:${footer.email}`} class="text-gray-300 hover:text-coral-light transition-colors">
          {footer.email}
        </a>
        <div class="flex flex-wrap items-center justify-center md:justify-end gap-x-4 gap-y-1 text-gray-400">
          <a href="/guides/" class="hover:text-gray-200 transition-colors">Guides</a>
          <a href="/ressources/" class="hover:text-gray-200 transition-colors">Ressources</a>
          {/* /fr/methodology existait deja mais n'etait linke nulle part -
              le footer pointait vers la version anglaise. */}
          <a href="/fr/methodology" class="hover:text-gray-200 transition-colors">Méthodologie</a>
          <a href="/privacy" class="hover:text-gray-200 transition-colors">Confidentialité</a>
          <a href="/terms" class="hover:text-gray-200 transition-colors">CGU</a>
          <a href="/mentions-legales" class="hover:text-gray-200 transition-colors">Mentions légales</a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-6 border-t border-charcoal-light/30 text-center">
      <p class="text-gray-400 text-xs">
        {footer.copyright}
      </p>
    </div>
  </div>
</footer>
