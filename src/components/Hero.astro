---
/**
 * Landing hero - redesign per 12-marketing.html (mobile-first).
 *
 * Structure from the ref : providers tag, hooky H1 with coral em, double
 * CTA, trust line, and the sample-result demo card (grade + per-AI bars)
 * replacing the old decorative orbital circles.
 *
 * Funnel decision (2026-06-11) : primary CTA = self-serve /register
 * (S15 reopen direction), the 24h free-audit modal stays one click away
 * as the secondary CTA. Copy stays French - the landing sells to the
 * French market even though the app UI is English.
 */
import site from '../content/site.json';
const { hero } = site;
---

<section class="lhero">
  <div class="lhero__inner">
    <div class="lhero__copy">
      <div class="lhero__tag">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="8" cy="8" r="6"/><path d="M8 5v3l2 1.5"/></svg>
        ChatGPT &middot; Gemini &middot; Claude &middot; Mistral
      </div>

      <h1>Que disent <em>ChatGPT et Gemini</em> de votre marque&nbsp;?</h1>

      <p class="lhero__lede">
        sen-ai pose aux IA les questions que vos clients leur posent, puis vous montre
        quand votre marque est citée, quand elle ne l'est pas, et qui est recommandé à votre place.
      </p>

      <div class="lhero__cta">
        <a class="lhero__btn lhero__btn--primary" href="/register">Lancer mon premier scan gratuit</a>
        <button type="button" id="hero-audit-cta" class="lhero__btn lhero__btn--ghost">
          {hero.cta_primary}
        </button>
      </div>

      <div class="lhero__trust">Sans CB ni engagement &middot; Premier scan gratuit &middot; Audit expert sous 24h</div>
    </div>

    {/* Sample result card - what the product actually shows */}
    <div class="lhero__demo" aria-hidden="true">
      <div class="demo__card">
        <div class="demo__hd">
          <div class="demo__grade">C</div>
          <div>
            <div class="demo__name">Votre marque</div>
            <div class="demo__sub">citée dans 41% des réponses</div>
          </div>
        </div>
        <div class="demo__bars">
          <div class="dbar"><span class="dbar__n"><span class="dbar__ic" style="background:#10A37F">AI</span>OpenAI</span><span class="dbar__track"><span class="dbar__fill" style="width:52%;background:var(--status-positive)"></span></span><span class="dbar__v">52%</span></div>
          <div class="dbar"><span class="dbar__n"><span class="dbar__ic" style="background:#4285F4">G</span>Gemini</span><span class="dbar__track"><span class="dbar__fill" style="width:44%;background:var(--sev-low)"></span></span><span class="dbar__v">44%</span></div>
          <div class="dbar"><span class="dbar__n"><span class="dbar__ic" style="background:#D97757">C</span>Claude</span><span class="dbar__track"><span class="dbar__fill" style="width:38%;background:var(--sev-medium)"></span></span><span class="dbar__v">38%</span></div>
          <div class="dbar"><span class="dbar__n"><span class="dbar__ic" style="background:#FF7000">M</span>Mistral</span><span class="dbar__track"><span class="dbar__fill" style="width:29%;background:var(--sev-high)"></span></span><span class="dbar__v">29%</span></div>
        </div>
        <div class="demo__foot">Et la liste des sources que chaque IA cite - les vôtres ou celles de vos concurrents.</div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Mobile-first per 12-marketing.html ; scales to a 2-col desktop hero. */
  .lhero { background: var(--color-surface); border-bottom: 1px solid var(--color-border); padding: 44px 22px 36px; }
  .lhero__inner { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 32px; align-items: center; }
  @media (min-width: 900px) { .lhero { padding: 72px 32px 64px; } .lhero__inner { grid-template-columns: 1.1fr 1fr; gap: 56px; } }

  .lhero__tag { display: inline-flex; align-items: center; gap: 6px; font-size: 11.5px; font-weight: 600; color: var(--color-text-secondary); background: var(--color-surface-muted); padding: 5px 11px; border-radius: var(--radius-full); margin-bottom: 18px; }
  .lhero h1 { font-size: 30px; font-weight: 700; letter-spacing: -.03em; line-height: 1.1; color: var(--color-text-primary); }
  @media (min-width: 900px) { .lhero h1 { font-size: 42px; } }
  .lhero h1 em { font-style: normal; color: var(--color-primary); }
  .lhero__lede { font-size: 15px; color: var(--color-text-secondary); margin-top: 14px; line-height: 1.55; max-width: 54ch; }
  @media (min-width: 900px) { .lhero__lede { font-size: 16px; } }

  .lhero__cta { display: flex; flex-direction: column; gap: 10px; margin-top: 22px; }
  @media (min-width: 640px) { .lhero__cta { flex-direction: row; } }
  .lhero__btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; height: 50px; padding: 0 22px; border-radius: var(--radius-md); font: 650 15px var(--font-sans); cursor: pointer; border: 1px solid transparent; text-decoration: none; transition: .12s; }
  .lhero__btn--primary { background: var(--color-primary); color: #fff; }
  .lhero__btn--primary:hover { background: var(--color-primary-hover); }
  .lhero__btn--ghost { background: var(--color-surface); color: var(--color-text-primary); border-color: var(--color-border-strong); }
  .lhero__btn--ghost:hover { background: var(--color-surface-sunken); }
  .lhero__trust { font-size: 12px; color: var(--color-text-muted); margin-top: 14px; }

  .demo__card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-md); padding: 18px; max-width: 420px; }
  .demo__hd { display: flex; align-items: center; gap: 11px; }
  .demo__grade { width: 38px; height: 38px; border-radius: 9px; background: var(--status-warning-bg); color: var(--status-warning); box-shadow: inset 0 0 0 1.5px var(--status-warning); display: grid; place-items: center; font-size: 19px; font-weight: 750; flex: none; }
  .demo__name { font-size: 14px; font-weight: 680; color: var(--color-text-primary); }
  .demo__sub { font-size: 11.5px; color: var(--color-text-muted); }
  .demo__bars { margin-top: 14px; display: flex; flex-direction: column; gap: 9px; }
  .dbar { display: grid; grid-template-columns: 64px 1fr 34px; align-items: center; gap: 9px; font-size: 11.5px; }
  .dbar__n { font-weight: 600; display: flex; align-items: center; gap: 6px; color: var(--color-text-primary); }
  .dbar__ic { width: 15px; height: 15px; border-radius: 4px; display: grid; place-items: center; color: #fff; font-size: 8px; font-weight: 700; }
  .dbar__track { height: 7px; background: var(--color-surface-muted); border-radius: var(--radius-full); overflow: hidden; }
  .dbar__fill { height: 100%; border-radius: var(--radius-full); }
  .dbar__v { font-weight: 700; text-align: right; color: var(--color-text-primary); }
  .demo__foot { margin-top: 14px; padding-top: 12px; border-top: 1px dashed var(--color-border); font-size: 11.5px; color: var(--color-text-muted); line-height: 1.45; }
</style>

<script>
  document.getElementById('hero-audit-cta')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-audit-modal'));
  });
</script>
