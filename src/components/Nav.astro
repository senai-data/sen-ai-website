---
// Navigation sticky avec menu mobile CSS-only
---

<header>
<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 transition-shadow duration-300" id="nav" aria-label="Navigation principale">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Checkbox pour le menu mobile (CSS-only) -->
    <input type="checkbox" id="mobile-menu-toggle" class="sr-only" aria-label="Menu mobile" />

    <div class="flex items-center justify-between h-16">
      <!-- Brand lockup (docs/DESIGN_TOKENS.md) : lotus glyph + wordmark -->
      <a href="/" class="flex items-center gap-2 shrink-0" aria-label="sen-ai.fr - Accueil">
        <img src="/logo-mark.svg" alt="" class="h-8 w-8" />
        <span class="text-[15px] font-bold tracking-tight text-charcoal-dark">sen-ai<span class="text-charcoal-light font-medium">.fr</span></span>
      </a>

      <!-- Desktop navigation -->
      <div class="hidden md:flex items-center gap-6 lg:gap-8">
        <a href="#ai-scan" class="text-charcoal hover:text-coral transition-colors text-sm font-medium">AI Scan</a>
        <a href="/agency" class="text-charcoal hover:text-coral transition-colors text-sm font-medium">For agencies</a>
        <a href="/pricing" class="text-charcoal hover:text-coral transition-colors text-sm font-medium">Pricing</a>
        <a href="#histoire" class="text-charcoal hover:text-coral transition-colors text-sm font-medium">Notre histoire</a>
        <span class="w-px h-5 bg-gray-200" aria-hidden="true"></span>
        <a href="/login" class="text-charcoal-light hover:text-charcoal-dark transition-colors text-sm font-medium">Log in</a>
        <a href="/register" class="inline-flex items-center px-4 py-2 bg-coral text-white text-sm font-medium rounded-lg hover:bg-coral-dark transition-colors">
          Start free
        </a>
      </div>

      <!-- Mobile hamburger -->
      <label for="mobile-menu-toggle" class="hamburger md:hidden flex flex-col gap-1.5 cursor-pointer p-2 -mr-2" aria-label="Ouvrir le menu">
        <span class="line line-1 block w-6 h-0.5 bg-charcoal transition-transform duration-300 origin-center"></span>
        <span class="line line-2 block w-6 h-0.5 bg-charcoal transition-opacity duration-300"></span>
        <span class="line line-3 block w-6 h-0.5 bg-charcoal transition-transform duration-300 origin-center"></span>
      </label>
    </div>

    <!-- Menu mobile -->
    <div class="mobile-panel md:hidden overflow-hidden transition-all duration-300" id="mobile-menu">
      <div class="pb-4 flex flex-col gap-3">
        <a href="#ai-scan" class="text-charcoal hover:text-coral transition-colors py-2 text-sm font-medium">AI Scan</a>
        <a href="/agency" class="text-charcoal hover:text-coral transition-colors py-2 text-sm font-medium">For agencies</a>
        <a href="/pricing" class="text-charcoal hover:text-coral transition-colors py-2 text-sm font-medium">Pricing</a>
        <a href="#histoire" class="text-charcoal hover:text-coral transition-colors py-2 text-sm font-medium">Notre histoire</a>
        <div class="h-px bg-gray-200 my-1" aria-hidden="true"></div>
        <a href="/login" class="text-charcoal-light hover:text-charcoal-dark transition-colors py-2 text-sm font-medium">Log in</a>
        <a href="/register" class="inline-flex items-center justify-center px-4 py-2 bg-coral text-white text-sm font-medium rounded-lg hover:bg-coral-dark transition-colors">
          Start free
        </a>
      </div>
    </div>
  </div>
</nav>
</header>

<style>
  .mobile-panel {
    max-height: 0;
  }
  #mobile-menu-toggle:checked ~ * .mobile-panel,
  #mobile-menu-toggle:checked ~ .mobile-panel {
    max-height: 24rem;
  }
  #mobile-menu-toggle:checked ~ * .line-1,
  #mobile-menu-toggle:checked ~ .flex .line-1 {
    transform: rotate(45deg) translateY(4px) translateX(4px);
  }
  #mobile-menu-toggle:checked ~ * .line-2,
  #mobile-menu-toggle:checked ~ .flex .line-2 {
    opacity: 0;
  }
  #mobile-menu-toggle:checked ~ * .line-3,
  #mobile-menu-toggle:checked ~ .flex .line-3 {
    transform: rotate(-45deg) translateY(-4px) translateX(4px);
  }
</style>

<script>
  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      const toggle = document.getElementById('mobile-menu-toggle') as HTMLInputElement;
      if (toggle) toggle.checked = false;
    });
  });
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      nav?.classList.add('shadow-md');
    } else {
      nav?.classList.remove('shadow-md');
    }
  });

</script>
