---
// Navigation sticky avec menu mobile CSS-only
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 transition-shadow duration-300" id="nav">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Checkbox pour le menu mobile (CSS-only) -->
    <input type="checkbox" id="mobile-menu-toggle" class="sr-only" aria-label="Menu mobile" />

    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0" aria-label="sen-ai.fr — Accueil">
        <img src="/logo.svg" alt="sen-ai.fr" class="h-8 w-auto" />
      </a>

      <!-- Desktop navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#solution" class="text-charcoal hover:text-coral transition-colors text-sm font-medium">Solution</a>
        <a href="#fonctionnalites" class="text-charcoal hover:text-coral transition-colors text-sm font-medium">Fonctionnalites</a>
        <a href="#resultats" class="text-charcoal hover:text-coral transition-colors text-sm font-medium">Resultats</a>
        <a href="#tarifs" class="text-charcoal hover:text-coral transition-colors text-sm font-medium">Tarifs</a>
        <a href="mailto:contact@sen-ai.fr" class="inline-flex items-center px-4 py-2 bg-coral text-white text-sm font-medium rounded-lg hover:bg-coral-dark transition-colors">
          Contact
        </a>
      </div>

      <!-- Mobile hamburger -->
      <label for="mobile-menu-toggle" class="hamburger md:hidden flex flex-col gap-1.5 cursor-pointer p-2 -mr-2" aria-label="Ouvrir le menu">
        <span class="line line-1 block w-6 h-0.5 bg-charcoal transition-transform duration-300 origin-center"></span>
        <span class="line line-2 block w-6 h-0.5 bg-charcoal transition-opacity duration-300"></span>
        <span class="line line-3 block w-6 h-0.5 bg-charcoal transition-transform duration-300 origin-center"></span>
      </label>
    </div>

    <!-- Menu mobile -->
    <div class="mobile-panel md:hidden overflow-hidden transition-all duration-300" id="mobile-menu">
      <div class="pb-4 flex flex-col gap-3">
        <a href="#solution" class="text-charcoal hover:text-coral transition-colors py-2 text-sm font-medium">Solution</a>
        <a href="#fonctionnalites" class="text-charcoal hover:text-coral transition-colors py-2 text-sm font-medium">Fonctionnalites</a>
        <a href="#resultats" class="text-charcoal hover:text-coral transition-colors py-2 text-sm font-medium">Resultats</a>
        <a href="#tarifs" class="text-charcoal hover:text-coral transition-colors py-2 text-sm font-medium">Tarifs</a>
        <a href="mailto:contact@sen-ai.fr" class="inline-flex items-center justify-center px-4 py-2 bg-coral text-white text-sm font-medium rounded-lg hover:bg-coral-dark transition-colors">
          Contact
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  /* Menu fermé par défaut */
  .mobile-panel {
    max-height: 0;
  }

  /* Menu ouvert quand checkbox cochée */
  #mobile-menu-toggle:checked ~ * .mobile-panel,
  #mobile-menu-toggle:checked ~ .mobile-panel {
    max-height: 24rem;
  }

  /* Hamburger → croix */
  #mobile-menu-toggle:checked ~ * .line-1,
  #mobile-menu-toggle:checked ~ .flex .line-1 {
    transform: rotate(45deg) translateY(4px) translateX(4px);
  }
  #mobile-menu-toggle:checked ~ * .line-2,
  #mobile-menu-toggle:checked ~ .flex .line-2 {
    opacity: 0;
  }
  #mobile-menu-toggle:checked ~ * .line-3,
  #mobile-menu-toggle:checked ~ .flex .line-3 {
    transform: rotate(-45deg) translateY(-4px) translateX(4px);
  }
</style>

<script>
  // Fermer le menu mobile au clic sur un lien
  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      const toggle = document.getElementById('mobile-menu-toggle') as HTMLInputElement;
      if (toggle) toggle.checked = false;
    });
  });

  // Ombre sur scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      nav?.classList.add('shadow-md');
    } else {
      nav?.classList.remove('shadow-md');
    }
  });
</script>
