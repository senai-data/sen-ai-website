---
/**
 * Date Range Picker — GSC-inspired date filter for scan results.
 *
 * storytellingwithdata: "Provide context" — date range gives temporal context to all data.
 * lawsofux:
 * - Hick's Law: presets reduce choices (All / Latest / Last 2). No overwhelming calendar.
 * - Jakob's Law: GSC pattern familiar to marketers.
 * - Recognition > Recall: show dates, not "Run 2/3".
 * - Doherty: link navigation = instant SSR reload.
 *
 * Adapts by run count:
 * - 1 run: static date label
 * - 2-3 runs: pills with "All" default + individual dates
 * - 4+ runs: dropdown with presets + custom range
 */
interface Props {
  runs: Array<{
    id: string;
    run_index: number;
    completed_at: string | null;
  }>;
  currentRange: string;
  fromDate?: string;
  toDate?: string;
  currentTab: string;
  rootScanId: string;
}

const { runs, currentRange, fromDate, toDate, currentTab, rootScanId } = Astro.props;

function fmtShort(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
}
function fmtFull(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

const tabPath = currentTab === 'overview' ? 'results' : currentTab;
function rangeUrl(range: string, extra = ''): string {
  return `/app/scans/${rootScanId}/${tabPath}?range=${range}${extra}`;
}

const rangeLabel = currentRange === 'all' ? 'All dates'
  : currentRange === 'latest' ? fmtFull(runs[runs.length - 1]?.completed_at)
  : currentRange === 'last2' ? 'Last 2 runs'
  : currentRange === 'custom' ? `${fmtShort(fromDate)} — ${fmtShort(toDate)}`
  : 'All dates';

const firstDate = runs[0]?.completed_at;
const lastDate = runs[runs.length - 1]?.completed_at;
---

{/* 1 run: static label */}
{runs.length <= 1 && lastDate && (
  <span class="text-[11px] text-charcoal-light">{fmtFull(lastDate)}</span>
)}

{/* 2-3 runs: pills (Hick's Law: few clear choices) */}
{runs.length > 1 && runs.length <= 3 && (
  <div class="flex items-center gap-0.5 bg-gray-100 rounded-lg p-0.5">
    <a href={rangeUrl('all')}
       class:list={[
         'px-2.5 py-1 rounded-md text-[11px] font-medium transition-all',
         currentRange === 'all' ? 'bg-white shadow-sm text-coral' : 'text-charcoal-light hover:text-charcoal-dark',
       ]}>
      All
    </a>
    {runs.map(r => (
      <a href={rangeUrl('latest') + `&run=${r.id}`}
         class:list={[
           'px-2.5 py-1 rounded-md text-[11px] font-medium transition-all',
           currentRange === 'latest' && Astro.url.searchParams.get('run') === r.id
             ? 'bg-white shadow-sm text-charcoal-dark'
             : 'text-charcoal-light hover:text-charcoal-dark',
         ]}
         title={fmtFull(r.completed_at)}>
        {fmtShort(r.completed_at)}
      </a>
    ))}
  </div>
)}

{/* 4+ runs: dropdown (Progressive Disclosure) */}
{runs.length > 3 && (
  <div class="relative" x-data="{ open: false, custom: false }">
    <button
      @click="open = !open"
      @click.outside="open = false"
      class="flex items-center gap-1.5 px-3 py-1.5 bg-gray-100 rounded-lg text-[11px] font-medium text-charcoal-dark hover:bg-gray-200 transition-colors"
    >
      <svg class="w-3.5 h-3.5 text-charcoal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      {rangeLabel}
      <svg class="w-3 h-3 text-charcoal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>

    <div x-show="open" x-transition class="absolute right-0 mt-1 bg-white rounded-lg shadow-lg border border-gray-100 py-1 min-w-[200px] z-30">
      {/* Presets */}
      <a href={rangeUrl('all')} class:list={['block px-4 py-2 text-xs transition-colors', currentRange === 'all' ? 'bg-coral/5 text-coral font-medium' : 'text-charcoal-dark hover:bg-gray-50']}>
        All dates
        <span class="text-[10px] text-charcoal-light ml-1">{fmtShort(firstDate)} — {fmtShort(lastDate)}</span>
      </a>
      <a href={rangeUrl('latest')} class:list={['block px-4 py-2 text-xs transition-colors', currentRange === 'latest' ? 'bg-coral/5 text-coral font-medium' : 'text-charcoal-dark hover:bg-gray-50']}>
        Latest run
        <span class="text-[10px] text-charcoal-light ml-1">{fmtShort(lastDate)}</span>
      </a>
      {runs.length >= 3 && (
        <a href={rangeUrl('last2')} class:list={['block px-4 py-2 text-xs transition-colors', currentRange === 'last2' ? 'bg-coral/5 text-coral font-medium' : 'text-charcoal-dark hover:bg-gray-50']}>
          Last 2 runs
        </a>
      )}

      <div class="border-t border-gray-100 my-1"></div>

      {/* Individual runs */}
      <p class="px-4 py-1 text-[10px] text-charcoal-light uppercase">Individual runs</p>
      {[...runs].reverse().map(r => (
        <a href={rangeUrl('latest') + `&run=${r.id}`}
           class:list={['block px-4 py-2 text-xs transition-colors', 'text-charcoal-dark hover:bg-gray-50']}>
          {fmtFull(r.completed_at)}
          <span class="text-[10px] text-charcoal-light ml-1">Run {(r.run_index ?? 0) + 1}</span>
        </a>
      ))}

      <div class="border-t border-gray-100 my-1"></div>

      {/* Custom range */}
      <button @click.stop="custom = !custom" class="w-full text-left px-4 py-2 text-xs text-charcoal-dark hover:bg-gray-50">
        Custom range...
      </button>
      <div x-show="custom" x-transition class="px-4 py-2 space-y-2">
        <div class="flex items-center gap-2">
          <input type="date" id="dateFrom" class="text-[11px] border border-gray-200 rounded px-2 py-1 w-full" value={fromDate || ''} />
          <span class="text-[10px] text-charcoal-light">to</span>
          <input type="date" id="dateTo" class="text-[11px] border border-gray-200 rounded px-2 py-1 w-full" value={toDate || ''} />
        </div>
        <button
          @click={`window.location.href='/app/scans/${rootScanId}/${tabPath}?range=custom&from='+document.getElementById('dateFrom').value+'&to='+document.getElementById('dateTo').value`}
          class="w-full px-3 py-1.5 bg-coral text-white rounded text-[11px] font-medium hover:bg-coral-dark transition-colors">
          Apply
        </button>
      </div>
    </div>
  </div>
)}
