---
import site from '../content/site.json';
const { solution } = site;
---

<section id="solution" class="py-20 sm:py-28 px-4">
  <div class="max-w-6xl mx-auto">
    <!-- Titre -->
    <h2 class="text-3xl sm:text-4xl font-bold text-charcoal-dark text-center mb-16">
      {solution.title}
    </h2>

    <!-- Étapes -->
    <div class="flex flex-col lg:flex-row items-start lg:items-stretch gap-4 lg:gap-0">
      {solution.steps.map((step, i) => (
        <div class="flex flex-col lg:flex-row items-center flex-1">
          <!-- Carte étape -->
          <div class="flex flex-col items-center text-center px-4 py-6 flex-1">
            <!-- Numéro -->
            <div class="w-14 h-14 rounded-full bg-coral text-white flex items-center justify-center text-xl font-bold mb-4 shrink-0">
              {step.number}
            </div>
            <!-- Titre -->
            <h3 class="text-lg font-bold text-charcoal-dark mb-3">
              {step.title}
            </h3>
            <!-- Description -->
            <p class="text-sm text-charcoal-light leading-relaxed">
              {step.description}
            </p>
          </div>

          {/* Flèche entre les étapes (pas après la dernière) */}
          {i < solution.steps.length - 1 && (
            <div class="flex items-center justify-center shrink-0 text-coral/40">
              {/* Flèche horizontale desktop */}
              <svg class="hidden lg:block w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
              {/* Flèche verticale mobile */}
              <svg class="lg:hidden w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
