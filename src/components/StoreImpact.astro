---
import site from '../content/site.json';
const { storeimpact } = site;

const iconMap: Record<string, string> = {
  link: '<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m9.86-3.061a4.5 4.5 0 0 0-1.242-7.244l-4.5-4.5a4.5 4.5 0 0 0-6.364 6.364L5.25 9.503" />',
  clipboard: '<path stroke-linecap="round" stroke-linejoin="round" d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0 1 18 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3 1.5 1.5 3-3.75" />',
  megaphone: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46" />',
  cpu: '<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z" />',
  envelope: '<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />'
};
---

<section id="store-impact" class="py-20 sm:py-28 px-4">
  <div class="max-w-5xl mx-auto">
    <!-- Header de la solution -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-gads/10 text-gads text-sm font-bold rounded-full uppercase tracking-wide mb-4">
        Solution
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-charcoal-dark mb-4">
        {storeimpact.title}
      </h2>
      <p class="text-xl text-charcoal-light max-w-2xl mx-auto">
        {storeimpact.tagline}
      </p>
    </div>

    <!-- Description -->
    <p class="text-center text-charcoal-light leading-relaxed max-w-3xl mx-auto mb-16">
      {storeimpact.description}
    </p>

    <!-- Mindset / Démarche -->
    <div class="mb-20">
      <h3 class="text-2xl font-bold text-charcoal-dark text-center mb-3">
        {storeimpact.mindset.title}
      </h3>
      <p class="text-charcoal-light text-center max-w-xl mx-auto mb-12">
        {storeimpact.mindset.subtitle}
      </p>

      <!-- Pipeline verticale -->
      <div class="relative">
        <div class="absolute left-6 sm:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-gads/20 via-gads/40 to-gads-dark/40 hidden sm:block"></div>

        <div class="space-y-10 sm:space-y-14">
          {storeimpact.mindset.steps.map((step) => (
            <div class="flex items-start gap-6 sm:gap-8 group">
              <div class="relative z-10 shrink-0 w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-white border-2 border-gads/30 group-hover:border-gads flex items-center justify-center transition-colors duration-300 shadow-sm">
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gads" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <Fragment set:html={iconMap[step.icon]} />
                </svg>
              </div>
              <div class="flex-1 pt-0.5 sm:pt-1">
                <h4 class="text-lg sm:text-xl font-bold text-charcoal-dark mb-2 group-hover:text-gads transition-colors duration-300">
                  {step.title}
                </h4>
                <p class="text-charcoal-light leading-relaxed max-w-xl">
                  {step.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Livrables -->
    <div class="mb-16">
      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        <!-- Newsletter -->
        <div class="bg-white rounded-2xl p-8 sm:p-10 border-2 border-gads/20 shadow-lg shadow-gads/5 hover:shadow-xl transition-shadow duration-300">
          <div class="w-12 h-12 rounded-xl bg-gads/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-gads" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-charcoal-dark mb-2">
            {storeimpact.livrables.newsletter.title}
          </h3>
          <p class="text-charcoal-light mb-6 italic text-sm">
            {storeimpact.livrables.newsletter.subtitle}
          </p>
          <ul class="space-y-3">
            {storeimpact.livrables.newsletter.points.map((point) => (
              <li class="flex items-start gap-3 text-charcoal-light text-sm">
                <span class="text-gads mt-0.5 shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Dashboard -->
        <div class="bg-white rounded-2xl p-8 sm:p-10 border-2 border-gads-dark/20 shadow-lg shadow-gads-dark/5 hover:shadow-xl transition-shadow duration-300">
          <div class="w-12 h-12 rounded-xl bg-gads-dark/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-gads-dark" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-charcoal-dark mb-2">
            {storeimpact.livrables.dashboard.title}
          </h3>
          <p class="text-charcoal-light mb-6 italic text-sm">
            {storeimpact.livrables.dashboard.subtitle}
          </p>
          <ul class="space-y-3">
            {storeimpact.livrables.dashboard.points.map((point) => (
              <li class="flex items-start gap-3 text-charcoal-light text-sm">
                <span class="text-gads-dark mt-0.5 shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Clients store-impact -->
    <div class="text-center">
      <p class="text-charcoal-light text-lg font-medium">
        {storeimpact.clients.text}
      </p>
    </div>
  </div>
</section>
