---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <title>{title} — sen-ai.fr</title>
  </head>
  <body class="bg-gray-50 text-charcoal font-sans antialiased min-h-screen">
    <slot />
  </body>
</html>
