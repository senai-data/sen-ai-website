---
import site from '../content/site.json';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Page language - "fr" (default, marketing) or "en" (methodology, legal, agency). */
  lang?: 'fr' | 'en';
  /** True on pages search engines must not index (404, error states).
   *  2026-07-18 : the 404 page shipped with index,follow for months. */
  noindex?: boolean;
  /** hreflang alternates, e.g. { fr: '/guides/x/', en: '/ressources/y/' }.
   *  Must live in <head> to count - hence a prop rather than a slot.
   *  x-default falls back to the fr entry (our primary market). */
  alternates?: Record<string, string>;
}

const {
  title = site.meta.title,
  description = site.meta.description,
  lang = 'fr',
  noindex = false,
  alternates,
} = Astro.props;

const ogLocale = lang === 'en' ? 'en_GB' : 'fr_FR';

const canonicalURL = new URL(Astro.url.pathname, site.meta.url);

// Langue des donnees structurees 2026-07-18 : ces deux blocs decrivent LA
// PAGE, ils suivent donc son `lang` - contrairement au chrome nav/footer qui
// decrit des destinations francaises. Avant ce fix ils servaient une
// description et une featureList francaises en dur dans le <head> des pages
// <html lang="en"> (/agency, /methodology, /terms, /privacy, /ressources).
// `description` est deja la description propre a la page, donc bilingue.
const featureList = lang === 'en'
  ? [
      "Multi-model LLM visibility tracking",
      "GEO-optimised content generation",
      "Automated netlinking intelligence",
      "Schema.org FAQ generation",
      "Brand reputation monitoring"
    ]
  : [
      "Analyse de visibilité LLM multi-modèles",
      "Génération de contenu GEO optimisé",
      "Intelligence netlinking automatisée",
      "Génération FAQ Schema.org",
      "Veille réputation RAPP"
    ];

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "sen-ai.fr",
  "url": "https://sen-ai.fr",
  "logo": "https://sen-ai.fr/logo-sen-ai-fr.png",
  "description": description,
  "slogan": "from data to bloom",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "contact@sen-ai.fr",
    "contactType": "customer service",
    "availableLanguage": "French"
  }
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "sen-ai.fr",
  "applicationCategory": "BusinessApplication",
  "description": description,
  "inLanguage": lang === 'en' ? 'en' : 'fr-FR',
  "operatingSystem": "Web",
  "url": "https://sen-ai.fr",
  "featureList": featureList
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* Google Search Console - URL-prefix property https://sen-ai.fr/
        verification (public token, safe to expose). Lives in BaseLayout so
        the homepage and every public page carry it. */}
    <meta name="google-site-verification" content="LEzratE4HdRZrBlFhvrvqoPRcjBS-9CoSWAR2E-jk3s" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalURL.href} />
    {alternates && Object.entries(alternates).map(([code, href]) => (
      <link rel="alternate" hreflang={code} href={new URL(href, site.meta.url).href} />
    ))}
    {alternates && alternates.fr && (
      <link rel="alternate" hreflang="x-default" href={new URL(alternates.fr, site.meta.url).href} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://sen-ai.fr/og-image.png" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://sen-ai.fr/og-image.png" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />

    <!-- Alpine.js for interactive components (modal, etc.) — defer keeps it non-blocking -->
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js" defer></script>
    <style is:global>[x-cloak] { display: none !important; }</style>

    <!-- Cloudflare Web Analytics (cookieless, sans bandeau RGPD) -->
    <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "2884f25c202e4c5f945e03519b468596"}'></script>
  </head>
  <body class="bg-white text-charcoal font-sans antialiased">
    {/* Suit le `lang` de la page : c'est le premier element focusable, il
        etait en francais en dur sur les pages anglaises. */}
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-coral focus:text-white focus:rounded-lg focus:text-sm focus:font-medium">
      {lang === 'en' ? 'Skip to main content' : 'Aller au contenu principal'}
    </a>
    <slot />
  </body>
</html>
