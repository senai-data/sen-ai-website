---
/**
 * Scan Results Layout - nested inside DashboardLayout.
 * Provides: breadcrumb, sticky scan header (grade + brand + sparkline + run selector),
 * horizontal tabs, and content slot.
 *
 * Every scan result sub-page (Overview, Topics, Personas, Questions, Actions)
 * uses this layout instead of DashboardLayout directly.
 *
 * Laws of UX:
 * - Jakob's Law: standard SaaS tab pattern (Semrush, Ahrefs)
 * - Hick's Law: 5 tabs exactly
 * - Von Restorff: grade badge + coral active tab
 * - Recognition > Recall: breadcrumb + dates in run selector
 * - Doherty Threshold: SSR fetch < 50ms on internal Docker network
 */
export const prerender = false;

import DashboardLayout from './DashboardLayout.astro';
import ScanBreadcrumb from '../components/ScanBreadcrumb.astro';
import ScanTabs from '../components/ScanTabs.astro';
import ScanDateRangePicker from '../components/ScanDateRangePicker.astro';
import ScanProviderFilter from '../components/ScanProviderFilter.astro';
import Tip from '../components/Tip.astro';
import { fetchScanHeader } from '../lib/scan-header';

interface Props {
  scanId: string;
  activeTab: 'overview' | 'topics' | 'personas' | 'questions' | 'citations' | 'wikipedia' | 'audit' | 'schema' | 'competitors' | 'reddit' | 'pr-outreach' | 'internal-linking' | 'youtube' | 'crisis' | 'compliance' | 'actions';
  /** Mobile P3 - forwarded to DashboardLayout. Only the Overview leaf
   *  (results.astro) opts in : it's the scan-complete email's deep-link
   *  target. Dense leaves keep the <1024px gate. */
  mobileReady?: boolean;
}

const { scanId, activeTab, mobileReady = false } = Astro.props;

// Auth guard
const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

// Read global filters from URL query params
const rangeParam = Astro.url.searchParams.get('range') || 'all';
const fromParam = Astro.url.searchParams.get('from') || undefined;
const toParam = Astro.url.searchParams.get('to') || undefined;
const runParam = Astro.url.searchParams.get('run') || undefined;
const providerParam = Astro.url.searchParams.get('provider') || 'all';

// If a specific run is selected, use it directly
const effectiveScanId = (rangeParam === 'latest' && runParam) ? runParam : scanId;

// Fetch shared header data (with range + provider for aggregation)
const headerData = await fetchScanHeader(effectiveScanId, token, rangeParam, fromParam, toParam, providerParam);

// Guards
if (headerData.scan.status === 'not_found') return Astro.redirect('/app/scans');
if (headerData.scan.status !== 'completed' && headerData.scan.status !== 'error') {
  return Astro.redirect(`/app/scans/${scanId}`);
}

const { scan, grade, currentRate, delta, eraNote, sparkSvg, runs, tabCounts, overview } = headerData;

// Resolve the TRUE root (parent_scan_id null) - NOT runs[0] : imported
// lineages carry the root at run_index 5 with antedated children 1-4
// (seo-llm history import), so position in the run order proves nothing.
// The root is where lineage settings (model_overrides, runs_depth) live.
const rootRun: any = runs.find((r: any) => !(r as any).parent_scan_id) || runs[0] || null;
const rootScanId = rootRun?.id || scanId;
// Custom model override active on this lineage ? (root config rides the
// lineage payload - no extra fetch). Feeds the state dot on Rescan settings.
const hasModelOverrides = Object.keys((rootRun?.config?.model_overrides) || {}).length > 0;

// Tab label mapping for breadcrumb
const tabLabels: Record<string, string> = {
  overview: 'Overview', topics: 'Topics', personas: 'Personas',
  questions: 'Questions', citations: 'Citations', competitors: 'Competitors',
  wikipedia: 'Wikipedia', reddit: 'Reddit', 'pr-outreach': 'PR / Media', youtube: 'YouTube',
  audit: 'Page Audit', schema: 'Schema', 'internal-linking': 'Internal links',
  crisis: 'Crisis', actions: 'Actions', compliance: 'Compliance',
};

// Derive current tab path for date picker links
const currentTabPath = activeTab === 'overview' ? 'results' : activeTab;

// Critical count for Actions badge
const criticalCount = tabCounts.actions > 0 ? tabCounts.actions : 0;

// Preserve all query params across tab switches (UX coherence)
const currentQuery = Astro.url.searchParams.toString();

// Range label for breadcrumb context
const rangeContext = rangeParam === 'all' && runs.length > 1 ? ` (${runs.length} scans)` : '';
---

<DashboardLayout title={`${scan.focus_brand || scan.name || scan.domain} - ${tabLabels[activeTab]}`} activeSection="scans" mobileReady={mobileReady}>

  {/* Breadcrumb (Recognition > Recall) */}
  <ScanBreadcrumb
    scanId={scanId}
    scanName={scan.focus_brand || scan.name || scan.domain}
    current={tabLabels[activeTab]}
  />

  {/* Sticky Scan Header (Von Restorff: grade badge stands out) */}
  <div class="static lg:sticky top-0 z-20 bg-white/95 backdrop-blur-sm shadow-sm px-4 lg:px-8 py-3">
    <div class="max-w-5xl flex items-center justify-between gap-4 flex-wrap">
      <div class="flex items-center gap-4 min-w-0">
        {/* Grade badge */}
        <div class={`w-12 h-12 rounded-xl ${grade.bg} shadow-sm flex flex-col items-center justify-center shrink-0`}>
          <span class={`text-lg font-black ${grade.text}`}>{grade.letter}</span>
          <span class={`text-[8px] ${grade.sub}`}>{currentRate}%</span>
        </div>
        <div class="min-w-0">
          <h1 class="text-base font-bold text-charcoal-dark truncate">
            {scan.focus_brand || scan.name || scan.domain}
            {scan.focus_brand && <span class="text-sm font-normal text-charcoal-light ml-2">({scan.domain})</span>}
          </h1>
          <div class="flex items-center gap-3 text-xs text-charcoal-light">
            <Tip id="score_grade">{grade.label}</Tip>
            {delta !== null && (
              <span class={`font-semibold ${delta > 0 ? 'text-emerald-600' : delta < 0 ? 'text-red-500' : 'text-charcoal-light'}`}>
                {delta > 0 ? '\u2191' : delta < 0 ? '\u2193' : '\u2192'}{Math.abs(delta).toFixed(1)}pts
              </span>
            )}
            {eraNote && (
              <span class="font-semibold text-charcoal-light cursor-help" title={eraNote}>
                &#10227; models updated
              </span>
            )}
            {sparkSvg && <Fragment set:html={sparkSvg} />}
          </div>
        </div>
      </div>
      <div class="flex items-center gap-3 shrink-0 flex-wrap">
        <ScanProviderFilter
          currentProvider={providerParam}
          availableProviders={overview?.providers || ['openai']}
          currentTab={activeTab}
          scanId={scanId}
          otherParams={currentQuery}
        />
        <ScanDateRangePicker
          runs={runs}
          currentRange={rangeParam}
          fromDate={fromParam}
          toDate={toParam}
          currentTab={activeTab}
          rootScanId={rootScanId}
        />
        {/* S15.4 auto-rescan schedule picker. Inline next to Rescan so the
            "every week" mental model is right next to "do it now". The
            inline relative time ("next in 7d") gives instant confidence
            the toggle actually took. */}
        <div
          x-data={`{
            sched: '${(scan as any).schedule || 'manual'}',
            next: ${(scan as any).next_run_at ? `'${(scan as any).next_run_at}'` : 'null'},
            saving: false,
            err: '',
            get nextLabel() {
              if (!this.next || this.sched === 'manual') return '';
              const d = new Date(this.next).getTime() - Date.now();
              const days = Math.round(d / 86400000);
              if (days <= 0) return 'due now';
              if (days === 1) return 'next in 1d';
              return 'next in ' + days + 'd';
            },
            async change(ev) {
              const v = ev.target.value;
              const prev = this.sched;
              this.sched = v;
              this.err = '';
              this.saving = true;
              try {
                const r = await fetch('/api/scans/${scanId}', {
                  method: 'PATCH',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ schedule: v }),
                });
                if (!r.ok) {
                  const j = await r.json().catch(() => ({}));
                  this.err = j.detail || 'Failed';
                  this.sched = prev;
                } else {
                  const j = await r.json();
                  this.next = j.next_run_at || null;
                }
              } catch (e) {
                this.err = (e && e.message) || 'Network error';
                this.sched = prev;
              }
              this.saving = false;
            },
          }`}
          class="flex items-center gap-2"
          title="Auto-rescan schedule"
        >
          <select
            @change="change($event)"
            :disabled="saving"
            class="text-xs border border-gray-200 rounded-lg px-2 py-1.5 text-charcoal-dark bg-white hover:border-coral focus:outline-none focus:border-coral disabled:opacity-50"
          >
            <option value="manual" :selected="sched==='manual'">Manual</option>
            <option value="weekly" :selected="sched==='weekly'">Weekly</option>
            <option value="monthly" :selected="sched==='monthly'">Monthly</option>
          </select>
          <span x-show="nextLabel && !err" x-text="nextLabel" class="text-[10px] text-charcoal-light"></span>
          <span x-show="err" x-text="err" class="text-[10px] text-red-500"></span>
        </div>
        {/* Rescan settings - LINEAGE settings stored on the root, editable
            between scans : Sampling (N runs, precision - no era needed, the
            CI display carries it) + model versions (BYOK selector - the next
            rescan applies it and the trend marks a new model era, P3).
            History stays one continuous series across every change. */}
        <div x-data={`modelsPanel('${rootScanId}')`} class="relative">
          <button
            @click="toggle()"
            class="text-xs border border-gray-200 rounded-lg px-2 py-1.5 text-charcoal-dark bg-white hover:border-coral focus:outline-none focus:border-coral"
            title={hasModelOverrides
              ? 'Sampling and AI model versions used by the next rescan - custom model version active'
              : 'Sampling and AI model versions used by the next rescan'}
          >
            Rescan settings
            {hasModelOverrides && <span class="inline-block w-1.5 h-1.5 rounded-full bg-coral ml-1 align-middle"></span>}
          </button>
          <div x-show="open" @click.outside="open = false" style="display:none"
               class="absolute right-0 mt-2 w-80 bg-white border border-gray-200 rounded-xl shadow-lg p-4 z-30 text-left">
            <p class="text-xs font-semibold text-charcoal-dark mb-2">Next rescan</p>
            <template x-if="loading">
              <p class="text-xs text-charcoal-light">Loading...</p>
            </template>
            <template x-if="!loading && loaded">
              <div>
                <label class="block mb-1 text-[11px] text-charcoal-light">
                  <span class="font-semibold text-charcoal-dark">Sampling</span>
                  <span class="float-right font-semibold text-charcoal-dark" x-text="runsDepth + ' run' + (runsDepth > 1 ? 's' : '')"></span>
                  {/* Free 1-20 (the server always allowed it - only the UI was
                      preset-locked). A slider works HERE because the credits
                      line below updates live while dragging ; save on release. */}
                  <input type="range" min="1" max="20" step="1" class="w-full mt-1 accent-coral"
                         :value="runsDepth"
                         :disabled="saving"
                         @input="runsDepth = parseInt($event.target.value, 10) || 1"
                         @change="saveSampling($event.target.value)"
                         title="How many times each question is asked to each AI. More runs = a mention rate with a real margin of error. 1 credit = 1 question x 1 run." />
                  <span class="flex justify-between text-[9px] text-gray-400"><span>1</span><span>10 recommended</span><span>20</span></span>
                </label>
                <p class="text-[10px] text-charcoal-light" x-text="creditsLine()"></p>
                <p class="text-[10px] text-charcoal-light mb-2" x-show="estCostLine()" x-text="estCostLine()"
                   title="Estimated from observed token usage per model - your provider invoices are authoritative. Includes the selected AIs at their chosen versions plus the brand-extraction analyzer reading every answer."></p>

                <div class="mb-2 text-[11px] text-charcoal-light border-t border-gray-100 pt-2">
                  <span class="font-semibold text-charcoal-dark">AIs surveyed</span>
                  <div class="flex gap-4 mt-1">
                    <label class="inline-flex items-center gap-1.5 cursor-pointer">
                      <input type="checkbox" :checked="providers.includes('openai')" :disabled="saving" @change="toggleProvider('openai')" />
                      OpenAI
                    </label>
                    <label class="inline-flex items-center gap-1.5 cursor-pointer">
                      <input type="checkbox" :checked="providers.includes('gemini')" :disabled="saving" @change="toggleProvider('gemini')" />
                      Gemini
                    </label>
                  </div>
                  <p class="text-[10px] text-charcoal-light mt-1">
                    Adding or removing an AI is annotated on your trend as a coverage change.
                    More AIs (Mistral, Claude) will appear here when their scanning ships.
                  </p>
                </div>

                <template x-if="!byokCovered">
                  <p class="text-[11px] text-charcoal-light border-t border-gray-100 pt-2">
                    <span class="font-semibold text-charcoal-dark">AI model versions :</span>
                    sen-ai platform models. Platform upgrades apply automatically and are
                    annotated on your trend as a model era - your history stays one continuous
                    series. Choosing specific versions requires your own API keys :
                    <a href="/app/settings/api-keys" class="text-coral hover:underline">Manage API keys</a>.
                  </p>
                </template>
                <template x-if="byokCovered">
                  <div class="border-t border-gray-100 pt-2">
                    <template x-for="prov in Object.keys(options)" :key="prov">
                      <label class="block mb-1 text-[11px] text-charcoal-light" x-show="providers.includes(prov)">
                        <span class="font-semibold text-charcoal-dark" x-text="prov === 'openai' ? 'OpenAI model' : 'Gemini model'"></span>
                        <select class="mt-1 w-full text-[11px] border border-gray-200 rounded px-1.5 py-1 bg-white"
                                :disabled="saving || (options[prov] || []).length < 2"
                                @change="save(prov, $event.target.value)">
                          <template x-for="opt in options[prov]" :key="opt.model">
                            <option :value="opt.model" :title="(opt.tag || opt.note) + ' - ' + opt.price"
                                    :selected="selected(prov) === opt.model"
                                    x-text="opt.label"></option>
                          </template>
                        </select>
                        <span class="block text-[10px] text-charcoal-light mt-0.5" x-text="optionNote(prov)"></span>
                      </label>
                    </template>
                    <p class="text-[10px] text-charcoal-light mt-1">
                      Changing models never breaks your history : the trend marks a new model
                      era at that point instead of pretending the numbers are comparable across it.
                    </p>
                  </div>
                </template>
                <p class="text-[10px] mt-1" :class="err ? 'text-red-500' : 'text-emerald-600'"
                   x-show="err || savedMsg" x-text="err || savedMsg"></p>
              </div>
            </template>
            <p class="text-[10px] text-red-500 mt-1" x-show="!loading && !loaded && err" x-text="err"></p>
          </div>
        </div>
        <button
          id="rescanBtn"
          class="px-4 py-2 bg-coral text-white rounded-lg text-sm font-medium hover:bg-coral-dark hover:shadow-md transition-all"
        >
          Rescan
        </button>
      </div>
    </div>
  </div>

  {/* Horizontal Tabs (Hick's: 5 tabs, Serial Position: Overview first, Actions last) */}
  <ScanTabs
    scanId={scanId}
    activeTab={activeTab}
    counts={tabCounts}
    criticalCount={criticalCount}
    queryString={currentQuery}
  />

  {/* Page content */}
  <div class="px-4 lg:px-8 max-w-5xl pb-8 pt-6">
    {headerData.error && (
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-red-700 text-sm mb-6">
        {headerData.error}
      </div>
    )}
    <slot />
  </div>

  {/* Chart.js CDN - loaded only on scan result pages */}
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js"></script>

  {/* Chart.js global defaults - storytellingwithdata: eliminate clutter */}
  <script is:inline>
    if (typeof Chart !== 'undefined') {
      Chart.defaults.font.family = "system-ui, -apple-system, 'Segoe UI', sans-serif";
      Chart.defaults.font.size = 12;
      Chart.defaults.color = '#9ca3af';
      Chart.defaults.plugins.legend.display = false;
      Chart.defaults.plugins.tooltip.backgroundColor = '#1f2937';
      Chart.defaults.plugins.tooltip.cornerRadius = 8;
      Chart.defaults.plugins.tooltip.padding = { top: 8, bottom: 8, left: 12, right: 12 };
      Chart.defaults.plugins.tooltip.titleFont = { size: 11, weight: 'normal' };
      Chart.defaults.plugins.tooltip.bodyFont = { size: 13, weight: 'bold' };
      Chart.defaults.animation.duration = 300;
      Chart.defaults.elements.bar.borderRadius = 4;
      Chart.defaults.elements.bar.borderSkipped = false;
      Chart.defaults.elements.line.tension = 0.3;
      Chart.defaults.elements.point.radius = 3;
      Chart.defaults.elements.point.hoverRadius = 5;
      Chart.defaults.scale.grid.display = false;
      Chart.defaults.scale.border = { display: false };
      Chart.defaults.responsive = true;
      Chart.defaults.maintainAspectRatio = false;
    }
  </script>

  {/* Global: highlight brand mentions in LLM response text
      Von Restorff Effect (lawsofux): highlighted brands stand out from plain text.
      Preattentive attribute (storytellingwithdata): color processed before conscious thought.
      YOUR brand = emerald highlight, competitors = orange highlight. */}
  <script is:inline>
    window._escHtml = function(s) {
      var d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    };
    window._escRx = function(s) {
      return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    };
    window.highlightResponse = function(text, brandMentions) {
      if (!text) return '';
      var html = window._escHtml(text);
      if (!brandMentions || !brandMentions.length) return html;
      var seen = {};
      var sorted = brandMentions.slice().sort(function(a, b) {
        return (b.brand_name || '').length - (a.brand_name || '').length;
      });
      for (var i = 0; i < sorted.length; i++) {
        var bm = sorted[i];
        var name = bm.brand_name;
        if (!name || seen[name.toLowerCase()]) continue;
        seen[name.toLowerCase()] = true;
        var cls = bm.est_marque_cible
          ? 'background:#d1fae5;color:#065f46;padding:1px 3px;border-radius:3px;font-weight:500'
          : 'background:#ffedd5;color:#9a3412;padding:1px 3px;border-radius:3px;font-weight:500';
        var rx = new RegExp('(' + window._escRx(name) + ')', 'gi');
        html = html.replace(rx, '<mark style="' + cls + '">$1</mark>');
      }
      return html;
    };

    /* Sprint 7 — highlight a single cited URL (and its bare domain) inside
       the raw LLM response_text. Same yellow style as Tip/contexte preview.
       Used by competitors.astro to render the response inline with the
       citation visually anchored.

       Gemini wraps its citations in vertex redirect URLs (vertexaisearch.
       cloud.google.com/grounding-api-redirect/...), so the canonical URL
       never appears in the response text. To still anchor the citation
       visually we also highlight the bare brand name extracted from the
       host (e.g. "vichy" from "www.vichy.fr") - usually appears in the
       page title that Gemini lists alongside each redirect URL. */
    window.highlightUrlInResponse = function(text, url, targetBrand, competitorBrands) {
      if (!text) return { html: '', matched: false };
      var html = window._escHtml(text);
      // Three distinct colors so the user can read the discussion at
      // a glance : yellow URL, emerald target, orange competitor.
      var styleUrl    = 'background:#fde68a;color:#1f2937;padding:1px 3px;border-radius:3px;font-weight:500';
      var styleTarget = 'background:#d1fae5;color:#065f46;padding:1px 3px;border-radius:3px;font-weight:600';
      var styleComp   = 'background:#ffedd5;color:#9a3412;padding:1px 3px;border-radius:3px;font-weight:600';
      var matched = false;
      var markFor = function(style) {
        return function(m) { matched = true; return '<mark style="' + style + '">' + m + '</mark>'; };
      };

      var host = '';
      try { host = new URL(url || '').hostname.replace(/^www\./, ''); } catch (_) {}

      // 1. URL + bare domain (yellow).
      if (url) {
        html = html.replace(new RegExp('(' + window._escRx(url) + ')', 'gi'), markFor(styleUrl));
      }
      if (host) {
        html = html.replace(new RegExp('\\b(' + window._escRx(host) + ')\\b', 'gi'), markFor(styleUrl));
      }
      // 2. Target brand (emerald). Skip very short stems to avoid over-matching.
      //    Also highlight individual word stems (e.g. "Avène" alone when the
      //    full name is "Eau Thermale Avène") since LLM responses often use
      //    the short form. Skip stop-words and length < 4 to avoid noise.
      if (targetBrand && targetBrand.length >= 3) {
        html = html.replace(new RegExp('\\b(' + window._escRx(targetBrand) + ')\\b', 'gi'), markFor(styleTarget));
        var STOPWORDS = { 'eau': 1, 'thermale': 1, 'thermal': 1, 'spring': 1, 'water': 1, 'the': 1, 'la': 1, 'le': 1, 'les': 1, 'de': 1, 'du': 1, 'des': 1, 'avec': 1, 'pour': 1 };
        var words = String(targetBrand).split(/[\s\-_]+/);
        for (var w = 0; w < words.length; w++) {
          var stem = words[w].toLowerCase();
          if (stem.length >= 4 && !STOPWORDS[stem]) {
            html = html.replace(new RegExp('\\b(' + window._escRx(words[w]) + ')\\b', 'gi'), markFor(styleTarget));
          }
        }
      }
      // 3. Competitor brands (orange). Sorted by length desc so longer
      //    names match first (avoid stem-stealing). Skip <3 chars.
      if (competitorBrands && competitorBrands.length) {
        var sorted = competitorBrands.slice().filter(function(n) { return n && n.length >= 3; });
        sorted.sort(function(a, b) { return b.length - a.length; });
        for (var i = 0; i < sorted.length; i++) {
          html = html.replace(new RegExp('\\b(' + window._escRx(sorted[i]) + ')\\b', 'gi'), markFor(styleComp));
        }
      }
      return { html: html, matched: matched };
    };
  </script>

  {/* Rescan script */}
  <script is:inline define:vars={{ scanId }}>
    document.getElementById('rescanBtn')?.addEventListener('click', async function() {
      if (!confirm('Run a new scan with the same settings? This will consume scan credits.')) return;
      this.disabled = true;
      this.textContent = 'Creating...';
      try {
        const res = await fetch('/api/scans/' + scanId + '/rescan', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        if (res.ok) {
          const data = await res.json();
          // The rescan endpoint returns a serialized scan : the id field is
          // `id` (scan_id was undefined -> redirected to /app/scans/undefined).
          window.location.href = '/app/scans/' + (data.id || data.scan_id);
        } else {
          const err = await res.json().catch(() => ({}));
          const d = err && err.detail;
          alert((d && d.message) || (typeof d === 'string' ? d : 'Rescan failed'));
          this.disabled = false;
          this.textContent = 'Rescan';
        }
      } catch (e) {
        alert('Network error: ' + e.message);
        this.disabled = false;
        this.textContent = 'Rescan';
      }
    });
  </script>

  {/* Model-versions panel (header "AI models" button). Lazy load : options
      + BYOK state ride /cost-estimate on first open, saves PATCH the ROOT
      config (rescans copy the root, so that's where the lineage setting
      lives). */}
  <script is:inline>
    document.addEventListener('alpine:init', () => {
      Alpine.data('modelsPanel', (rootId) => ({
        open: false, loading: false, loaded: false,
        byokCovered: false, options: {}, overrides: {},
        runsDepth: 1, activeQuestions: 0, providers: [], analyzerCost: 0,
        saving: false, err: '', savedMsg: '',
        toggle() { this.open = !this.open; if (this.open && !this.loaded && !this.loading) this.load(); },
        async load() {
          this.loading = true; this.err = '';
          try {
            const r = await fetch('/api/scans/' + rootId + '/cost-estimate');
            if (r.ok) {
              const j = await r.json();
              this.byokCovered = !!j.byok_covered;
              this.options = j.model_options || {};
              this.overrides = j.model_overrides || {};
              this.runsDepth = j.runs_depth || 1;
              this.activeQuestions = j.active_questions || 0;
              this.providers = j.providers || ['openai'];
              this.analyzerCost = j.est_analyzer_cost_per_response || 0;
              this.loaded = true;
            } else { this.err = 'Could not load model options (' + r.status + ')'; }
          } catch { this.err = 'Network error'; }
          this.loading = false;
        },
        creditsLine() {
          const full = this.activeQuestions * this.runsDepth;
          const credits = this.byokCovered ? Math.ceil(full / 2) : full;
          return this.activeQuestions + ' questions x ' + this.runsDepth + ' run' + (this.runsDepth > 1 ? 's' : '')
            + (this.byokCovered ? ' x 50% BYOK' : '') + ' = ' + credits.toLocaleString('en-US')
            + ' credit' + (credits !== 1 ? 's' : '') + ' per rescan';
        },
        async saveSampling(v) {
          const n = Math.max(1, Math.min(20, parseInt(v, 10) || 1));
          const prev = this.runsDepth;
          this.runsDepth = n; this.saving = true; this.err = ''; this.savedMsg = '';
          try {
            const r = await fetch('/api/scans/' + rootId + '/config', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ runs_depth: n }),
            });
            if (r.ok) { this.savedMsg = 'Saved - applies from the next rescan'; }
            else {
              const j = await r.json().catch(() => ({}));
              const d = j && j.detail;
              this.err = (typeof d === 'string' ? d : 'Save failed (' + r.status + ')');
              this.runsDepth = prev;
            }
          } catch { this.err = 'Network error'; this.runsDepth = prev; }
          this.saving = false;
        },
        selected(p) {
          const list = this.options[p] || [];
          return this.overrides[p] || (list[0] && list[0].model) || '';
        },
        fmtUsd(v) { return v < 1 ? '$' + v.toFixed(2) : '$' + Math.round(v).toLocaleString('en-US'); },
        optionNote(p) {
          const e = (this.options[p] || []).find(o => o.model === this.selected(p));
          if (!e) return '';
          let note = (e.tag || e.note) + ' - ' + e.price;
          if (e.est_cost_per_call && this.byokCovered) {
            note += ' - est. ~' + this.fmtUsd(e.est_cost_per_call * this.activeQuestions * this.runsDepth) + ' per rescan on your key';
          }
          return note;
        },
        estCostLine() {
          // Estimated provider spend per rescan on the org's own keys :
          // selected AIs at their chosen versions + the analyzer reading
          // every answer. Estimates from observed usage - the provider
          // invoice is authoritative.
          if (!this.byokCovered) return '';
          const calls = this.activeQuestions * this.runsDepth;
          let total = 0;
          for (const p of this.providers) {
            const e = (this.options[p] || []).find(o => o.model === this.selected(p));
            if (e && e.est_cost_per_call) total += e.est_cost_per_call * calls;
          }
          // Analyzer : per-answer at N=1 ; ONE consensus call per question x AI
          // over the N concatenated answers at N>1 (~2x a single read).
          total += (this.analyzerCost || 0) * this.activeQuestions * this.providers.length * (this.runsDepth > 1 ? 2 : 1);
          return total > 0 ? 'Estimated AI cost : ~' + this.fmtUsd(total) + ' per rescan, billed to your API keys' : '';
        },
        async toggleProvider(p) {
          const has = this.providers.includes(p);
          const next = has ? this.providers.filter(x => x !== p) : this.providers.concat([p]);
          if (!next.length) {
            this.err = 'Keep at least one AI';
            this.providers = this.providers.slice(); // re-sync the checkbox
            return;
          }
          const prev = this.providers;
          this.providers = next; this.saving = true; this.err = ''; this.savedMsg = '';
          try {
            const r = await fetch('/api/scans/' + rootId + '/config', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ providers: next }),
            });
            if (r.ok) { this.savedMsg = 'Saved - applies from the next rescan'; }
            else {
              const j = await r.json().catch(() => ({}));
              const d = j && j.detail;
              this.err = (typeof d === 'string' ? d : 'Save failed (' + r.status + ')');
              this.providers = prev;
            }
          } catch { this.err = 'Network error'; this.providers = prev; }
          this.saving = false;
        },
        async save(p, model) {
          const prev = Object.assign({}, this.overrides);
          const next = Object.assign({}, this.overrides);
          const dflt = ((this.options[p] || [])[0] || {}).model;
          if (!model || model === dflt) delete next[p]; else next[p] = model;
          this.overrides = next; this.saving = true; this.err = ''; this.savedMsg = '';
          try {
            const r = await fetch('/api/scans/' + rootId + '/config', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ model_overrides: next }),
            });
            if (r.ok) { this.savedMsg = 'Saved - applies from the next rescan'; }
            else {
              const j = await r.json().catch(() => ({}));
              const d = j && j.detail;
              this.err = (d && d.message) || (typeof d === 'string' ? d : 'Save failed (' + r.status + ')');
              this.overrides = prev;
            }
          } catch { this.err = 'Network error'; this.overrides = prev; }
          this.saving = false;
        },
      }));
    });
  </script>
</DashboardLayout>
