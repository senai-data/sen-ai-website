---
/**
 * Sprint 15 - Landing publique agences.
 *
 * Argumentaire commercial pour les agences marketing qui veulent revendre le
 * suivi de visibilite IA a leurs propres clients. La plomberie multi-tenant
 * existe deja (Phase E.C.1/2 organizations + roles par workspace).
 *
 * Langue 2026-07-18 : cette page est FRANCAISE parce qu'elle est dans le
 * tunnel francais - la nav dit "Agences" et /pricing dit "Voir l'offre
 * agences". Le jumeau anglais vit a /en/agency, vers lequel pointent les
 * surfaces anglaises de l'app (welcome, agency overview, bulk). Paire
 * declaree en hreflang.
 *
 * Pas d'authentification requise.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout lang="fr" title="Pour les agences | sen-ai.fr" description="Suivez la visibilité IA de 10 à 100 marques clientes depuis un seul espace. Multi-tenant par conception, tarifs dégressifs, marque blanche sur demande." alternates={{ fr: '/agency', en: '/en/agency' }}>
  <Nav />
  <main class="pt-24 pb-20 px-4">
    <div class="max-w-5xl mx-auto">

      <!-- Hero -->
      <section class="text-center mb-16">
        <div class="flex justify-center mb-4">
          <a href="/en/agency" class="text-sm text-charcoal-light hover:text-coral underline">English &rarr;</a>
        </div>
        <p class="text-coral uppercase tracking-[0.25em] text-sm font-medium mb-4">Pour les agences</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-charcoal-dark mb-4 leading-tight">
          Revendez le suivi de visibilité IA<br/>sous votre propre marque.
        </h1>
        <p class="text-lg text-charcoal-light max-w-2xl mx-auto leading-relaxed">
          Suivez comment ChatGPT, Gemini, Claude et Mistral citent 10 à 100 marques clientes depuis
          un espace centralisé. Multi-tenant par conception. Tarifs dégressifs. Marque blanche sur demande.
        </p>
        <div class="flex items-center justify-center gap-3 mt-8 flex-wrap">
          <a href="/register?intent=agency" class="inline-flex items-center gap-2 px-8 py-4 bg-coral text-white font-medium rounded-xl text-base hover:bg-coral-dark hover:shadow-lg transition-all">
            Commencer gratuitement
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
          <a href="mailto:contact@sen-ai.fr?subject=Tarifs%20agence%20-%20devis%20volume" class="inline-flex items-center gap-2 px-8 py-4 border-2 border-charcoal-dark text-charcoal-dark font-medium rounded-xl text-base hover:bg-charcoal-dark hover:text-white transition-all">
            Demander un devis volume
          </a>
        </div>
      </section>

      <!-- Pourquoi sen-ai pour les agences -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-charcoal-dark text-center mb-8">Pourquoi les agences choisissent sen-ai</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <div class="w-10 h-10 bg-coral/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
            </div>
            <h3 class="font-bold text-charcoal-dark mb-2">Un seul compte, N espaces</h3>
            <p class="text-sm text-charcoal-light leading-relaxed">
              Créez un espace de travail par client. Chaque espace suit sa propre marque, ses
              concurrents, ses scans et ses crédits contenu. On passe de l'un à l'autre depuis le
              menu de l'en-tête, sans se reconnecter.
            </p>
          </div>
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <div class="w-10 h-10 bg-coral/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            </div>
            <h3 class="font-bold text-charcoal-dark mb-2">Des rôles d'équipe précis</h3>
            <p class="text-sm text-charcoal-light leading-relaxed">
              Rôles propriétaire / admin / membre au niveau de l'organisation, croisés avec des rôles
              gestionnaire / éditeur / lecteur par espace. Les analystes juniors restent en lecture
              seule sur les gros comptes. Les responsables de compte lancent les scans. Vous décidez
              qui voit la facturation.
            </p>
          </div>
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <div class="w-10 h-10 bg-coral/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h3 class="font-bold text-charcoal-dark mb-2">Conformité prête pour les achats</h3>
            <p class="text-sm text-charcoal-light leading-relaxed">
              Rapport de transparence par scan, modèle d'AIPD au niveau de l'organisation et page
              méthodologie publique. Pensé pour les revues achats liées au règlement européen sur
              l'IA (applicable en août 2026). Vos clients cochent la case.
            </p>
          </div>
        </div>
      </section>

      <!-- Ce que contient chaque espace -->
      <section class="mb-16 bg-gradient-to-br from-coral/5 to-white rounded-3xl p-10 border border-coral/20">
        <h2 class="text-2xl font-bold text-charcoal-dark text-center mb-8">Chaque espace de travail inclut</h2>
        <div class="grid md:grid-cols-2 gap-x-10 gap-y-3 max-w-3xl mx-auto">
          {[
            ['Vue d\'ensemble', 'Taux de citation, taux de mention de la marque, sentiment, courbe de tendance'],
            ['Sujets et personas', 'Personas côté acheteur générés automatiquement à partir du domaine client'],
            ['Questions', '5 types de questions par persona, formulées sans nommer la marque'],
            ['Citations', 'Chaque URL citée par les IA, avec le détail par question et par modèle'],
            ['Wikipédia', 'Détection d\'une présence Wikipédia absente ou faible, marque et concurrents'],
            ['Audit de pages', 'Audit GEO 7 motifs (étude Princeton) sur les pages citées du client'],
            ['Schema', 'Audit JSON-LD et générateur par type de page'],
            ['Concurrents', 'Rétro-ingénierie des 5 principaux rivaux - pages, schemas, backlinks'],
            ['Reddit', 'Fils que les IA citent pour la marque ou ses concurrents, et leur sentiment'],
            ['RP et médias', 'Domaines de presse qui citent les concurrents mais pas le client'],
            ['Maillage interne', 'Topologie des pages orphelines, culs-de-sac et hubs, qualité des ancres'],
            ['YouTube', 'Chaînes de créateurs que les IA citent pour la marque et ses rivaux'],
            ['Radar de crise', 'Instantané des sentiments négatifs et modèles de réponse associés'],
            ['Conformité', 'Rapport de transparence par scan, journal d\'audit et modèle d\'AIPD'],
          ].map(([k, v]) => (
            <div class="flex items-baseline gap-2">
              <span class="text-coral mt-0.5">✓</span>
              <span class="text-sm text-charcoal-dark"><strong>{k}.</strong> <span class="text-charcoal-light">{v}</span></span>
            </div>
          ))}
        </div>
      </section>

      <!-- Tarifs -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-charcoal-dark text-center mb-3">Tarifs dégressifs</h2>
        <p class="text-charcoal-light text-center max-w-2xl mx-auto mb-10">
          Achetez vos crédits scan et contenu par packs taillés pour une agence. Les crédits n'expirent
          jamais. Les espaces puisent dans une réserve commune : un mois calme chez le client A libère
          des scans pour le client B.
        </p>
        <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <p class="text-[10px] text-charcoal-light uppercase tracking-wide font-semibold mb-2">Pour les petits studios</p>
            <h3 class="text-lg font-bold text-charcoal-dark mb-1">Pack Agence</h3>
            <p class="text-xs text-charcoal-light mb-4">Jusqu'à 10 espaces clients, réserve de crédits commune</p>
            <div class="mb-3">
              <span class="text-3xl font-bold text-charcoal-dark">300 €</span>
              <span class="text-sm text-charcoal-light ml-1">/ 5 000 crédits scan</span>
            </div>
            <p class="text-[10px] text-emerald-600 font-medium mb-5">0,06 € le crédit scan · 25 % de remise sur le tarif à l'unité</p>
            <a href="/register?intent=agency" class="block w-full py-2.5 border-2 border-coral text-coral font-medium rounded-lg hover:bg-coral hover:text-white transition-all text-center text-sm">
              Commencer gratuitement
            </a>
          </div>

          <div class="bg-white rounded-2xl border-2 border-coral shadow-lg shadow-coral/10 p-6 relative">
            <div class="absolute -top-3 left-6 bg-coral text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wide">
              Recommandé
            </div>
            <p class="text-[10px] text-charcoal-light uppercase tracking-wide font-semibold mb-2">Pour les agences de taille moyenne</p>
            <h3 class="text-lg font-bold text-charcoal-dark mb-1">Pack Enterprise</h3>
            <p class="text-xs text-charcoal-light mb-4">Jusqu'à 50 espaces, file prioritaire, support Slack</p>
            <div class="mb-3">
              <span class="text-3xl font-bold text-charcoal-dark">1 000 €</span>
              <span class="text-sm text-charcoal-light ml-1">/ 20 000 crédits scan</span>
            </div>
            <p class="text-[10px] text-emerald-600 font-medium mb-5">0,05 € le crédit scan · 38 % de remise</p>
            <a href="/register?intent=agency" class="block w-full py-2.5 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark hover:shadow-md transition-all text-center text-sm">
              Commencer gratuitement
            </a>
          </div>

          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <p class="text-[10px] text-charcoal-light uppercase tracking-wide font-semibold mb-2">Pour les grands réseaux</p>
            <h3 class="text-lg font-bold text-charcoal-dark mb-1">Sur mesure</h3>
            <p class="text-xs text-charcoal-light mb-4">Plus de 50 espaces, marge négociée, marque blanche</p>
            <div class="mb-3">
              <span class="text-3xl font-bold text-charcoal-dark">Parlons-en</span>
            </div>
            <p class="text-[10px] text-charcoal-light mb-5">Devis volume, onboarding dédié, échange avec votre DPO</p>
            <a href="mailto:contact@sen-ai.fr?subject=Agence%20-%20devis%20sur%20mesure" class="block w-full py-2.5 border-2 border-charcoal-dark text-charcoal-dark font-medium rounded-lg hover:bg-charcoal-dark hover:text-white transition-all text-center text-sm">
              Nous contacter
            </a>
          </div>
        </div>
        <p class="text-center text-xs text-charcoal-light mt-6">
          Les deux packs incluent 50 crédits scan offerts sur le premier espace. Sans abonnement.
          <a href="/pricing" class="text-coral hover:text-coral-dark font-medium">Voir les tarifs à l'unité →</a>
        </p>
      </section>

      <!-- Mise en place -->
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-charcoal-dark text-center mb-8">Comment une agence met sen-ai en place</h2>
        <div class="space-y-4 max-w-3xl mx-auto">
          {[
            ['1', 'Créez votre compte avec votre email professionnel', 'Gratuit, sans carte bancaire. Vous arrivez directement sur votre premier espace.'],
            ['2', 'Créez un espace par client', 'Depuis le menu de l\'en-tête. Chaque espace suit un domaine de marque et ses concurrents.'],
            ['3', 'Invitez votre équipe avec des rôles précis', 'Au niveau organisation (propriétaire / admin / membre) et par espace (gestionnaire / éditeur / lecteur). Les juniors restent en lecture seule ; les responsables de compte lancent les scans.'],
            ['4', 'Achetez un pack de crédits volume', 'La réserve est partagée entre les espaces, qui y puisent au fil des scans.'],
            ['5', 'Lancez le premier scan', 'Choisissez un client, sélectionnez les sujets, lancez. 10 à 15 minutes de bout en bout.'],
            ['6', 'Transmettez le rapport de transparence', 'Chaque scan produit un rapport de conformité prêt à imprimer. À transmettre au service achats ou au DPO de votre client.'],
          ].map(([step, title, desc]) => (
            <div class="flex gap-4 items-start bg-white rounded-xl border border-gray-200 p-5">
              <div class="w-9 h-9 bg-coral/10 rounded-lg flex items-center justify-center shrink-0">
                <span class="text-sm font-bold text-coral">{step}</span>
              </div>
              <div>
                <p class="font-semibold text-charcoal-dark text-sm mb-0.5">{title}</p>
                <p class="text-[13px] text-charcoal-light leading-relaxed">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="mb-16 max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-charcoal-dark mb-6 text-center">Questions des agences</h2>
        <div class="space-y-3">
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-charcoal-dark hover:bg-gray-50 list-none flex justify-between items-center">
              Puis-je mettre le dashboard en marque blanche ?
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-charcoal-light leading-relaxed">
              Le produit standard est aux couleurs de sen-ai.fr. La marque blanche et le domaine
              personnalisé font partie de l'offre sur mesure - dites-nous quel niveau de
              personnalisation vous visez.
            </div>
          </details>
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-charcoal-dark hover:bg-gray-50 list-none flex justify-between items-center">
              Quelle marge pour un revendeur ?
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-charcoal-light leading-relaxed">
              Les packs volume vous donnent déjà 25 à 38 % de remise sur le tarif à l'unité. Vous
              fixez librement votre prix de revente. La plupart des agences que nous accompagnons
              intègrent le suivi dans un forfait mensuel plutôt que de refacturer les crédits un à un.
            </div>
          </details>
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-charcoal-dark hover:bg-gray-50 list-none flex justify-between items-center">
              Mon client peut-il se connecter lui-même ?
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-charcoal-light leading-relaxed">
              Oui. Invitez-le comme lecteur sur son propre espace. Il ne voit que ses données, jamais
              celles des autres clients. Vous gardez la facturation et l'administration au niveau de
              l'organisation.
            </div>
          </details>
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-charcoal-dark hover:bg-gray-50 list-none flex justify-between items-center">
              Comment le règlement européen sur l'IA s'applique-t-il à mes clients ?
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-charcoal-light leading-relaxed">
              Nous sommes déployeur d'IA à risque limité au sens de l'article 50 du règlement européen
              sur l'IA (applicable le 2 août 2026). Les obligations de transparence s'appliquent ;
              aucune évaluation de conformité n'est requise. Chaque scan produit un rapport de
              transparence prêt à imprimer, et le tableau de bord de l'organisation inclut un modèle
              d'AIPD pré-rempli que vous adaptez pour votre client. Voir la
              <a href="/fr/methodology" class="text-coral hover:text-coral-dark">page méthodologie</a>.
            </div>
          </details>
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-charcoal-dark hover:bg-gray-50 list-none flex justify-between items-center">
              Où sont hébergées les données ?
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-charcoal-light leading-relaxed">
              Chez Hetzner, à Helsinki en Finlande (UE). Les fournisseurs d'IA (OpenAI, Anthropic)
              opèrent sous EU-US Data Privacy Framework et clauses contractuelles types ; Gemini est
              hébergé dans l'UE via Google Ireland. La liste complète des sous-traitants est dans le
              <a href="/app/compliance" class="text-coral hover:text-coral-dark">centre de conformité de l'application</a>.
            </div>
          </details>
        </div>
      </section>

      <!-- CTA final -->
      <section class="text-center bg-charcoal-dark text-white rounded-3xl px-8 py-14">
        <h2 class="text-2xl sm:text-3xl font-bold mb-3">Prêt à passer à l'échelle sur tout votre portefeuille ?</h2>
        <p class="text-charcoal-light mb-8 max-w-xl mx-auto">
          Commencez gratuitement, créez autant d'espaces que vous avez de clients, et passez à un pack
          volume quand vous avez besoin de plus de crédits.
        </p>
        <div class="flex items-center justify-center gap-3 flex-wrap">
          <a href="/register?intent=agency" class="inline-flex items-center gap-2 px-8 py-4 bg-coral text-white font-medium rounded-xl text-base hover:bg-coral-dark hover:shadow-lg transition-all">
            Créer mon compte agence
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
          <a href="mailto:contact@sen-ai.fr?subject=Tarifs%20agence%20-%20devis%20volume" class="inline-flex items-center gap-2 px-8 py-4 border border-white/30 text-white font-medium rounded-xl text-base hover:bg-white/10 transition-all">
            Nous écrire d'abord
          </a>
        </div>
      </section>

    </div>
  </main>
  <Footer />
</BaseLayout>
