  <script is:inline>
    // Jump-nav scroll-spy : smooth-scroll on click + IntersectionObserver
    // highlights the section currently in the reading band.
    (() => {
      const nav = document.getElementById('cphJump');
      if (!nav) return;
      const links = Array.from(nav.querySelectorAll('a'));
      const map = {};
      links.forEach((l) => {
        const id = l.getAttribute('href').slice(1);
        const el = document.getElementById(id);
        if (el) map[id] = l;
        l.addEventListener('click', (e) => {
          e.preventDefault();
          document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
        });
      });
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.remove('active'));
            map[e.target.id]?.classList.add('active');
          }
        });
      }, { rootMargin: '-15% 0px -75% 0px' });
      Object.keys(map).forEach((id) => obs.observe(document.getElementById(id)));
    })();
  </script>
