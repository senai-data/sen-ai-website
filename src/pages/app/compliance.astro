---
/**
 * Org-level AI Act compliance hub - redesign per 08-compliance.html.
 *
 * Sprint 14 content preserved verbatim (sub-processors registry from
 * src/data/subprocessors.ts, data governance, full 6-section DPIA
 * template, scan audit log) ; restructured visually : sticky jump nav
 * with scroll-spy, 4 honest status cards, .tbl panels, .clog changelog,
 * print-only document header.
 *
 * PRINT : keeps the S14 visibility:hidden + override pattern (memory
 * foot-gun #3 - anything added outside .compliance-hub stays hidden on
 * print unless explicitly overridden). The same HTML is the PDF.
 */
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { SUBPROCESSORS, CHANGELOG, changelogKindLabel } from '../../data/subprocessors';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

const activeOrgCookie = Astro.cookies.get('active_organization_id')?.value;
const activeClientCookie = Astro.cookies.get('active_client_id')?.value;
const upstreamCookie = [
  `token=${token}`,
  activeOrgCookie ? `active_organization_id=${activeOrgCookie}` : null,
  activeClientCookie ? `active_client_id=${activeClientCookie}` : null,
].filter(Boolean).join('; ');

let scans: any[] = [];
let activeClient: any = null;
let activeOrgId: string | null = null;
try {
  const clientsRes = await fetch('http://api:8000/api/clients/', {
    headers: { Cookie: upstreamCookie },
    signal: AbortSignal.timeout(3000),
  });
  const clients = clientsRes.ok ? await clientsRes.json() : [];
  activeClient = clients.find((c: any) => c.id === activeClientCookie) || clients[0] || null;
  if (activeClient?.id) {
    const scansRes = await fetch(`http://api:8000/api/scans?client_id=${activeClient.id}`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(5000),
    });
    scans = scansRes.ok ? await scansRes.json() : [];
  }
  // S14.1 - org id builds the server-side PDF download URL.
  const orgsRes = await fetch('http://api:8000/api/organizations/', {
    headers: { Cookie: upstreamCookie },
    signal: AbortSignal.timeout(3000),
  });
  if (orgsRes.ok) {
    const orgs = await orgsRes.json();
    activeOrgId = (orgs.find((o: any) => o.is_active) || orgs[0])?.id || null;
  }
} catch (_) {}

function fmtDate(iso?: string): string {
  if (!iso) return '-';
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '-';
  return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' });
}

const reportDate = new Date().toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: '2-digit' });
const completedScans = scans.filter((s: any) => s.status === 'completed');
const totalScans = scans.length;
const activeSubs = SUBPROCESSORS.filter((sp) => sp.status === 'active');
const aiProviderCount = activeSubs.filter((sp) => sp.category === 'ai-provider').length;

function scanStatusChip(status: string): string {
  if (status === 'completed') return 'chip--positive';
  if (status === 'failed') return 'chip--critical';
  return 'chip--warning';
}
const kindChip: Record<string, string> = {
  added: 'chip--positive',
  scope_change: 'chip--warning',
  sunset: 'chip--critical',
  restored: 'chip--info',
  initial_disclosure: 'chip--neutral',
};
---

<DashboardLayout title="Compliance" activeSection="dashboard">
  <style is:global>
    /* Page-local vocabulary from 08-compliance.html (.wrap .jump .phead
       .status .stc .shead .panel .tbl .clog .printhead). */
    .cph { display: grid; grid-template-columns: 200px 1fr; gap: 32px; max-width: 1180px; margin: 0 auto; padding: var(--space-7) var(--space-6) var(--space-9); }
    @media (max-width: 899px) { .cph { grid-template-columns: 1fr; } .cph .jump { display: none; } }

    .cph .jump { position: sticky; top: 84px; align-self: start; }
    .cph .jump__l { font-size: 10.5px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--color-text-muted); padding: 0 10px; margin-bottom: 8px; }
    .cph .jump a { display: block; padding: 7px 10px; border-radius: var(--radius-md); font-size: 13px; color: var(--color-text-secondary); text-decoration: none; transition: .12s; border-left: 2px solid transparent; }
    .cph .jump a:hover { background: var(--color-surface); color: var(--color-text-primary); }
    .cph .jump a.active { color: var(--coral-700); font-weight: 600; border-left-color: var(--color-primary); background: var(--color-primary-subtle); }

    .cph .doc { min-width: 0; }
    .cph .printhead { display: none; }

    .cph .phead { display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; margin-bottom: var(--space-5); flex-wrap: wrap; }
    .cph .phead h1 { font-size: 26px; font-weight: 700; letter-spacing: -.025em; color: var(--color-text-primary); display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .cph .phead .reg { font-size: 11px; font-weight: 600; color: var(--color-text-secondary); background: var(--color-surface-muted); border: 1px solid var(--color-border); padding: 3px 9px; border-radius: var(--radius-full); }
    .cph .phead p { font-size: 14px; color: var(--color-text-secondary); margin-top: 7px; max-width: 64ch; }
    .cph .phead__meta { font-size: 12.5px; color: var(--color-text-muted); margin-top: 10px; display: flex; gap: 16px; flex-wrap: wrap; }
    .cph .phead__meta b { color: var(--color-text-secondary); font-weight: 600; }
    .cph .phead__actions { display: flex; gap: 10px; flex: none; }

    .cph .status { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: var(--space-7); }
    @media (max-width: 899px) { .cph .status { grid-template-columns: repeat(2, 1fr); } }
    .cph .stc { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 16px 18px; box-shadow: var(--shadow-xs); }
    .cph .stc__l { font-size: 11px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; color: var(--color-text-muted); }
    .cph .stc__v { font-size: 17px; font-weight: 700; letter-spacing: -.015em; margin-top: 10px; color: var(--color-text-primary); line-height: 1.25; }
    .cph .stc__m { font-size: 12px; color: var(--color-text-muted); margin-top: 7px; }

    .cph section { margin-bottom: var(--space-7); scroll-margin-top: 84px; }
    .cph .shead { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; margin-bottom: var(--space-4); padding-bottom: 12px; border-bottom: 1px solid var(--color-border); }
    .cph .shead h2 { font-size: 18px; font-weight: 680; letter-spacing: -.015em; color: var(--color-text-primary); }
    .cph .shead p { font-size: 13px; color: var(--color-text-muted); margin-top: 3px; max-width: 70ch; }
    .cph .shead__r { font-size: 12.5px; color: var(--color-text-muted); flex: none; }

    .cph .panel { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-xs); overflow: hidden; }
    .cph .panel--pad { padding: var(--space-5); }

    .cph table.tbl { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 13px; }
    .cph table.tbl th { text-align: left; font-size: 11px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; color: var(--color-text-muted); padding: 10px 16px; border-bottom: 1px solid var(--color-border); background: var(--color-surface-sunken); white-space: nowrap; }
    .cph table.tbl td { padding: 11px 16px; border-bottom: 1px solid var(--color-border); color: var(--color-text-secondary); vertical-align: middle; }
    .cph table.tbl tbody tr:last-child td { border-bottom: 0; }
    .cph table.tbl tbody tr:hover { background: var(--color-surface-sunken); }
    .cph .ev { font-weight: 550; color: var(--color-text-primary); }
    .cph .mono { font-family: var(--font-mono); font-size: 11.5px; color: var(--color-text-muted); }

    .cph .kv { width: 100%; font-size: 13px; border-collapse: collapse; }
    .cph .kv th { width: 30%; padding: 10px 16px; text-align: left; color: var(--color-text-muted); font-weight: 600; vertical-align: top; border-bottom: 1px solid var(--color-border); }
    .cph .kv td { padding: 10px 16px; color: var(--color-text-primary); vertical-align: top; border-bottom: 1px solid var(--color-border); }
    .cph .kv tr:last-child th, .cph .kv tr:last-child td { border-bottom: 0; }
    .cph .kv a { color: var(--coral-700); }

    .cph .note { font-size: 12px; color: var(--color-text-muted); font-style: italic; padding: 12px 16px; border-top: 1px dashed var(--color-border); }
    .cph .note a { color: var(--coral-700); }

    .cph .changelog { display: flex; flex-direction: column; }
    .cph .clog { display: grid; grid-template-columns: 130px 1fr; gap: 18px; padding: 14px 0; border-bottom: 1px solid var(--color-border); }
    .cph .changelog .clog:last-child { border-bottom: 0; }
    .cph .clog__date { font-size: 12.5px; color: var(--color-text-muted); }
    .cph .clog__t { font-size: 13.5px; font-weight: 650; color: var(--color-text-primary); display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .cph .clog__d { font-size: 13px; color: var(--color-text-secondary); margin-top: 4px; line-height: 1.5; }

    .cph .dpia-h3 { font-size: 13.5px; font-weight: 700; color: var(--color-text-primary); margin-top: 18px; margin-bottom: 5px; }
    .cph .dpia-h3:first-child { margin-top: 0; }
    .cph .dpia-p { font-size: 12.5px; color: var(--color-text-secondary); line-height: 1.6; margin: 3px 0; }
    .cph .dpia-p strong, .cph .dpia-p b { color: var(--color-text-primary); }
    .cph .dpia-ul { list-style: disc; padding-left: 20px; font-size: 12.5px; color: var(--color-text-secondary); line-height: 1.65; margin-top: 5px; }

    .cph .bullets { list-style: disc; padding-left: 20px; font-size: 13px; color: var(--color-text-secondary); line-height: 1.8; }
    .cph .bullets a { color: var(--coral-700); font-weight: 600; text-decoration: none; }
    .cph .bullets a:hover { color: var(--coral-800); }

    /* ============ PRINT - S14 visibility pattern preserved ============ */
    .screen-only { display: revert; }
    @media print {
      @page { margin: 18mm 16mm; }
      body { background: #fff !important; }
      body * { visibility: hidden !important; }
      .compliance-hub, .compliance-hub * { visibility: visible !important; }
      .compliance-hub { position: absolute !important; left: 0; top: 0; width: 100%; display: block !important; padding: 0 !important; }
      .compliance-hub .jump, .compliance-hub .screen-only { display: none !important; }
      .compliance-hub .printhead { display: block !important; margin-bottom: 14px; padding-bottom: 14px; border-bottom: 2px solid #111; }
      .compliance-hub .printhead__row { display: flex; justify-content: space-between; align-items: flex-end; }
      .compliance-hub .printhead__org { font-size: 15px; font-weight: 700; }
      .compliance-hub .printhead__doc { font-size: 12px; color: #444; margin-top: 2px; }
      .compliance-hub .printhead__date { font-size: 11px; color: #444; text-align: right; }
      .compliance-hub .phead h1 { font-size: 20px; }
      .compliance-hub .status { gap: 8px; }
      .compliance-hub .stc, .compliance-hub .panel { box-shadow: none !important; border: 1px solid #ccc; }
      .compliance-hub .panel { page-break-inside: avoid; }
      .compliance-hub section { page-break-inside: auto; margin-bottom: 22px; }
      .compliance-hub .shead { page-break-after: avoid; }
      .compliance-hub table.tbl tbody tr, .compliance-hub .clog { page-break-inside: avoid; }
      .compliance-hub a[href] { color: inherit !important; text-decoration: none !important; }
    }
  </style>

  <div class="cph compliance-hub">
    {/* JUMP NAV (screen only) */}
    <nav class="jump screen-only" id="cphJump">
      <div class="jump__l">On this page</div>
      <a href="#identity" class="active">Identity</a>
      <a href="#subproc">Sub-processors</a>
      <a href="#governance">Data governance</a>
      <a href="#audit">Audit log</a>
      <a href="#dpia">DPIA template</a>
      <a href="#resources">Resources</a>
    </nav>

    <div class="doc">
      {/* print-only document header */}
      <div class="printhead">
        <div class="printhead__row">
          <div>
            <div class="printhead__org">{activeClient?.name || 'Workspace'} - sen-ai.fr</div>
            <div class="printhead__doc">AI Act compliance record</div>
          </div>
          <div class="printhead__date">Generated {reportDate}</div>
        </div>
      </div>

      <div class="phead">
        <div>
          <h1>AI Act compliance <span class="reg">EU 2024/1689</span></h1>
          <p>
            The org-level record of how this workspace uses generative-AI providers, what data
            it processes, and every scan recorded. Built to attach to a procurement or DPO file.
            Use the per-scan Compliance tab for transparency reports on individual scans.
          </p>
          <div class="phead__meta">
            <span>Report date <b>{reportDate}</b></span>
            <span>Workspace <b>{activeClient?.name || '-'}</b></span>
            <span>Scans recorded <b>{totalScans}</b></span>
          </div>
        </div>
        <div class="phead__actions screen-only">
          <button onclick="window.print()" class="btn btn--secondary btn--md">Browser print</button>
          {activeOrgId && (
            <a href={`/api/organizations/${activeOrgId}/compliance/pdf`} download class="btn btn--primary btn--md">
              <svg class="ic" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 2v8M4.5 6.5L8 10l3.5-3.5M3 13h10"/></svg>
              Download PDF
            </a>
          )}
        </div>
      </div>

      {/* STATUS - factual values only, no fabricated audit verdicts */}
      <div class="status">
        <div class="stc">
          <div class="stc__l">AI Act posture</div>
          <div class="stc__v">Limited-risk deployer</div>
          <div class="stc__m">Title IV, Article 50 - transparency duties</div>
        </div>
        <div class="stc">
          <div class="stc__l">DPIA</div>
          <div class="stc__v">Template provided</div>
          <div class="stc__m">Validate with your DPO before signing</div>
        </div>
        <div class="stc">
          <div class="stc__l">Sub-processors</div>
          <div class="stc__v">{activeSubs.length} active</div>
          <div class="stc__m">{aiProviderCount} generative-AI providers</div>
        </div>
        <div class="stc">
          <div class="stc__l">Scan audit trail</div>
          <div class="stc__v">{totalScans} recorded</div>
          <div class="stc__m">{completedScans.length} completed with full results</div>
        </div>
      </div>

      {/* IDENTITY */}
      <section id="identity">
        <div class="shead">
          <div><h2>Workspace identity</h2><p>The legal anchor of this record - which workspace, which brand, generated when.</p></div>
        </div>
        <div class="panel">
          <table class="kv">
            <tbody>
              <tr><th>Workspace name</th><td>{activeClient?.name || '-'}</td></tr>
              <tr><th>Workspace ID</th><td><span class="mono">{activeClient?.id || '-'}</span></td></tr>
              <tr><th>Brand under monitoring</th><td>{activeClient?.brand || '-'}</td></tr>
              <tr><th>Report date</th><td>{reportDate}</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      {/* SUB-PROCESSORS */}
      <section id="subproc">
        <div class="shead">
          <div>
            <h2>Sub-processors</h2>
            <p>
              Third parties that process data on behalf of this workspace. Each operates under a
              Data Processing Addendum (DPA) and at least one of : EU-US Data Privacy Framework,
              EU Standard Contractual Clauses, or EU-based hosting.
            </p>
          </div>
          <div class="shead__r">{activeSubs.length} active</div>
        </div>
        <div class="panel">
          <table class="tbl">
            <thead>
              <tr><th>Sub-processor</th><th>Purpose</th><th>Hosting region</th><th>Lawful transfer mechanism</th></tr>
            </thead>
            <tbody>
              {activeSubs.map((sp) => (
                <tr>
                  <td class="ev">{sp.legal_entity}</td>
                  <td>{sp.purpose}</td>
                  <td>{sp.hosting_region}</td>
                  <td>{sp.transfer_mechanism}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="note">
            AI providers process prompt text containing brand / domain / topic data only.
            No personal data of your end users is transmitted to any AI provider. Full
            disclosure in our <a href="/privacy" target="_blank">Privacy Policy</a>.
          </p>
        </div>

        {/* changelog - the user-visible mirror of src/data/subprocessors.ts */}
        <div class="shead" style="margin-top:var(--space-5)">
          <div><h2 style="font-size:15px">Sub-processors changelog</h2><p>Versioned record of every registry change, so an old DPA can be checked against what was true at signing.</p></div>
        </div>
        <div class="panel panel--pad">
          <div class="changelog">
            {CHANGELOG.length === 0 && <p style="font-size:12.5px;color:var(--color-text-muted);font-style:italic">No changes recorded yet.</p>}
            {CHANGELOG.map((c) => (
              <div class="clog">
                <div class="clog__date">{c.date}</div>
                <div>
                  <div class="clog__t">
                    <span class={`chip chip--sm ${kindChip[c.kind] || 'chip--neutral'}`}>{changelogKindLabel(c.kind)}</span>
                    {c.subprocessor_id === 'all' ? 'All sub-processors' : (SUBPROCESSORS.find((s) => s.id === c.subprocessor_id)?.legal_entity || c.subprocessor_id)}
                  </div>
                  <div class="clog__d">{c.summary}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* GOVERNANCE */}
      <section id="governance">
        <div class="shead">
          <div><h2>Data governance summary</h2><p>Roles, retention and rights under GDPR for the data this workspace processes.</p></div>
        </div>
        <div class="panel">
          <table class="kv">
            <tbody>
              <tr><th>Data controller</th><td>The customer (you) is the controller for any brand / domain / persona data uploaded to the workspace.</td></tr>
              <tr><th>Data processor</th><td>sen-ai.fr is the processor, acting on the customer&apos;s documented instructions.</td></tr>
              <tr><th>Personal data exposure</th><td>Minimal. Only the email + name of users granted workspace access are stored. AI provider prompts contain no personal data.</td></tr>
              <tr><th>Retention period</th><td>Scan results retained for the duration of the workspace subscription, then 30 days post-cancellation before deletion.</td></tr>
              <tr><th>International transfers</th><td>OpenAI and Anthropic (US) under EU-US Data Privacy Framework + Standard Contractual Clauses. All other sub-processors are EU-hosted.</td></tr>
              <tr><th>Right to access / erase</th><td>Email <a href="mailto:contact@sen-ai.fr">contact@sen-ai.fr</a>. Workspace owner can also delete any scan from the UI at any time.</td></tr>
              <tr><th>Breach notification</th><td>72-hour notification to the customer in case of a confirmed personal data breach, per GDPR Article 33.</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      {/* AUDIT LOG */}
      <section id="audit">
        <div class="shead">
          <div><h2>Audit log</h2><p>Complete list of scans recorded against this workspace. Each row links to the per-scan transparency report.</p></div>
          <div class="shead__r">{totalScans} scan{totalScans === 1 ? '' : 's'}, {completedScans.length} completed</div>
        </div>
        {scans.length === 0 ? (
          <div class="panel panel--pad">
            <p style="font-size:12.5px;color:var(--color-text-muted);font-style:italic">No scans in this workspace yet.</p>
          </div>
        ) : (
          <div class="panel">
            <table class="tbl">
              <thead>
                <tr><th>Scan name</th><th>Domain</th><th>Type</th><th>Status</th><th>Created</th><th>Completed</th><th class="screen-only">Report</th></tr>
              </thead>
              <tbody>
                {scans.map((s: any) => (
                  <tr>
                    <td class="ev">{s.name || s.focus_brand_name || '-'}</td>
                    <td>{s.domain || '-'}</td>
                    <td>{s.scan_type || '-'}</td>
                    <td><span class={`chip chip--sm ${scanStatusChip(s.status)}`}>{s.status}</span></td>
                    <td class="mono">{fmtDate(s.created_at)}</td>
                    <td class="mono">{fmtDate(s.completed_at)}</td>
                    <td class="screen-only"><a href={`/app/scans/${s.id}/compliance`} style="color:var(--coral-700);font-weight:600;font-size:12px;text-decoration:none">Open &rarr;</a></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>

      {/* DPIA */}
      <section id="dpia">
        <div class="shead">
          <div>
            <h2>Data Protection Impact Assessment - template</h2>
            <p>
              The EU AI Act does not by itself require a DPIA, but Article 35 GDPR does when
              processing is likely to result in a high risk to natural persons. For limited-risk
              AI applications like sen-ai a DPIA is typically NOT mandatory, but procurement teams
              often ask for one. Adapt this template, then print to PDF and attach to your DPA.
            </p>
          </div>
        </div>
        <div class="panel panel--pad">
          <h3 class="dpia-h3">1. Processing description</h3>
          <p class="dpia-p"><strong>Service used :</strong> sen-ai.fr - brand visibility analytics across generative AI systems.</p>
          <p class="dpia-p"><strong>Purpose :</strong> Measure how third-party AI systems (ChatGPT, Gemini, Claude, Mistral) reference the customer&apos;s brand and competitors when responding to typical buyer questions. Surface optimisation opportunities.</p>
          <p class="dpia-p"><strong>Categories of data processed :</strong> Brand names, domain names, persona descriptions (fictional), topic taxonomies. No personal data of end users.</p>
          <p class="dpia-p"><strong>Data subjects :</strong> Only the customer&apos;s account holders (workspace users) - identified by email + name.</p>

          <h3 class="dpia-h3">2. Necessity &amp; proportionality</h3>
          <p class="dpia-p"><strong>Lawful basis :</strong> Article 6(1)(b) GDPR - performance of a contract (the SaaS subscription).</p>
          <p class="dpia-p"><strong>Data minimisation :</strong> sen-ai.fr does not collect personal data of the customer&apos;s end users. AI provider prompts contain only brand / domain / topic data.</p>
          <p class="dpia-p"><strong>Retention :</strong> Scan results retained for the active subscription + 30 days. Account data retained per Privacy Policy.</p>

          <h3 class="dpia-h3">3. Risk assessment</h3>
          <p class="dpia-p"><strong>Risk to data subjects :</strong> LOW. The only data subjects are workspace users (employees of the customer). No biometric, health, financial, or special-category data is processed.</p>
          <p class="dpia-p"><strong>Risk of unauthorised access :</strong> Mitigated by encrypted storage at rest, TLS in transit, HttpOnly auth cookies, scoped per-workspace access controls.</p>
          <p class="dpia-p"><strong>Risk of AI bias / discrimination :</strong> The AI systems used are GENERAL-PURPOSE and outside sen-ai.fr&apos;s control. sen-ai.fr does not train or fine-tune any model. Bias risks rest with the upstream AI providers.</p>
          <p class="dpia-p"><strong>Risk of international transfer :</strong> Two sub-processors are US-based (OpenAI, Anthropic). Mitigated by EU-US Data Privacy Framework + Standard Contractual Clauses.</p>

          <h3 class="dpia-h3">4. Safeguards in place</h3>
          <ul class="dpia-ul">
            <li>EU-hosted application + database (Hetzner, Finland)</li>
