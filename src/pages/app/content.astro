---
/**
 * Content Pipeline — Kanban board for FAQ and netlinking articles.
 *
 * Reads from `scan_content_items` table via the new content_items API.
 * Lifecycle columns: TO CREATE → IN REVIEW → APPROVED → PUBLISHED.
 *
 * UX Laws applied :
 * - Goal-Gradient: lifecycle left→right shows progress, status-colored counts
 * - Jakob's Law: Trello-like Kanban convention
 * - Zeigarnik: counts per column keep incomplete tasks visible
 * - Von Restorff: priority badges (red for critique) stand out
 * - Law of Common Region: bordered columns + cards group naturally
 * - Hick's Law: Generate dropdown (FAQ/Article) instead of two side buttons
 * - Serial Position: TO CREATE sorted by priority desc (critique first)
 * - Postel's Law: hover tooltips on truncated questions
 * - Aesthetic-Usability: empty columns explain what'll appear (mental model)
 * - Fitts's Law: filter pills above dropdowns (1-click vs 2-click)
 */
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Tip from '../../components/Tip.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

// Phase MR.2 — tooltip texts for the suggest-media modal KPIs. Defined once
// here (these KPIs appear ONLY in this modal). If they later show up elsewhere
// (e.g. validation page), promote to the shared TIPS dict in
// src/components/Tip.astro per feedback_tooltips.md. Format : ≤2 lines, a
// concrete example in <em>, <br/> for line breaks.
const mediaTips = {
  strategy:
    'Follow = media where a competitor already appears (proven open to articles, on-topic).<br/>'
    + '<em>Avoid = media with no competitor — stand out instead.</em>',
  require_price:
    'On = only media with a known publishing price.<br/>'
    + '<em>Off = also show media you\'d have to contact directly.</em>',
};

// Read filter from query params for SSR-friendly state (browser back/forward)
const ctParam = Astro.url.searchParams.get('content_type') || 'all';
const scanParam = Astro.url.searchParams.get('scan_id') || '';
// "show_rejected=1" surfaces the Rejected column. Off by default — rejected
// is a soft-delete signal so most users don't want noise. But we MUST expose
// the column on demand because Reject is reversible (Regenerate from validation
// page), and otherwise the only way to find a rejected item is the direct URL.
const showRejected = Astro.url.searchParams.get('show_rejected') === '1';

let clientId: string | null = null;
let kanban: any = { items: [], by_column: {}, counts: {}, total: 0 };
let scans: any[] = [];

try {
  const activeOrgCookie = Astro.cookies.get('active_organization_id')?.value;
  const activeClientCookie = Astro.cookies.get('active_client_id')?.value;
  const upstreamCookie = [
    `token=${token}`,
    activeOrgCookie ? `active_organization_id=${activeOrgCookie}` : null,
    activeClientCookie ? `active_client_id=${activeClientCookie}` : null,
  ].filter(Boolean).join('; ');
  const clientsRes = await fetch('http://api:8000/api/clients/', {
    headers: { Cookie: upstreamCookie },
    signal: AbortSignal.timeout(3000),
  });
  const clients = clientsRes.ok ? await clientsRes.json() : [];
  clientId = clients[0]?.id || null;

  if (clientId) {
    // Fetch scans for filter dropdown (latest 20)
    const scansRes = await fetch(`http://api:8000/api/scans?client_id=${clientId}`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(3000),
    });
    if (scansRes.ok) {
      scans = (await scansRes.json()).slice(0, 20);
    }

    // Build content-items query
    const params = new URLSearchParams();
    if (ctParam !== 'all') params.set('content_type', ctParam);
    if (scanParam) params.set('scan_id', scanParam);
    if (showRejected) params.set('include_rejected', 'true');
    const qs = params.toString();
    const url = `http://api:8000/api/clients/${clientId}/content-items${qs ? '?' + qs : ''}`;
    const itemsRes = await fetch(url, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(5000),
    });
    if (itemsRes.ok) {
      kanban = await itemsRes.json();
    }
  }
} catch (e) {}

const baseColumns = [
  {
    key: 'to_create',
    label: 'To create',
    dot: 'var(--sev-medium)',
    emptyMsg: 'Generated content suggestions will land here. Run a scan to discover opportunities.',
    helpMsg: 'Click Generate to create FAQ or article from an opportunity.',
  },
  {
    key: 'in_review',
    label: 'In review',
    dot: 'var(--status-info)',
    emptyMsg: 'Items move here once content is generated, awaiting your review.',
    helpMsg: 'Click a card to review and edit before approving.',
  },
  {
    key: 'approved',
    label: 'Approved',
    dot: 'var(--status-neutral)',
    emptyMsg: 'Approved items appear here, ready to publish.',
    helpMsg: 'Click a card to mark as published.',
  },
  {
    key: 'published',
    label: 'Published',
    dot: 'var(--status-positive)',
    emptyMsg: 'Published content with live URLs and tracking will be visible here.',
    helpMsg: 'Click a card to see latest position metrics.',
  },
];
const rejectedColumn = {
  key: 'rejected',
  label: 'Rejected',
  dot: 'var(--color-text-muted)',
  emptyMsg: 'No rejected items.',
  helpMsg: 'Click a card to regenerate (gives the LLM another shot) or leave as-is.',
};
const columns = showRejected ? [...baseColumns, rejectedColumn] : baseColumns;

const totalAcrossAll = (kanban.counts?.to_create || 0) + (kanban.counts?.in_review || 0)
  + (kanban.counts?.approved || 0) + (kanban.counts?.published || 0);

// Priority chips (components.css .chip variants)
function priorityClass(p: string): string {
  if (p === 'critique') return 'chip--critical';
  if (p === 'haute') return 'chip--warning';
  if (p === 'moyenne') return 'chip--info';
  return 'chip--neutral';
}
function priorityLabel(p: string): string {
  if (p === 'critique') return 'Critical';
  if (p === 'haute') return 'High';
  if (p === 'moyenne') return 'Medium';
  return p || '-';
}

function typeLabel(t: string): string {
  if (t === 'faq') return 'FAQ';
  if (t === 'netlinking_article') return 'Article';
  return t || '-';
}

function ageLabel(iso: string | null): string {
  if (!iso) return '';
  const ms = Date.now() - new Date(iso).getTime();
  const m = Math.floor(ms / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ago`;
  const d = Math.floor(h / 24);
  return `${d}d ago`;
}
---

<DashboardLayout title="Content" activeSection="content">
  <style is:global>
    /* Page-local vocabulary from 09-content.html (.head .fchip .board .col
       .ccard .typechip .lift). Chips from components.css. */
    .ctp { padding: var(--space-6); max-width: 1440px; }
    .ctp .head h1 { font-size: 24px; font-weight: 700; letter-spacing: -.025em; color: var(--color-text-primary); }
    .ctp .head p { font-size: 13.5px; color: var(--color-text-secondary); margin-top: 5px; max-width: 64ch; }

    .ctp .tools { display: flex; align-items: center; gap: 12px; margin: 18px 0 20px; flex-wrap: wrap; }
    .ctp .fchip { font-size: 12.5px; font-weight: 600; color: var(--color-text-secondary); background: var(--color-surface); border: 1px solid var(--color-border-strong); padding: 6px 12px; border-radius: var(--radius-full); cursor: pointer; transition: .12s; text-decoration: none; }
    .ctp .fchip:hover { border-color: var(--neutral-400); }
    .ctp .fchip.on { background: var(--color-text-primary); color: #fff; border-color: var(--color-text-primary); }
    .ctp .tools__label { font-size: 11.5px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; color: var(--color-text-muted); }
    .ctp .tools__note { font-size: 12.5px; color: var(--color-text-muted); margin-left: auto; white-space: nowrap; }
    .ctp .tools .select { width: auto; max-width: 300px; height: 34px; padding-top: 0; padding-bottom: 0; font-size: 12.5px; }
    .ctp .tools .input { width: auto; min-width: 220px; flex: 1; height: 34px; padding-top: 0; padding-bottom: 0; font-size: 12.5px; }

    .ctp .board { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; align-items: start; }
    .ctp .board--5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }
    @media (max-width: 1199px) { .ctp .board, .ctp .board--5 { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (max-width: 699px) { .ctp .board, .ctp .board--5 { grid-template-columns: 1fr; } }
    /* Columns cap at viewport height and scroll internally (Trello model) -
       a 1000+ card "To create" column must not stretch the page while the
       other columns sit empty at the top. */
    .ctp .col { background: var(--color-surface-sunken); border: 1px solid var(--color-border); border-radius: var(--radius-lg); display: flex; flex-direction: column; min-height: 220px; max-height: calc(100vh - 230px); }
    .ctp .col__body { overflow-y: auto; }
    .ctp .col__head { display: flex; align-items: center; gap: 9px; padding: 14px 16px 10px; flex: none; }
    .ctp .col__dot { width: 8px; height: 8px; border-radius: 50%; flex: none; }
    .ctp .col__title { font-size: 13px; font-weight: 680; color: var(--color-text-primary); }
    .ctp .col__count { font-size: 11px; font-weight: 700; color: var(--color-text-muted); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-full); padding: 1px 8px; }
    .ctp .col__body { padding: 4px 12px 14px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .ctp .col__empty { font-size: 12px; color: var(--color-text-muted); text-align: center; padding: 24px 12px; border: 1px dashed var(--color-border); border-radius: var(--radius-md); line-height: 1.5; }

    .ctp .ccard { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-xs); padding: 13px 14px; transition: box-shadow .12s, border-color .12s; }
    .ctp .ccard:hover { box-shadow: var(--shadow-md); }
    .ctp .ccard__top { display: flex; align-items: center; gap: 6px; margin-bottom: 9px; flex-wrap: wrap; }
    .ctp .typechip { font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: var(--radius-full); border: 1px solid var(--color-border); color: var(--color-text-secondary); background: var(--color-surface-sunken); }
    .ctp .ccard__title { font-size: 13.5px; font-weight: 650; line-height: 1.35; color: var(--color-text-primary); }
    .ctp .ccard__target { font-size: 12px; color: var(--color-text-secondary); margin-top: 6px; display: flex; gap: 6px; align-items: flex-start; line-height: 1.4; }
    .ctp .ccard__target svg { flex: none; margin-top: 2px; color: var(--color-text-muted); }
    .ctp .ccard__foot { margin-top: 11px; padding-top: 10px; border-top: 1px solid var(--color-border); }
    .ctp .lift { font-size: 11px; font-weight: 700; color: var(--color-text-secondary); background: var(--color-surface-muted); padding: 2px 7px; border-radius: var(--radius-full); }
    .ctp .ccard__domain { font-size: 11px; color: var(--color-text-muted); max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .ctp .ccard__media { font-size: 11px; color: var(--coral-700); font-weight: 600; margin: 2px 0 6px; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }

    .ctp .btn-mini { font-size: 11px; font-weight: 600; border-radius: var(--radius-sm); padding: 5px 10px; border: 1px solid transparent; cursor: pointer; transition: .12s; font-family: var(--font-sans); }
    .ctp .btn-mini--primary { background: var(--color-primary); color: #fff; }
    .ctp .btn-mini--primary:hover { background: var(--color-primary-hover); }
    .ctp .btn-mini--outline { background: var(--color-surface); border-color: var(--color-border-strong); color: var(--color-text-secondary); }
    .ctp .btn-mini--outline:hover { background: var(--color-surface-sunken); color: var(--color-text-primary); }
    .ctp .btn-mini--warn { background: var(--status-warning-bg); color: #8a5a00; }
    .ctp .btn-mini--warn:hover { filter: brightness(.97); }
  </style>

  <div class="ctp">
    <!-- Header -->
    <div class="head flex items-center justify-between">
      <div>
        <h1>Content pipeline</h1>
        <p>Content that closes the gaps your scans found - the questions where AI does not yet cite the brand.</p>
      </div>
    </div>

    <!-- Filter bar (Fitts's Law: pills first for 1-click, dropdowns for less common) -->
    <div class="tools">
      <span class="tools__label">Type</span>
      <a href={`?${scanParam ? `scan_id=${scanParam}` : ''}`} class={`fchip ${ctParam === 'all' ? 'on' : ''}`}>All</a>
      <a href={`?content_type=faq${scanParam ? `&scan_id=${scanParam}` : ''}`} class={`fchip ${ctParam === 'faq' ? 'on' : ''}`}>FAQ</a>
      <a href={`?content_type=netlinking_article${scanParam ? `&scan_id=${scanParam}` : ''}`} class={`fchip ${ctParam === 'netlinking_article' ? 'on' : ''}`}>Articles</a>

      {scans.length > 0 && (
        <div class="flex items-center gap-2">
          <span class="tools__label">Scan</span>
          {/* Form-submit pattern: native GET form, hidden inputs preserve sibling
              filters (content_type / show_rejected) so changing scan_id never
              wipes them. onchange="this.form.submit()" is the most reliable
              cross-browser auto-submit — replaces a previous inline
              `window.location=` handler that didn't fire reliably in some
              browser/extension combos and left the page on /app/content?
              with no scan_id in the URL. */}
          <form method="GET" class="flex items-center gap-2">
            {ctParam !== 'all' && <input type="hidden" name="content_type" value={ctParam} />}
            {showRejected && <input type="hidden" name="show_rejected" value="1" />}
            <select name="scan_id" onchange="this.form.submit()" class="select">
              <option value="">All scans</option>
              {(() => {
                // Disambiguate labels when multiple scans share the same name
                // (common with "test 1", "test 2", etc. created during dev).
                const nameCount: any = {};
                for (const s of scans) {
                  const k = ((s.name || s.domain || '') as string).trim();
                  nameCount[k] = (nameCount[k] || 0) + 1;
                }
                return scans.map((s: any) => {
                  const name = (s.name || '').trim();
                  const domain = (s.domain || '').trim();
                  const isAmbiguous = nameCount[name] > 1;
                  let label = name || domain;
                  if (name && isAmbiguous) {
                    label = `${name} · ${domain || s.id.slice(0, 6)}`;
                  }
                  return <option value={s.id} selected={scanParam === s.id}>{label}</option>;
                });
              })()}
            </select>
          </form>
        </div>
      )}

      <div class="flex-1 min-w-[200px]" x-data="{ q: '' }">
        <input type="text" placeholder="Search topic, question, persona..." class="input"
               x-model="q"
               @input.debounce.200ms="document.querySelectorAll('[data-card]').forEach(c => { const haystack = c.getAttribute('data-haystack') || ''; c.style.display = haystack.toLowerCase().includes(q.toLowerCase()) ? '' : 'none'; })" />
      </div>

      {/* Show rejected toggle — Postel's : let users opt into seeing the
           soft-deleted items so they can regenerate or audit. Off by default
           (Hick's : reduce columns shown). */}
      <a href={(() => {
            const u = new URL(Astro.url);
            if (showRejected) u.searchParams.delete('show_rejected');
            else u.searchParams.set('show_rejected', '1');
            return u.pathname + (u.searchParams.toString() ? '?' + u.searchParams.toString() : '');
          })()}
         title={showRejected ? 'Hide rejected items' : 'Show rejected items (regenerable from their detail page)'}
         class={`fchip ${showRejected ? 'on' : ''}`}>
        {showRejected ? '✓ Showing rejected' : 'Show rejected'}
      </a>

      <span class="tools__note"><strong style="color:var(--color-text-primary)">{totalAcrossAll}</strong> total</span>
    </div>

    {totalAcrossAll === 0 && !scanParam && ctParam === 'all' ? (
      <!-- Global empty state -->
      <div class="empty" style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);max-width:none">
        <div class="empty__art"><span>FAQ / ART</span></div>
        <p class="empty__title">No content yet</p>
        <p class="empty__body">Run a scan to discover opportunities, then generate FAQ or articles to fill this pipeline.</p>
        <a href="/app/scans/new" class="btn btn--primary btn--md">Run a scan</a>
      </div>
    ) : (
      <!-- Kanban grid — 4 cols default, 5 when Rejected toggle is on -->
      <div class={`board ${showRejected ? 'board--5' : ''}`}>
        {columns.map(col => {
          const items = (kanban.by_column?.[col.key] || []) as any[];
          const count = items.length;
          return (
            <div class="col">
              <div class="col__head">
                <span class="col__dot" style={`background:${col.dot}`}></span>
                <span class="col__title">{col.label}</span>
                <span class="col__count">{count}</span>
              </div>

              <!-- Cards or empty state -->
              <div class="col__body">
                {count === 0 ? (
                  <div class="col__empty">{col.emptyMsg}</div>
                ) : items.map((item: any) => {
                  const haystack = [item.topic_name, item.persona_name, item.target_question, item.scan_domain].filter(Boolean).join(' ');
                  const isToCreate = col.key === 'to_create';
                  const isPublished = col.key === 'published';
                  return (
                    <div data-card data-haystack={haystack} class="ccard">
                      <!-- Top row: badges -->
                      <div class="ccard__top">
                        {item.content_type && (
                          <span class="typechip">{typeLabel(item.content_type)}</span>
                        )}
                        {item.priority && (
                          <span class={`chip chip--sm ${priorityClass(item.priority)}`}>
                            <span class="chip__dot"></span>{priorityLabel(item.priority)}
                          </span>
                        )}
                        {col.key === 'to_create' && !item.target_url && (
                          <span class="chip chip--sm chip--warning"
                                title={item.content_type === 'netlinking_article'
                                  ? 'Set the media partner URL where this article will be published (e.g. https://www.doctissimo.fr/...), then click Generate.'
                                  : 'Pick a URL on your site where this FAQ should live, then click Generate.'}>
                            {item.content_type === 'netlinking_article' ? 'Needs media URL' : 'Needs URL'}
                          </span>
                        )}
                        {/* Phase B Tier A — intent chip from the Haiku
                            classifier (content_metadata.intent_category).
                            Hidden for promotional_fit and other (no signal
                            value). Safety categories are filtered out
                            upstream so they normally don't appear here at
                            all — defensive render in case a legacy item
                            survives. */}
                        {(() => {
                          const cat = item.content_metadata?.intent_category;
                          if (!cat || cat === 'promotional_fit' || cat === 'other') return null;
                          const map = {
                            informational_neutral: { label: 'Informational', cls: 'chip--info' },
                            safety_warning:        { label: 'Safety',        cls: 'chip--warning' },
                            side_effects:          { label: 'Side effects',  cls: 'chip--warning' },
                            contre_indication:     { label: 'Contre-indication', cls: 'chip--warning' },
                            complaint_sav:         { label: 'SAV',           cls: 'chip--warning' },
                          } as const;
                          const m = (map as any)[cat];
                          if (!m) return null;
                          return (
                            <span class={`chip chip--sm ${m.cls}`}
                                  title={`Question intent: ${m.label}. Classified by the scan pipeline.`}>
                              {m.label}
                            </span>
                          );
                        })()}
                        {/* Scan-domain chip — labelled by intent : on FAQ scans
                            it's the user's own brand site (where the FAQ will
                            live), on netlinking_article it's the competitor's
                            scanned domain (the OPPORTUNITY source — what made
                            us identify this article need). Different mental
                            model, different prefix. */}
                        {item.scan_domain && (
                          <span class="ccard__domain"
                                title={item.content_type === 'netlinking_article'
                                  ? `Scanned (competitor): ${item.scan_domain} — article will publish on a media partner, not here.`
                                  : item.scan_domain}>
                            {item.content_type === 'netlinking_article' ? '🔍 ' : ''}{item.scan_domain}
                          </span>
                        )}
                      </div>

                      {/* Phase C.1.3 — Article media-partner top candidate
                          chip. Show the picked media + LinkFinder price (if
                          enriched) so user sees the "real" target at a glance
                          without opening validation page. FAQ items show
                          target_url in the existing layout below. */}
                      {item.content_type === 'netlinking_article' && item.target_url && (item.target_url_source === 'media_picker' || item.target_url_source === 'media_replacement') && (
                        <div class="ccard__media">
                          <span>&rarr; {(item.target_page_title || item.target_url.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '').slice(0, 30))}</span>
                          {item.target_url_source === 'media_replacement' && (
                            <span class="chip chip--sm chip--positive" title="You replaced the auto-picked media with this one via Find alternative.">Picked</span>
                          )}
                          {Array.isArray(item.target_url_candidates) && item.target_url_candidates?.[0]?.price_eur != null && (
                            <span style="color:var(--status-warning);font-size:10.5px" title="LinkFinder published price (HT) for a sponsored placement">
                              €{Math.round(item.target_url_candidates[0].price_eur).toLocaleString('fr-FR')}
                            </span>
                          )}
                          {Array.isArray(item.target_url_candidates) && item.target_url_candidates?.[0]?.da != null && (
                            <span style="color:var(--color-text-muted);font-size:10.5px" title="Domain Authority">
                              DA {item.target_url_candidates[0].da}
                            </span>
                          )}
                        </div>
                      )}

                      <!-- Topic + question (clickable to detail) -->
                      <a href={`/app/content/${item.id}`} class="block" style="text-decoration:none;color:inherit">
                        {item.topic_name && (
                          <p class="ccard__title" title={item.topic_name}>{item.topic_name}</p>
                        )}
                        {item.target_question && (
                          <p class="ccard__target" title={item.target_question}>
                            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="7" r="5"/><path d="M11 11l3 3"/></svg>
                            <span>{item.target_question}</span>
                          </p>
                        )}
                      </a>

                      <!-- Per-status footer -->
                      {isToCreate && (
                        <div class="ccard__foot"
                             x-data={`{
                               generating: ${item.status === 'generating' ? 'true' : 'false'},
                               error: '',
                               meta: ${JSON.stringify(item.content_metadata || {})},
                               tick: Date.now(),
                               progress() {
                                 const ip = (this.meta && this.meta.in_progress) || {};
                                 const startedAt = ip.started_at ? new Date(ip.started_at).getTime() : null;
                                 const elapsedSec = startedAt ? Math.max(0, Math.floor((this.tick - startedAt) / 1000)) : 0;
                                 const totalSec = ip.estimated_total_seconds || 600;
                                 return {
                                   phase_label: ip.phase_label || 'Generating',
                                   phase_num: ip.phase_num || 1,
                                   phase_total: ip.phase_total || 5,
                                   elapsed: elapsedSec,
                                   total: totalSec,
                                   pct: Math.min(95, Math.floor((elapsedSec / totalSec) * 100))
                                 };
                               },
                               async _poll() {
                                 try {
                                   const pr = await fetch('/api/content-items/${item.id}');
                                   if (pr.ok) {
                                     const d = await pr.json();
                                     this.meta = d.content_metadata || {};
                                     if (d.status !== 'identified' && d.status !== 'generating') {
                                       window.location.reload();
                                       return;
                                     }
                                   }
                                 } catch(e) {}
                                 setTimeout(() => this._poll(), 3000);
                               },
                               async startGen() {
                                 this.generating = true;
                                 this.error = '';
                                 try {
                                   const r = await fetch('/api/content-items/${item.id}/generate', { method: 'POST' });
                                   if (r.ok) {
                                     this._poll();
                                   } else {
                                     const j = await r.json().catch(() => ({}));
                                     this.error = j.detail?.message || j.detail || 'Failed';
                                     this.generating = false;
                                   }
                                 } catch (e) {
                                   this.error = e.message;
                                   this.generating = false;
                                 }
                               }
                             }`}
                             x-init="setInterval(() => tick = Date.now(), 1000); if (generating) _poll();">
                          <!-- Generating : show progress (phase + elapsed + bar) -->
                          <div x-show="generating" class="space-y-1.5">
                            <div class="flex items-center justify-between text-[10px]">
                              <span style="color:var(--coral-700);font-weight:600">
                                <span x-text="progress().phase_num + '/' + progress().phase_total + ' - ' + progress().phase_label"></span>
                              </span>
                              <span style="color:var(--color-text-muted)" x-text="progress().elapsed + 's / ~' + progress().total + 's'"></span>
                            </div>
                            <div style="width:100%;height:4px;background:var(--color-surface-muted);border-radius:var(--radius-full);overflow:hidden">
                              <div style="height:100%;background:var(--coral-400);border-radius:var(--radius-full);transition:width .3s"
                                   :style="'width: ' + progress().pct + '%'"></div>
                            </div>
                            <p class="text-[10px]" style="color:var(--color-text-muted);font-style:italic">
                              {item.content_type === 'netlinking_article'
                                ? 'Article gen takes 5-15 min. You can leave this page.'
                                : 'FAQ gen takes ~60s.'}
                            </p>
                          </div>

                          <!-- Idle : score + Generate button + (article only) Find alternative -->
                          <div x-show="!generating" class="flex items-center justify-between gap-2 flex-wrap">
                            {item.opportunity_score != null && (
                              <span class="lift" title="Opportunity score">{Math.round(item.opportunity_score)}</span>
                            )}
                            <div class="flex items-center gap-1.5 flex-wrap">
                              {item.target_url ? (
                                item.content_type === 'faq' ? (
                                  <button @click="startGen()" type="button" class="btn-mini btn-mini--primary"
                                          title="Generate FAQ content (~60s, 1 content credit)">
                                    Generate FAQ
                                  </button>
                                ) : item.content_type === 'netlinking_article' ? (
                                  <button @click="startGen()" type="button" class="btn-mini btn-mini--primary"
                                          title="Generate netlinking article (~5-15 min, 3 content credits)">
                                    Generate article
                                  </button>
                                ) : (
                                  <span class="text-[10px]" style="color:var(--color-text-muted);font-style:italic">Unsupported content_type</span>
                                )
                              ) : (
                                <a href={`/app/content/${item.id}`} class="btn-mini btn-mini--warn" style="text-decoration:none"
                                   title={item.content_type === 'netlinking_article'
                                     ? 'Open validation page → set the media partner URL where the article will be published, then Generate.'
                                     : 'Open validation page → set a target URL on your site, then Generate.'}>
                                  {item.content_type === 'netlinking_article' ? 'Set media URL →' : 'Set URL →'}
                                </a>
                              )}
                              {/* Phase MR.2 — Find alternative media button.
                                  Shown when : netlinking_article AND user hasn't
                                  already picked an alternative AND (no target_url
                                  OR auto-picked media has no price). Once
                                  target_url_source='media_replacement' the user
                                  has committed — hide the button to reduce
                                  visual clutter (Hick's Law). They can rematch
                                  from the validation page if needed. */}
                              {item.content_type === 'netlinking_article'
                                && item.target_url_source !== 'media_replacement'
                                && (
                                  !item.target_url
                                  || (Array.isArray(item.target_url_candidates)
                                      && item.target_url_candidates?.[0]?.price_eur == null)
                                ) && (
                                <button type="button" @click.stop={`$dispatch('open-suggest-media', { id: '${item.id}', target_question: ${JSON.stringify(item.target_question || '')}, topic: ${JSON.stringify(item.topic_name || '')} })`}
                                        class="btn-mini btn-mini--outline"
                                        title="Get up to 5 ranked alternative media partners based on LLM citations + Babbar + LinkFinder data.">
                                  Find alternative
                                </button>
                              )}
                            </div>
                            <p x-show="error" x-text="error" class="text-[10px]" style="color:var(--status-critical)"></p>
                          </div>
                        </div>
                      )}

                      {!isToCreate && !isPublished && (
                        <div class="ccard__foot flex items-center justify-between text-[11px]" style="color:var(--color-text-muted)">
                          <span>{ageLabel(item.identified_at)}</span>
                          {item.promoted_brand_names?.length > 0 && (
                            <span class="truncate max-w-[120px]" title={item.promoted_brand_names.join(', ')}>
                              ✓ {item.promoted_brand_names[0]}{item.promoted_brand_names.length > 1 ? ` +${item.promoted_brand_names.length - 1}` : ''}
                            </span>
                          )}
                        </div>
                      )}

                      {isPublished && (
                        <div class="ccard__foot flex items-center justify-between text-[11px]">
                          {item.published_url ? (
                            <a href={item.published_url} target="_blank" rel="noopener" @click.stop
                               class="truncate max-w-[150px]" style="color:var(--coral-700);font-weight:600;text-decoration:none" title={item.published_url}>
                              {item.published_url.replace(/^https?:\/\//, '').slice(0, 25)}…
                            </a>
                          ) : <span style="color:var(--color-text-muted)">No URL set</span>}
                          {item.position_delta != null && (
                            <span style={`font-weight:650;color:${item.position_delta > 0 ? 'var(--status-positive)' : item.position_delta < 0 ? 'var(--status-critical)' : 'var(--color-text-muted)'}`}>
                              {item.position_delta > 0 ? '+' : ''}{item.position_delta.toFixed(1)} pos
                            </span>
                          )}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>

  {/* ── Phase MR.2 — Suggest alternative media modal ──────────────────────────
      Single global Alpine component. Opens via custom event :
        $dispatch('open-suggest-media', { id, target_question, topic })
      Calls POST /suggest-media → polls /suggest-media-result every 600ms →
      shows top-5 with breakdown → Accept (POST /accept-suggestion) or Reject
      (local exclude → re-fetch). Closes on Escape, backdrop click, or × button. */}
  <div x-data={`{
         open: false,
         loading: false,
         item: null,
         strategy: 'match_competitor',
         requirePrice: true,
         suggestions: [],
         rejected: [],
         attemptsUsed: 0,
         attemptsCap: 5,
         intentBlocked: false,
         intentMessage: '',
         diagnostics: null,
         strategyFallback: false,
         error: '',
         lastWasWebSearch: false,
         webSearchDone: false,
         webSearchNewCount: 0,
         webSearchRefunded: false,
         async open_(detail) {
           this.open = true;
           this.item = detail;
           this.rejected = [];
           await this._fetch();
         },
         async _fetch(useLlm = false) {
           this.loading = true;
           this.error = '';
           this.intentBlocked = false;
           this.suggestions = [];
           this.lastWasWebSearch = useLlm;
           try {
             const r = await fetch('/api/content-items/' + this.item.id + '/suggest-media', {
               method: 'POST',
               headers: { 'Content-Type': 'application/json' },
               credentials: 'same-origin',
               body: JSON.stringify({
                 strategy: this.strategy,
                 require_price: this.requirePrice,
                 exclude_domains: this.rejected,
                 top_k: 5,
                 use_llm_fallback: useLlm,
               }),
             });
             if (!r.ok) {
               const j = await r.json().catch(() => ({}));
               this.error = (j.detail && (j.detail.message || j.detail)) || ('HTTP ' + r.status);
               this.loading = false;
               return;
             }
             const body = await r.json();
             this.attemptsUsed = body.attempts_used || 0;
             this.attemptsCap = body.attempts_cap || 5;
             await this._poll(body.job_id);
           } catch (e) {
             this.error = e.message || 'Network error';
             this.loading = false;
           }
         },
         async _poll(jobId) {
           const start = Date.now();
           // Web search (source 5) does an LLM call + LinkFinder + scoring —
           // can run several minutes. DB-only path is seconds. Size the
           // timeout accordingly so we don't false-timeout a paid run.
           const timeoutMs = this.lastWasWebSearch ? 360000 : 90000;
           while (this.open && Date.now() - start < timeoutMs) {
             try {
               const r = await fetch('/api/content-items/' + this.item.id + '/suggest-media-result?job_id=' + jobId, {
                 credentials: 'same-origin',
               });
               if (r.ok) {
                 const j = await r.json();
                 if (j.status === 'completed') {
                   const res = j.result || {};
                   if (res.status === 'intent_not_eligible') {
                     this.intentBlocked = true;
                     this.intentMessage = res.message || 'This question is not eligible for netlinking placement.';
                   } else if (res.status === 'error') {
                     this.error = res.error || 'Suggestion failed';
                   } else {
                     this.suggestions = res.suggestions || [];
                     this.diagnostics = res.diagnostics || null;
                     this.strategyFallback = !!(res.diagnostics && res.diagnostics.strategy_fallback);
                     // Web-search outcome notice (refund if it found nothing new)
                     if (this.lastWasWebSearch) {
                       this.webSearchDone = true;
                       this.webSearchNewCount = res.llm_new_count || 0;
                       this.webSearchRefunded = !!res.credit_refunded;
                     }
                   }
                   this.loading = false;
                   return;
                 } else if (j.status === 'failed') {
                   this.error = j.error || 'Job failed';
                   this.loading = false;
                   return;
                 }
               }
             } catch (e) { /* network blip — keep polling */ }
             await new Promise(r => setTimeout(r, 600));
           }
           if (this.open) {
             this.error = 'Timeout (>90s) — the worker may be busy generating an article. Wait a moment then click Refresh.';
             this.loading = false;
           }
         },
         reject(domain) {
           if (!this.rejected.includes(domain)) this.rejected.push(domain);
           this.suggestions = this.suggestions.filter(s => s.domain !== domain);
         },
         async accept(s) {
           try {
             const r = await fetch('/api/content-items/' + this.item.id + '/accept-suggestion', {
               method: 'POST',
               headers: { 'Content-Type': 'application/json' },
               credentials: 'same-origin',
               body: JSON.stringify({
                 domain: s.domain,
                 url: s.url,
                 rejected_domains: this.rejected,
                 price_eur: s.price_eur,
                 da: s.da, tf: s.tf, cf: s.cf, rd: s.rd,
                 media_group: s.media_group,
               }),
             });
             if (r.ok) {
               this.close();
               window.location.reload();
             } else {
               const j = await r.json().catch(() => ({}));
               this.error = (j.detail && (j.detail.message || j.detail)) || ('HTTP ' + r.status);
             }
           } catch (e) {
             this.error = e.message || 'Network error';
           }
         },
         async refresh() {
           await this._fetch(false);
         },
         async searchWeb() {
           // Opt-in paid source 5. Confirm the credit cost first.
           if (!confirm('Search the web for more media? This uses 1 content credit (refunded if it finds nothing new).')) return;
           this.webSearchDone = false;
           await this._fetch(true);
         },
         close() {
           this.open = false;
           this.item = null;
           this.suggestions = [];
           this.rejected = [];
           this.error = '';
           this.intentBlocked = false;
           this.lastWasWebSearch = false;
           this.webSearchDone = false;
         },
         fmtPrice(p) {
           if (p == null) return '—';
           return '€' + Math.round(p).toLocaleString('fr-FR');
         },
         badgeClass(b) {
           if (b === 'tier-1') return 'bg-emerald-100 text-emerald-800';
           if (b === 'mid') return 'bg-blue-100 text-blue-800';
           if (b === 'niche') return 'bg-gray-100 text-gray-700';
           return 'bg-amber-50 text-amber-700';
         },
         badgeLabel(b) {
           const map = { 'tier-1': 'Major media', 'mid': 'Mid-size', 'niche': 'Small / niche', 'unknown': 'Not rated' };
           return map[b] || 'Not rated';
         },
         sourceLabel(s) {
           const map = { scan_citation: 'Cited in your scan', cross_scan: 'Cited elsewhere', trust_sources: 'Trusted source', media_catalog: 'Our database', llm_web_search: 'AI search' };
           return map[s] || s;
         }
       }`}
       @open-suggest-media.window="open_($event.detail)"
       @keydown.escape.window="if (open) close()"
       x-show="open" x-cloak
       class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
       @click.self="close()">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-3xl max-h-[90vh] flex flex-col"
         @click.stop>
      <!-- Header -->
      <div class="px-5 py-4 border-b border-gray-100 flex items-start justify-between gap-4">
        <div class="flex-1 min-w-0">
          <h2 class="text-base font-semibold text-charcoal-dark">Find alternative media</h2>
          <p class="text-[11px] text-charcoal-light mt-0.5" x-show="item">
            <span x-text="item?.topic" class="font-medium"></span><span x-show="item?.topic"> · </span>
            <span class="italic" x-text="item?.target_question?.slice(0, 110) + (item?.target_question?.length > 110 ? '…' : '')"></span>
          </p>
        </div>
        <button @click="close()" type="button" class="text-charcoal-light hover:text-charcoal-dark text-xl leading-none">×</button>
      </div>

      <!-- Controls -->
      <div class="px-5 py-3 border-b border-gray-100 bg-gray-50/60">
        <div class="flex items-center gap-4 flex-wrap text-[12px]">
          <div class="flex items-center gap-2">
            <span class="text-charcoal-light underline decoration-dotted decoration-charcoal-light/50 cursor-help">
              <Tip text={mediaTips.strategy} position="bottom">Strategy:</Tip>
            </span>
            <label class="flex items-center gap-1 cursor-pointer">
              <input type="radio" x-model="strategy" value="match_competitor" @change="refresh()" class="accent-purple-600" />
              <span title="Media where a competitor already appears">Follow competitors</span>
            </label>
            <label class="flex items-center gap-1 cursor-pointer">
              <input type="radio" x-model="strategy" value="avoid_competitor" @change="refresh()" class="accent-purple-600" />
              <span title="Media with no competitor — stand out">Avoid competitors</span>
            </label>
          </div>
          <label class="flex items-center gap-1 cursor-pointer">
            <input type="checkbox" x-model="requirePrice" @change="refresh()" class="accent-purple-600" />
            <span class="underline decoration-dotted decoration-charcoal-light/50 cursor-help">
              <Tip text={mediaTips.require_price} position="bottom">Only media with a known price</Tip>
            </span>
          </label>
        </div>
        <!-- Plain-language legend (always visible, never clipped by modal scroll).
             One definition per line for scannability — Law of Proximity +
             Aesthetic-Usability (lawsofux). -->
        <dl class="mt-2 grid grid-cols-[auto_1fr] gap-x-2 gap-y-1 text-[10px] text-charcoal-light leading-snug">
          <dt class="font-semibold text-charcoal-dark whitespace-nowrap">Authority</dt>
          <dd>how trusted a site is across the web — 0-100, based on its backlinks</dd>
          <dt class="font-semibold text-charcoal-dark whitespace-nowrap">Major / Mid-size / Niche</dt>
          <dd>media ranked by that authority score</dd>
          <dt class="font-semibold text-charcoal-dark whitespace-nowrap">€ price</dt>
          <dd>what the media charges to publish your article</dd>
        </dl>
      </div>

      <!-- Body -->
      <div class="flex-1 overflow-y-auto px-5 py-4 space-y-3">
        <!-- Loading -->
        <div x-show="loading" class="text-center py-12 text-charcoal-light text-sm">
          <div class="inline-block w-6 h-6 border-2 border-purple-300 border-t-purple-600 rounded-full animate-spin mb-2"></div>
          <p x-show="!lastWasWebSearch">Searching alternative media…</p>
          <p x-show="lastWasWebSearch">Searching the web for media… this can take 1-3 minutes.</p>
        </div>

        <!-- Error -->
        <div x-show="!loading && error" class="bg-red-50 border border-red-200 text-red-800 text-[12px] rounded p-3" x-text="error"></div>

        <!-- Intent blocked -->
        <div x-show="!loading && intentBlocked" class="bg-amber-50 border border-amber-200 text-amber-900 text-[12px] rounded p-3">
          <strong>This question can't get netlinking suggestions.</strong>
          <p class="mt-1" x-text="intentMessage"></p>
        </div>

        <!-- Web-search outcome notice -->
        <div x-show="!loading && webSearchDone" class="text-[11px] rounded p-2.5"
             :class="webSearchNewCount > 0 ? 'bg-purple-50 border border-purple-200 text-purple-900' : 'bg-gray-50 border border-gray-200 text-charcoal-light'">
          <template x-if="webSearchNewCount > 0">
            <span>🔍 AI web search added <strong x-text="webSearchNewCount"></strong> new media (tagged <em>AI search</em> below).</span>
          </template>
          <template x-if="webSearchNewCount === 0">
            <span>🔍 AI web search found no new buyable media for this topic. <strong x-show="webSearchRefunded">Your credit was refunded.</strong></span>
          </template>
        </div>

        <!-- Empty -->
        <div x-show="!loading && !error && !intentBlocked && suggestions.length === 0" class="text-center py-10 text-charcoal-light text-sm">
          <p>No matching media found with the current filters.</p>
          <p class="text-[11px] mt-1">Try unchecking "Require LinkFinder price" or switching strategy.</p>
        </div>

        <!-- Strategy fallback notice (when avoid/match strict filter emptied the list) -->
        <div x-show="!loading && !error && !intentBlocked && strategyFallback && suggestions.length > 0"
             class="bg-amber-50 border border-amber-200 text-amber-900 text-[11px] rounded p-2.5">
          <strong>No media matched your strategy strictly.</strong>
          <span x-show="strategy === 'avoid_competitor'">All candidates have at least one competitor co-cited. Showing best ranked anyway — consider Match strategy or relax filters.</span>
          <span x-show="strategy === 'match_competitor'">No candidate has a competitor co-cited. Showing best ranked anyway — try Avoid strategy.</span>
        </div>

        <!-- Suggestions list -->
        <template x-for="s in suggestions" :key="s.domain">
          <div class="border border-gray-200 rounded-lg p-3 hover:border-purple-200 transition-all">
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-medium text-charcoal-dark" x-text="s.domain"></span>
                  <span class="text-[9px] font-bold rounded px-1.5 py-0.5"
                        :class="badgeClass(s.authority_badge)"
                        x-text="badgeLabel(s.authority_badge)"></span>
                  <span class="text-[10px] text-charcoal-light" x-show="s.da != null">Authority <span x-text="s.da"></span>/100</span>
                  <span class="text-[10px] text-amber-700 font-medium" x-text="fmtPrice(s.price_eur)" x-show="s.price_eur != null"></span>
                  <span class="text-[9px] text-gray-500 italic" x-text="sourceLabel(s.source)"></span>
                </div>
                <ul class="mt-1.5 space-y-0.5">
                  <template x-for="r in s.breakdown?.reasons || []" :key="r">
                    <li class="text-[11px] text-emerald-700">✓ <span x-text="r"></span></li>
                  </template>
                  <template x-for="r in s.breakdown?.risks || []" :key="r">
                    <li class="text-[11px] text-amber-700">⚠ <span x-text="r"></span></li>
                  </template>
                </ul>
                <a x-show="s.sample_recent_article_url" :href="s.sample_recent_article_url" target="_blank" rel="noopener"
                   class="text-[10px] text-purple-600 hover:underline mt-1 inline-block">
                  Sample article ↗
                </a>
              </div>
              <div class="flex flex-col gap-1.5">
                <button @click="accept(s)" type="button"
                        class="text-[10px] rounded px-2.5 py-1 font-medium bg-purple-600 text-white hover:bg-purple-700 transition-all whitespace-nowrap">
                  Accept →
                </button>
                <button @click="reject(s.domain)" type="button"
                        class="text-[10px] rounded px-2 py-1 font-medium text-charcoal-light hover:text-red-600 transition-all">
                  Reject
                </button>
              </div>
            </div>
          </div>
        </template>
      </div>

      <!-- Footer -->
      <div class="px-5 py-3 border-t border-gray-100 bg-gray-50/60 flex items-center justify-between text-[11px]">
        <span class="text-charcoal-light">
          <span x-text="attemptsUsed"></span>/<span x-text="attemptsCap"></span> attempts used
          <span x-show="rejected.length > 0" class="ml-2">· <span x-text="rejected.length"></span> rejected in this session</span>
        </span>
        <div class="flex items-center gap-2">
          <button @click="searchWeb()" type="button"
                  :disabled="loading || attemptsUsed >= attemptsCap"
                  class="text-[11px] rounded px-2.5 py-1 font-medium bg-white border border-purple-300 text-purple-700 hover:bg-purple-50 disabled:opacity-40 disabled:cursor-not-allowed transition-all"
                  title="Use AI to search the web for more buyable media. Costs 1 content credit — refunded if it finds nothing new.">
            🔍 Search the web (1 credit)
          </button>
          <button @click="refresh()" type="button"
                  :disabled="loading || attemptsUsed >= attemptsCap"
                  class="text-[11px] rounded px-2.5 py-1 font-medium bg-white border border-gray-200 text-charcoal-dark hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-all"
                  title="Re-run the free DB search with current filters, excluding rejected domains.">
            ↻ Refresh (5 more)
          </button>
          <button @click="close()" type="button"
                  class="text-[11px] rounded px-2.5 py-1 font-medium text-charcoal-light hover:text-charcoal-dark">
            Cancel
          </button>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
