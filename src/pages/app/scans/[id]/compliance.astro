---
/**
 * Sprint 14 - Per-scan AI Act compliance report.
 *
 * Renders the transparency + audit + methodology block that EU enterprise
 * procurement teams ask for under the EU AI Act (applicable 2 Aug 2026).
 * Print-optimized so the user can Ctrl+P to save as PDF.
 *
 * Data source : GET /api/scans/{id}/compliance-data
 */
export const prerender = false;
import ScanResultsLayout from '../../../../layouts/ScanResultsLayout.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');
const scanId = Astro.params.id as string;

const headers = { Cookie: `token=${token}` };
let data: any = null;
try {
  const res = await fetch(`http://api:8000/api/scans/${scanId}/compliance-data`, { headers });
  if (res.ok) data = await res.json();
} catch (_) {}

const scan = data?.scan || {};
const client = data?.client || {};
const triggeredBy = data?.triggered_by || {};
const providers: any[] = data?.providers || [];
// BYOK - providers that ran on the CUSTOMER's own API keys for this scan
// (recorded at launch). Empty for old scans and platform-keyed scans - the
// report keeps the platform wording in that case.
const byokProviders: string[] = data?.byok_providers || [];
const byokNames: Record<string, string> = { openai: 'OpenAI', anthropic: 'Anthropic', gemini: 'Google Gemini', mistral: 'Mistral' };
// P3 model eras + BYOK selector : exact model versions observed on this
// scan's rows (providers[].models) + customer-selected versions (config).
const modelOverrides: Record<string, string> = data?.model_overrides || {};
const runsDepth = data?.runs_depth || {};
const counts = data?.counts || {};
const dataSources = data?.data_sources || {};
const brandClass = data?.brand_classifications || {};

function fmtDate(iso?: string): string {
  if (!iso) return '-';
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '-';
  return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' })
    + ' ' + d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) + ' UTC';
}

function fmtDuration(s?: number): string {
  if (s == null) return '-';
  if (s < 60) return `${s}s`;
  if (s < 3600) return `${Math.round(s / 60)} min`;
  const h = Math.floor(s / 3600);
  const m = Math.round((s % 3600) / 60);
  return `${h}h ${m}min`;
}

import { SUBPROCESSORS, CHANGELOG, getSubprocessor, changelogKindLabel, changelogKindClass } from '../../../../data/subprocessors';

// Provider-key (as emitted by the LLM runner) -> sub-processor id. Lets
// the per-scan compliance table look up the centralised registry rather
// than maintaining its own copy. Add an entry here when a new provider
// goes live AND a matching SUBPROCESSORS row in src/data/subprocessors.ts.
const PROVIDER_TO_SUBPROCESSOR: Record<string, string> = {
  openai: 'openai',
  gemini: 'gemini',
  claude: 'anthropic',
  mistral: 'mistral',
};
function providerInfo(providerKey: string): { name: string; sub_processor: string; model_family: string; region: string } {
  const subId = PROVIDER_TO_SUBPROCESSOR[String(providerKey).toLowerCase()];
  const sp = subId ? getSubprocessor(subId) : undefined;
  if (!sp) return { name: providerKey, sub_processor: '-', model_family: '-', region: '-' };
  return { name: sp.name, sub_processor: sp.legal_entity, model_family: sp.model_family || '-', region: sp.hosting_region };
}

const reportDate = new Date().toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: '2-digit' });
const runsDisplay = runsDepth.configured || runsDepth.observed_max || 1;
---

<ScanResultsLayout scanId={scanId} activeTab="compliance">
  <div class="compliance-doc">

    {/* Header bar (in-app only, hidden on print) */}
    <div class="screen-only mb-6 flex items-center justify-between bg-white rounded-xl shadow-sm p-4">
      <div>
        <p class="text-[11px] text-charcoal-light uppercase tracking-wide mb-1">EU AI Act compliance report</p>
        <p class="text-sm text-charcoal-dark">
          Single-scan transparency + audit trail. Designed to satisfy EU procurement
          requirements under the EU AI Act (applicable 2 August 2026).
        </p>
      </div>
      <div class="ml-4 flex items-center gap-2 shrink-0">
        <a
          href={`/api/scans/${scanId}/compliance/pdf`}
          download
          class="px-4 py-2 rounded-lg bg-coral hover:bg-coral-dark text-white text-sm font-medium"
        >&#8595;  Download PDF</a>
        <button onclick="window.print()" class="px-3 py-2 rounded-lg border border-gray-200 text-charcoal-dark text-sm hover:bg-gray-50">
          Browser print
        </button>
      </div>
    </div>

    {!data && (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-800">
        Compliance data not available yet. Make sure the scan has run to completion.
      </div>
    )}

    {data && (
      <article class="report bg-white rounded-xl shadow-sm p-10 print:p-0 print:shadow-none print:rounded-none">

        {/* Document header */}
        <header class="border-b border-gray-200 pb-6 mb-8">
          <p class="text-[10px] uppercase tracking-widest text-charcoal-light mb-1">EU AI Act &mdash; Transparency &amp; audit report</p>
          <h1 class="text-2xl font-bold text-charcoal-dark mb-1">{scan.name || scan.domain || 'Scan compliance report'}</h1>
          <p class="text-[12px] text-charcoal-light">
            Workspace : <strong>{client.name || '-'}</strong> &middot;
            Scan ID : <code class="text-[10px] bg-gray-100 px-1 rounded">{scan.id}</code> &middot;
            Generated : {reportDate}
          </p>
        </header>

        {/* §1 Scan identification */}
        <section class="report-section">
          <h2 class="section-title">1. Scan identification</h2>
          <table class="kv-table">
            <tbody>
              <tr><th>Tracker name</th><td>{scan.name || '-'}</td></tr>
              <tr><th>Domain in scope</th><td>{scan.domain || '-'}</td></tr>
              <tr><th>Focus brand</th><td>{scan.focus_brand_name || '-'}</td></tr>
              <tr><th>Scan type</th><td>{scan.scan_type || 'unspecified'}</td></tr>
              <tr><th>Run index</th><td>{scan.run_index || 1} (1 = initial, 2+ = rescan)</td></tr>
              <tr><th>Schedule</th><td>{scan.schedule || 'manual'}</td></tr>
              <tr><th>Status</th><td>{scan.status}</td></tr>
            </tbody>
          </table>
        </section>

        {/* §2 Audit trail */}
        <section class="report-section">
          <h2 class="section-title">2. Audit trail</h2>
          <table class="kv-table">
            <tbody>
              <tr><th>Triggered by</th><td>{triggeredBy.name || triggeredBy.email || 'system'} {triggeredBy.email && triggeredBy.name && (<span class="text-[10px] text-charcoal-light">({triggeredBy.email})</span>)}</td></tr>
              <tr><th>Created at</th><td>{fmtDate(scan.created_at)}</td></tr>
              <tr><th>Started at</th><td>{fmtDate(scan.started_at)}</td></tr>
              <tr><th>Completed at</th><td>{fmtDate(scan.completed_at)}</td></tr>
              <tr><th>Total processing time</th><td>{fmtDuration(scan.duration_seconds)}</td></tr>
            </tbody>
          </table>
        </section>

        {/* §3 AI systems used */}
        <section class="report-section">
          <h2 class="section-title">3. AI systems used (general-purpose AI providers)</h2>
          <p class="section-prose">
            The following third-party general-purpose AI models were queried during this scan.
            sen-ai.fr does not train any of these models &mdash; we send prompts and receive responses,
            then process the responses to extract brand mentions and citation URLs.
          </p>
          <table class="data-table">
            <thead>
              <tr>
                <th>Provider</th>
                <th>Sub-processor</th>
                <th>Model family</th>
                <th>Model version</th>
                <th>Hosting region</th>
                <th>API key</th>
                <th class="text-right">LLM calls</th>
                <th class="text-right">Distinct runs</th>
              </tr>
            </thead>
            <tbody>
              {providers.length === 0 && (
                <tr><td colspan="8" class="text-charcoal-light italic">No provider responses recorded.</td></tr>
              )}
              {providers.map((p: any) => {
                const info = providerInfo(String(p.provider));
                const key = String(p.provider).toLowerCase();
                const observed: string[] = p.models || [];
                const isCustomerSelected = !!modelOverrides[key];
                return (
                  <tr>
                    <td>{info.name}</td>
                    <td>{info.sub_processor}</td>
                    <td>{info.model_family}</td>
                    <td>
                      {observed.length ? observed.join(', ') : '-'}
                      {isCustomerSelected && <span class="text-charcoal-light"> (customer-selected)</span>}
                    </td>
                    <td>{info.region}</td>
                    <td>{byokProviders.includes(key) ? 'Customer (BYOK)' : 'sen-ai platform'}</td>
                    <td class="text-right">{p.responses}</td>
                    <td class="text-right">{p.distinct_runs}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
          {byokProviders.length > 0 && (
            <p class="section-prose">
              This scan used customer-supplied API keys (BYOK) for : {byokProviders.map(p => byokNames[p] || p).join(', ')}.
              For those providers, prompt data flowed through the customer&apos;s own provider account
              and is governed by the customer&apos;s agreement with that provider. Providers marked
              &quot;sen-ai platform&quot; ran on sen-ai.fr keys under the sub-processor terms below.
            </p>
          )}
          <p class="section-note">
            Sub-processor data-protection certifications : OpenAI &amp; Anthropic operate under the
            EU-US Data Privacy Framework. Google Gemini is contracted through Google Ireland Ltd
            (EU controller). Mistral is EU-based (France). When an organization supplies its own
            provider API keys (BYOK), the calls to that provider are made through the customer&apos;s
            own provider account, under the customer&apos;s direct agreement with that provider - the
            API key column above records which keys carried this scan. Full sub-processor list +
            changelog at <a href="/app/compliance" target="_blank">organisation compliance hub</a>.
          </p>

          <h3 class="text-[13px] font-semibold text-charcoal-dark mt-6 mb-2">3.1 Sub-processors changelog (audit trail)</h3>
          <p class="section-prose">
            History of sub-processor additions, sunsets, and scope changes since
            sen-ai.fr&apos;s initial AI Act disclosure. Newest first.
          </p>
          <table class="data-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Change</th>
                <th>Sub-processor</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              {CHANGELOG.length === 0 && (
                <tr><td colspan="4" class="text-charcoal-light italic">No changes recorded yet.</td></tr>
              )}
              {CHANGELOG.map((c) => (
                <tr>
                  <td class="whitespace-nowrap tabular-nums">{c.date}</td>
                  <td><span class={`inline-block text-[10px] px-2 py-0.5 rounded uppercase ${changelogKindClass(c.kind)}`}>{changelogKindLabel(c.kind)}</span></td>
                  <td><strong>{c.subprocessor_id === 'all' ? '(all)' : (SUBPROCESSORS.find(s => s.id === c.subprocessor_id)?.legal_entity || c.subprocessor_id)}</strong></td>
                  <td>{c.summary}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>

        {/* §4 Methodology */}
        <section class="report-section">
          <h2 class="section-title">4. Methodology disclosure</h2>
          <table class="kv-table">
            <tbody>
              <tr><th>N-runs paradigm</th><td>{runsDisplay} run(s) per question per provider</td></tr>
              <tr><th>Topics analysed</th><td>{counts.topics || 0}</td></tr>
              <tr><th>Personas modelled</th><td>{counts.personas || 0}</td></tr>
              <tr><th>Questions evaluated</th><td>{counts.questions || 0}</td></tr>
              <tr><th>LLM responses captured</th><td>{counts.llm_responses || 0}</td></tr>
            </tbody>
          </table>
          <p class="section-prose mt-3">
            Each question is sent to each enabled provider <strong>{runsDisplay} times</strong> to
            account for the inherent variance in LLM outputs. The brand-mention extractor
            (an LLM-as-extractor pass) parses each response and writes the result in JSONB,
            classifying each mention&apos;s sentiment as positive / negative / neutral and tagging
            citation URLs.
          </p>
          <p class="section-prose">
            sen-ai.fr <strong>does not influence model training</strong>. Provider APIs are
            queried in read-only mode ; responses are not fed back into any model. The system
            is therefore a <em>limited-risk</em> AI application under Article 50 of the EU AI Act
            (transparency obligation only, no high-risk classification).
          </p>
          <p class="section-prose">
            Full methodology whitepaper :&nbsp;
            <a href="/methodology" target="_blank" class="text-coral hover:text-coral-dark">sen-ai.fr/methodology</a>.
          </p>
        </section>

        {/* §5 Data sources */}
        <section class="report-section">
          <h2 class="section-title">5. Data sources cited by AI providers</h2>
          <p class="section-prose">
            During this scan, the AI providers cited <strong>{dataSources.distinct_domains_total || 0}</strong> distinct
            web domains as sources for their responses. Top 50 by citation count :
          </p>
          {(dataSources.top_50 || []).length === 0 && (
            <p class="text-[12px] text-charcoal-light italic">No citations captured.</p>
          )}
          {(dataSources.top_50 || []).length > 0 && (
            <table class="data-table dense">
              <thead><tr><th>Domain</th><th class="text-right">Citations</th></tr></thead>
              <tbody>
                {(dataSources.top_50 as any[]).map(d => (
                  <tr><td>{d.domain || '-'}</td><td class="text-right">{d.citations}</td></tr>
                ))}
              </tbody>
            </table>
          )}
          <p class="section-note">
            Citation URLs are extracted from each AI provider&apos;s grounding metadata
            (where exposed by the API) or parsed from response text. They reflect the
            sources <strong>the AI cited</strong>, not data sen-ai.fr accessed independently.
          </p>
        </section>

        {/* §6 Brand classification snapshot */}
        <section class="report-section">
          <h2 class="section-title">6. Brand classification snapshot</h2>
          <p class="section-prose">
            Brands recognised by the analyser and their classification at scan time.
            Classification is user-controlled (Brands tab) ; this snapshot reflects the
            state when the report was generated.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 print:gap-2">
            <div>
              <p class="kv-label">Focus brand &amp; product lines</p>
              <ul class="brand-list">
                {(brandClass.my_brand || []).map((b: any) => <li>{b.name}</li>)}
                {(brandClass.my_brand || []).length === 0 && <li class="italic text-charcoal-light">none</li>}
              </ul>
            </div>
            <div>
              <p class="kv-label">Competitors tracked</p>
              <ul class="brand-list">
                {(brandClass.competitor || []).map((b: any) => <li>{b.name}</li>)}
                {(brandClass.competitor || []).length === 0 && <li class="italic text-charcoal-light">none</li>}
              </ul>
            </div>
            <div>
              <p class="kv-label">Ignored / out of scope</p>
              <ul class="brand-list">
                {(brandClass.ignored || []).slice(0, 30).map((b: any) => <li>{b.name}</li>)}
                {(brandClass.ignored || []).length > 30 && <li class="italic text-charcoal-light">+{(brandClass.ignored || []).length - 30} more</li>}
                {(brandClass.ignored || []).length === 0 && <li class="italic text-charcoal-light">none</li>}
              </ul>
            </div>
          </div>
        </section>

        {/* §7 Data subject rights */}
        <section class="report-section">
          <h2 class="section-title">7. Data subject rights &amp; data governance</h2>
          <p class="section-prose">
            This scan&apos;s personal data exposure is minimal :
          </p>
          <ul class="bullets">
            <li>The only identified individual associated with the scan is the user who triggered it (see §2). Their identity is not transmitted to AI providers.</li>
            <li>AI-provider prompts contain brand / domain / topic data only &mdash; no personal data of end users.</li>
            <li>Responses are stored at rest in sen-ai.fr&apos;s database (Hetzner cloud, Helsinki, Finland / EU) for the duration of the workspace subscription.</li>
            <li>Data subjects may exercise GDPR rights (access, rectification, erasure, portability) by emailing <a href="mailto:contact@sen-ai.fr">contact@sen-ai.fr</a>. See <a href="/privacy" target="_blank">Privacy Policy</a>.</li>
          </ul>
        </section>

        {/* §8 Transparency statement */}
        <section class="report-section">
          <h2 class="section-title">8. AI Act applicability &amp; transparency statement</h2>
          <p class="section-prose">
            sen-ai.fr is a <strong>monitoring tool</strong> that observes the outputs of third-party
            general-purpose AI systems. It does not autonomously make decisions producing legal
            or similarly significant effects on natural persons. Under the EU AI Act
            (Regulation (EU) 2024/1689) :
          </p>
          <ul class="bullets">
            <li>sen-ai.fr is not a <em>provider</em> of a general-purpose AI model. It is a downstream <em>deployer</em> of third-party AI systems for the purpose of brand visibility analytics.</li>
            <li>The risk classification is <strong>limited risk</strong> (Title IV) &mdash; transparency obligations apply ; no conformity assessment or CE marking is required.</li>
            <li>This report satisfies the transparency disclosure obligation by documenting the AI systems used, the data sources cited, and the methodology behind the metrics surfaced in the platform.</li>
            <li>sen-ai.fr does not engage in <em>prohibited practices</em> under Article 5 (social scoring, real-time biometric ID, exploitative manipulation, etc.).</li>
          </ul>
          <p class="section-note">
            This statement is informational and not legal advice. Customers should consult
            their own legal counsel for EU AI Act applicability to their specific use case.
          </p>
        </section>

        {/* Footer */}
        <footer class="border-t border-gray-200 pt-4 mt-8 text-[10px] text-charcoal-light leading-relaxed">
          <p>
            Generated by <strong>sen-ai.fr</strong> on {reportDate} for workspace
            <strong> {client.name || '-'}</strong>. This document is automatically generated from
            the scan&apos;s raw data and reflects the state of the scan at generation time.
            Subsequent rescans will produce a new report.
          </p>
          <p class="mt-2">
            Contact : <a href="mailto:contact@sen-ai.fr">contact@sen-ai.fr</a> &middot;
            Privacy Policy : <a href="/privacy" target="_blank">sen-ai.fr/privacy</a> &middot;
            Public methodology : <a href="/methodology" target="_blank">sen-ai.fr/methodology</a>
          </p>
        </footer>
      </article>
    )}

  </div>

  <style>
    .compliance-doc .section-title {
      font-size: 1.15rem;
      font-weight: 700;
      color: #1f2937;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      border-bottom: 1px solid #e5e7eb;
      padding-bottom: 0.4rem;
    }
    .compliance-doc .report-section { margin-bottom: 1.5rem; page-break-inside: avoid; }
    .compliance-doc .section-prose { font-size: 12.5px; line-height: 1.6; color: #374151; margin: 0.5rem 0; }
    .compliance-doc .section-note { font-size: 11px; line-height: 1.6; color: #6b7280; font-style: italic; margin-top: 0.6rem; }
    .compliance-doc .bullets { list-style: disc; padding-left: 1.25rem; font-size: 12.5px; line-height: 1.7; color: #374151; }
    .compliance-doc .bullets li { margin-bottom: 0.25rem; }
    .compliance-doc .kv-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; font-weight: 600; margin-bottom: 0.4rem; }
    .compliance-doc .brand-list { font-size: 12px; line-height: 1.5; color: #1f2937; list-style: none; padding: 0; }
    .compliance-doc .brand-list li { padding: 0.15rem 0; border-bottom: 1px dashed #f3f4f6; }
    .compliance-doc .kv-table { width: 100%; font-size: 12.5px; }
    .compliance-doc .kv-table th { width: 30%; padding: 0.4rem 0.6rem; text-align: left; color: #6b7280; font-weight: 600; vertical-align: top; }
    .compliance-doc .kv-table td { padding: 0.4rem 0.6rem; color: #1f2937; vertical-align: top; }
    .compliance-doc .kv-table tr { border-bottom: 1px solid #f3f4f6; }
    .compliance-doc .data-table { width: 100%; font-size: 12px; border-collapse: collapse; margin-top: 0.5rem; }
    .compliance-doc .data-table th { background: #f9fafb; padding: 0.4rem 0.6rem; text-align: left; font-weight: 600; color: #374151; border-bottom: 1px solid #e5e7eb; }
    .compliance-doc .data-table td { padding: 0.3rem 0.6rem; border-bottom: 1px solid #f3f4f6; color: #1f2937; }
    .compliance-doc .data-table.dense td { padding: 0.2rem 0.6rem; font-size: 11.5px; }
    .compliance-doc .data-table .text-right { text-align: right; }
    .compliance-doc code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }

    .screen-only { display: block; }

    @media print {
      /* Print-only-section pattern : hide everything, then unhide just
         the report, then absolute-position it to fill the page. This
         lets us reuse the in-app layout chrome without it showing on
         the printed PDF. */
      body * { visibility: hidden !important; }
      .compliance-doc, .compliance-doc * { visibility: visible !important; }
      .compliance-doc {
        position: absolute !important;
        left: 0; top: 0; width: 100%;
      }
      .compliance-doc .screen-only { display: none !important; }
      body { background: white !important; }
      .compliance-doc .report { box-shadow: none; padding: 0; }
      .compliance-doc h2.section-title { page-break-after: avoid; }
      .compliance-doc .data-table tr { page-break-inside: avoid; }
      .compliance-doc .report-section { page-break-inside: avoid; }
      @page { margin: 1.5cm 1.8cm; }
    }
  </style>
</ScanResultsLayout>
