---
/**
 * Sprint 11 - Internal Linking Audit.
 *
 * Per-page audit of the internal link graph of the user's own pages that
 * LLMs cite during this scan. Surfaces topology (orphan / hub / dead-end)
 * and anchor quality issues (generic anchors, empty alt text, duplicates),
 * along with a per-page linking_score and recommended action.
 *
 * Data source : GET  /api/scans/{id}/internal-linking
 * Refresh     : POST /api/scans/{id}/internal-linking/refresh
 *
 * Laws of UX :
 *  - Peak-End  : hero shows avg_linking_score + dead_end / orphan counts.
 *  - Hick      : 4 filter chips (All / Dead-end / Orphan / Issues).
 *  - Jakob     : table + row-click-to-expand mirrors Reddit / Competitors / PR.
 *  - Von Restorff : dead-end rows = red ring, orphan = amber, hub = sky.
 *  - Table-first per user decision : no graph visualization in v1.
 */
export const prerender = false;
import ScanResultsLayout from '../../../../layouts/ScanResultsLayout.astro';
import Tip from '../../../../components/Tip.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');
const scanId = Astro.params.id as string;

const headers = { Cookie: `token=${token}` };
let data: any = null;
try {
  const res = await fetch(`http://api:8000/api/scans/${scanId}/internal-linking`, { headers });
  if (res.ok) data = await res.json();
} catch (_) {}

const pages: any[] = data?.pages || [];
const summary = data?.summary || {};
const lastFetched = data?.last_fetched;

function timeAgo(iso?: string): string {
  if (!iso) return 'never';
  const t = new Date(iso).getTime();
  if (Number.isNaN(t)) return 'never';
  const mins = Math.round((Date.now() - t) / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins} min ago`;
  const hrs = Math.round(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.round(hrs / 24);
  if (days < 14) return `${days}d ago`;
  return new Date(iso).toISOString().slice(0, 10);
}

function scoreClasses(score?: number | null) {
  if (score == null) return { bg: 'bg-gray-100', text: 'text-charcoal-light' };
  if (score >= 70) return { bg: 'bg-emerald-100', text: 'text-emerald-700' };
  if (score >= 40) return { bg: 'bg-amber-100', text: 'text-amber-700' };
  return { bg: 'bg-red-100', text: 'text-red-700' };
}

function topoChip(t?: string) {
  switch (t) {
    case 'dead_end': return { label: 'dead-end', cls: 'bg-red-50 text-red-700 font-semibold', tip: 'link_topo_dead_end', ring: 'ring-1 ring-red-300' };
    case 'orphan':   return { label: 'orphan',   cls: 'bg-amber-50 text-amber-700',           tip: 'link_topo_orphan',   ring: 'ring-1 ring-amber-300' };
    case 'hub':      return { label: 'hub',      cls: 'bg-sky-50 text-sky-700',               tip: 'link_topo_hub',      ring: 'ring-1 ring-sky-200' };
    default:         return { label: 'healthy',  cls: 'bg-emerald-50 text-emerald-700',       tip: 'link_topo_healthy',  ring: '' };
  }
}

function actionChip(a?: { label?: string; tone?: string }) {
  if (!a || !a.label) return { label: '-', cls: 'text-charcoal-light' };
  const tone = a.tone || 'low';
  const map: Record<string, string> = {
    urgent:   'bg-red-100 text-red-700 font-semibold',
    high:     'bg-orange-100 text-orange-700',
    medium:   'bg-amber-100 text-amber-800',
    positive: 'bg-emerald-50 text-emerald-700',
    low:      'bg-gray-100 text-charcoal-light',
  };
  return { label: a.label, cls: map[tone] || 'bg-gray-100 text-charcoal-light' };
}

function shortPath(u: string | null): string {
  if (!u) return '';
  try {
    const url = new URL(u);
    return url.pathname + (url.search || '');
  } catch (_) {
    return u;
  }
}

const defaultFilter = (summary.dead_end || 0) > 0 ? 'dead_end' : ((summary.orphan || 0) > 0 ? 'orphan' : 'issues');
---

<ScanResultsLayout scanId={scanId} activeTab="internal-linking">
  <div x-data={`{ filter: '${defaultFilter}', expanded: null, refreshing: false }`}>

    <p class="text-sm text-charcoal-light mb-6">
      Internal linking audit of the pages on your site that LLMs actually
      cite in this scan. We re-fetch each page, parse every internal &lt;a
      href&gt;, and surface the structural issues : orphan pages (no inbound
      links from other cited pages), dead-ends (no outbound internal links),
      generic anchor text ("click here") that teaches LLMs nothing.
    </p>

    {/* Hero KPI banner */}
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-white rounded-xl shadow-sm p-6 lg:col-span-2">
        <p class="text-[11px] text-charcoal-light uppercase tracking-wide mb-2">
          <Tip id="link_avg_score">Average linking score</Tip>
        </p>
        <div class="flex items-baseline gap-3">
          <span class="text-3xl font-bold text-charcoal-dark">{summary.avg_linking_score != null ? summary.avg_linking_score : '-'}</span>
          <span class="text-base text-charcoal-light">/ 100 - across {summary.total || 0} pages</span>
        </div>
        <p class="text-[10px] text-charcoal-light mt-2 leading-snug">
          Topology breakdown :
          {summary.dead_end > 0 && <span class="text-red-700 font-semibold mr-2">{summary.dead_end} dead-end</span>}
          {summary.orphan > 0 && <span class="text-amber-700 mr-2">{summary.orphan} orphan</span>}
          {summary.hub > 0 && <span class="text-sky-700 mr-2">{summary.hub} hub</span>}
          {summary.healthy > 0 && <span class="text-emerald-700">{summary.healthy} healthy</span>}
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <p class="text-[11px] text-charcoal-light uppercase tracking-wide mb-2">Issue mix</p>
        {(() => {
          const it = summary.issues_by_type || {};
          const entries = Object.entries(it).sort((a: any, b: any) => (b[1] as number) - (a[1] as number));
          if (entries.length === 0) {
            return <p class="text-xs text-charcoal-light italic mt-2">No anchor issues detected.</p>;
          }
          const labelMap = {
            generic_anchor: 'generic anchors',
            empty_anchor: 'empty anchors',
            duplicate_anchor: 'duplicate anchors',
          } as any;
          return (
            <div class="space-y-1">
              {entries.slice(0, 4).map(([t, n]: any) => (
                <div class="flex items-center justify-between text-xs">
                  <span class="text-charcoal-dark truncate">{labelMap[t] || t}</span>
                  <span class="text-charcoal-light">{n}</span>
                </div>
              ))}
            </div>
          );
        })()}
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex flex-col justify-between">
        <div>
          <p class="text-[11px] text-charcoal-light uppercase tracking-wide mb-2">Last refresh</p>
          <p class="text-sm text-charcoal-dark">{timeAgo(lastFetched)}</p>
          <p class="text-[10px] text-charcoal-light mt-1">
            ~1-2s per page, capped at 200 URLs per run. Free, no LLM.
          </p>
        </div>
        <button
          @click={`if (refreshing) return; refreshing = true; fetch('/api/scans/${scanId}/internal-linking/refresh?reset=true', { method: 'POST' }).then(r => r.json()).then(_ => { setTimeout(() => location.reload(), 60000); }).catch(() => { refreshing = false; });`}
          :disabled="refreshing"
          class="mt-3 px-3 py-1.5 text-xs font-medium rounded-lg bg-coral text-white hover:bg-coral-dark disabled:bg-gray-300 transition-colors"
        >
          <span x-show="!refreshing">Refresh audit</span>
          <span x-show="refreshing">Crawling pages...</span>
        </button>
      </div>
    </div>

    {pages.length === 0 && (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-800">
        No internal linking audit yet. Click <strong>Refresh audit</strong>
        above. We fetch each of the LLM-cited pages on your site (the same
        set as the Page Audit tab), parse every internal anchor link, and
        compute orphan / hub / dead-end status from the link graph.
      </div>
    )}

    {pages.length > 0 && (
      <div>
        {/* Filter chips */}
        <div class="flex items-center gap-2 mb-3 text-[11px] flex-wrap">
          <span class="text-charcoal-light">Show :</span>
          <button @click="filter = 'all'"
                  :class="filter === 'all' ? 'bg-charcoal-dark text-white' : 'bg-gray-100 text-charcoal-light hover:bg-gray-200'"
                  class="px-2 py-1 rounded transition-colors">
            All ({summary.total})
          </button>
          <button @click="filter = 'issues'"
                  :class="filter === 'issues' ? 'bg-orange-600 text-white' : 'bg-orange-50 text-orange-700 hover:bg-orange-100'"
                  class="px-2 py-1 rounded transition-colors"
                  title="Pages with at least one anchor issue OR a dead-end / orphan status.">
            Needs attention ({(summary.dead_end||0)+(summary.orphan||0) + Math.max(0, (summary.total||0) - (summary.healthy||0) - (summary.hub||0) - (summary.dead_end||0) - (summary.orphan||0))})
          </button>
          {summary.dead_end > 0 && (
            <button @click="filter = 'dead_end'"
                    :class="filter === 'dead_end' ? 'bg-red-600 text-white' : 'bg-red-50 text-red-700 hover:bg-red-100'"
                    class="px-2 py-1 rounded transition-colors font-semibold">
              Dead-end ({summary.dead_end})
            </button>
          )}
          {summary.orphan > 0 && (
            <button @click="filter = 'orphan'"
                    :class="filter === 'orphan' ? 'bg-amber-600 text-white' : 'bg-amber-50 text-amber-700 hover:bg-amber-100'"
                    class="px-2 py-1 rounded transition-colors">
              Orphan ({summary.orphan})
            </button>
          )}
          {summary.hub > 0 && (
            <button @click="filter = 'hub'"
                    :class="filter === 'hub' ? 'bg-sky-600 text-white' : 'bg-sky-50 text-sky-700 hover:bg-sky-100'"
                    class="px-2 py-1 rounded transition-colors">
              Hubs ({summary.hub})
            </button>
          )}
        </div>

        <div class="bg-white rounded-xl shadow-sm overflow-hidden">
          <table class="w-full text-[11px]">
            <thead class="bg-gray-50 text-charcoal-light text-[10px] uppercase tracking-wide">
              <tr>
                <th class="text-left px-3 py-2 font-semibold">Page</th>
                <th class="text-left px-3 py-2 font-semibold w-24">Topology</th>
                <th class="text-right px-3 py-2 font-semibold w-16">Inbound</th>
                <th class="text-right px-3 py-2 font-semibold w-16">Outbound</th>
                <th class="text-right px-3 py-2 font-semibold w-16">Generic</th>
                <th class="text-left px-3 py-2 font-semibold w-36">Action</th>
                <th class="text-right px-3 py-2 font-semibold w-16">Score</th>
                <th class="text-right px-3 py-2 font-semibold w-8"></th>
              </tr>
            </thead>
            <tbody>
              {pages.map((p: any, pi: number) => {
                const sc = scoreClasses(p.linking_score);
                const topo = topoChip(p.topology);
                const action = actionChip(p.recommended_action);
                const rowKey = `p${pi}`;
                const hasIssues = (p.issues || []).length > 0;
                const matchesIssuesFilter = hasIssues || ['dead_end','orphan'].includes(p.topology);
                return (
                  <>
                    <tr
                      x-show={`
                        filter === 'all'
                        || (filter === 'issues' && ${matchesIssuesFilter})
                        || filter === '${p.topology}'
                      `}
                      class={`border-t border-gray-100 hover:bg-gray-50/60 cursor-pointer ${topo.ring}`}
                      @click={`expanded = expanded === '${rowKey}' ? null : '${rowKey}'`}
                    >
                      <td class="px-3 py-2 align-top">
                        <a href={p.url} target="_blank" rel="noopener noreferrer"
                           class="text-charcoal-dark hover:underline font-medium leading-tight inline-block"
                           title={p.url}
                           @click.stop>
                          {p.title || shortPath(p.url) || '(no title)'}
                          <svg class="inline-block w-3 h-3 ml-1 align-text-top text-charcoal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                          </svg>
                        </a>
                        <div class="text-[10px] text-charcoal-light mt-0.5 truncate" title={p.url}>{shortPath(p.url)}</div>
                      </td>
                      <td class="px-3 py-2 align-top">
                        <Tip id={topo.tip}>
                          <span class={`inline-block text-[9px] px-1.5 py-0.5 rounded uppercase ${topo.cls}`}>
                            {topo.label}
                          </span>
                        </Tip>
                      </td>
                      <td class="px-3 py-2 align-top text-right text-charcoal-dark">
                        <Tip id="link_inbound">
                          <span>{p.inbound_count}</span>
                        </Tip>
                      </td>
                      <td class="px-3 py-2 align-top text-right text-charcoal-dark">
                        {p.outbound_internal_count}
                      </td>
                      <td class="px-3 py-2 align-top text-right">
                        {p.generic_anchor_count > 0 ? (
                          <Tip id="link_generic_anchor">
                            <span class="text-amber-700 font-medium">{p.generic_anchor_count}</span>
                          </Tip>
                        ) : (
                          <span class="text-charcoal-light">0</span>
                        )}
                      </td>
                      <td class="px-3 py-2 align-top">
                        <Tip id="link_action">
                          <span class={`inline-block text-[9px] px-2 py-0.5 rounded ${action.cls}`}>{action.label}</span>
                        </Tip>
                      </td>
                      <td class="px-3 py-2 align-top text-right">
                        {p.linking_score != null ? (
                          <Tip id="link_score">
                            <span class={`inline-block text-[10px] px-2 py-0.5 rounded font-semibold ${sc.bg} ${sc.text}`}>
                              {p.linking_score}
                            </span>
                          </Tip>
                        ) : p.fetch_error ? (
                          <Tip id="comp_fetch_fail">
                            <span class="inline-block text-[9px] px-1.5 py-0.5 rounded bg-red-50 text-red-600">fail</span>
                          </Tip>
                        ) : (
                          <span class="text-charcoal-light">-</span>
                        )}
                      </td>
                      <td class="px-3 py-2 align-top text-right text-charcoal-light">
                        <svg class="w-3.5 h-3.5 inline-block transition-transform"
                             :class={`expanded === '${rowKey}' ? 'rotate-180' : ''`}
                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                      </td>
                    </tr>
                    <tr x-show={`expanded === '${rowKey}'`} x-transition>
                      <td colspan="8" class="px-3 py-3 bg-gray-50/40 border-t border-gray-100">

                        {/* Issues */}
                        {p.issues && p.issues.length > 0 && (
                          <div class="mb-3 px-3 py-2 bg-white rounded border border-amber-200">
                            <p class="text-[10px] uppercase tracking-wide text-amber-700 font-semibold mb-2">
                              {p.issues.length} issue{p.issues.length > 1 ? 's' : ''}
                            </p>
                            <ul class="space-y-2">
                              {p.issues.slice(0, 10).map((issue: any) => (
                                <li class="text-[11px] text-charcoal-dark leading-snug">
                                  <span class={`inline-block text-[9px] px-1.5 py-0.5 rounded uppercase mr-1.5 ${
                                    issue.severity === 'high' ? 'bg-red-50 text-red-700' :
                                    issue.severity === 'medium' ? 'bg-amber-50 text-amber-700' :
                                    'bg-gray-100 text-charcoal-light'
                                  }`}>{issue.severity}</span>
                                  {issue.message}
                                  {issue.target && (
                                    <a href={issue.target} target="_blank" rel="noopener noreferrer"
                                       class="ml-1 text-charcoal-light hover:text-charcoal-dark italic" @click.stop>
                                      → {shortPath(issue.target)}
                                    </a>
                                  )}
                                </li>
                              ))}
                            </ul>
                          </div>
                        )}

                        {/* Inbound sources */}
                        {p.inbound_sources && p.inbound_sources.length > 0 && (
                          <div class="mb-3 px-3 py-2 bg-white rounded border border-gray-100">
                            <p class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold mb-1">
                              Inbound from {p.inbound_count} cited page{p.inbound_count > 1 ? 's' : ''}
                              <span class="text-[9px] text-charcoal-light normal-case italic font-normal"> (showing first {p.inbound_sources.length})</span>
                            </p>
                            <ul class="space-y-0.5">
                              {p.inbound_sources.map((src: string) => (
                                <li class="text-[11px] text-charcoal-dark truncate">
                                  <a href={src} target="_blank" rel="noopener noreferrer"
                                     class="hover:underline text-charcoal-dark" @click.stop>{shortPath(src) || src}</a>
                                </li>
                              ))}
                            </ul>
                          </div>
                        )}

                        {/* Outbound sample */}
                        {p.outbound_internal_links && p.outbound_internal_links.length > 0 && (
                          <div class="mb-3 px-3 py-2 bg-white rounded border border-gray-100">
                            <p class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold mb-2">
                              Outbound internal links
                              <span class="text-[9px] text-charcoal-light normal-case italic font-normal"> (first 10 of {p.outbound_internal_count})</span>
                            </p>
                            <ul class="space-y-1">
                              {p.outbound_internal_links.slice(0, 10).map((link: any) => (
                                <li class="text-[11px] flex items-baseline gap-2 leading-snug">
                                  <span class={`shrink-0 ${link.is_generic ? 'text-amber-700 font-medium' : link.is_empty ? 'text-red-700 italic' : 'text-charcoal-dark'}`}>
                                    "{link.is_empty ? '(empty)' : (link.anchor || '').slice(0, 80)}"
                                  </span>
                                  <a href={link.target} target="_blank" rel="noopener noreferrer"
                                     class="text-charcoal-light hover:underline truncate" @click.stop>
                                    → {shortPath(link.target)}
                                  </a>
                                  {link.is_generic && <span class="text-[9px] text-amber-700 italic shrink-0">generic</span>}
                                  {link.is_empty && <span class="text-[9px] text-red-700 italic shrink-0">empty</span>}
                                  {link.position && <span class="text-[9px] text-charcoal-light shrink-0">[{link.position}]</span>}
                                </li>
                              ))}
                            </ul>
                          </div>
                        )}

                        {/* Action guidance */}
                        <div class="px-3 py-2 bg-white rounded border border-coral/20">
                          <p class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold mb-1">Playbook</p>
                          <p class="text-[12px] text-charcoal-dark leading-relaxed">
                            {p.topology === 'dead_end' && (
                              <>This page has zero internal links going out. Add 3-8 contextual links to related products, FAQ, or pillar pages so PageRank flows + LLMs can navigate deeper into your site.</>
                            )}
                            {p.topology === 'orphan' && (
                              <>No other LLM-cited page on your site links here. Identify 2-3 thematically-related hub pages (from the hub filter above) and add contextual links pointing to this one.</>
                            )}
                            {p.topology === 'hub' && (
                              <>This page is a topical hub - other cited pages already point here. Make sure its outbound anchors are descriptive 2-5 word phrases so PageRank flows back to product / category pages with topical context.</>
                            )}
                            {p.topology === 'healthy' && p.generic_anchor_count > 0 && (
                              <>Structurally fine, but {p.generic_anchor_count} generic anchor(s) waste linking opportunities. Rewrite "click here" / "lire la suite" style anchors with descriptive 2-5 word phrases.</>
                            )}
                            {p.topology === 'healthy' && p.generic_anchor_count === 0 && (
                              <>No structural red flags. Keep an eye on this page if you republish content - anchor quality decays over edit cycles.</>
                            )}
                          </p>
                        </div>
                      </td>
                    </tr>
                  </>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    )}

  </div>
</ScanResultsLayout>
