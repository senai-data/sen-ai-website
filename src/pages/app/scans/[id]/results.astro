---
/**
 * Scan Results - Overview
 *
 * Narrative summary answering "How am I doing ?" in one screen. Deep
 * dives live in their dedicated tabs (Topics, Personas, Competitors,
 * Questions, Actions). This page is the entry point every user sees
 * first when opening a scan.
 *
 * Layout per design handoff `03-flagship.html` (lower half) :
 *
 *   ┌──────┬──────┬──────┬──────┐
 *   │ KPI1 │ KPI2 │ KPI3 │ KPI4 │  ← 4-stat row with sparklines
 *   └──────┴──────┴──────┴──────┘
 *   ┌──────────┬───────┬─────┐
 *   │ Provider │  SoV  │ Sent│   ← 5 / 4 / 3 cols
 *   ├──────────┴───┬───┴─────┤
 *   │ Top questions │  Recent│   ← 7 / 5 cols
 *   └───────────────┴────────┘
 *
 *   secondary : Top Opportunities (kept - most actionable CTA)
 *
 * Laws of UX :
 *   - Serial Position : 4 KPIs first = remembered ; recent activity
 *     last = recency anchor.
 *   - Aesthetic-Usability : one card style, one panel style, no chart
 *     library load - SVG sparklines + HTML/CSS bars.
 *   - Hick : 4 KPIs, not 8 + 3 chart cards as before.
 *   - Von Restorff : critical sentiment / negative delta turns red,
 *     everything else stays quiet charcoal ("colour earns attention").
 *   - Doherty : all data is SSR-prepared, no in-flight chart paint.
 */
export const prerender = false;
import ScanResultsLayout from '../../../../layouts/ScanResultsLayout.astro';
import { fetchScanHeader } from '../../../../lib/scan-header';
import { sparkSvg, modelChangeNote, boundaryChipLabel } from '../../../../lib/sparkline';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');
const scanId = Astro.params.id as string;

const rangeParam = Astro.url.searchParams.get('range') || 'all';
const fromParam = Astro.url.searchParams.get('from') || '';
const toParam = Astro.url.searchParams.get('to') || '';
const runParam = Astro.url.searchParams.get('run') || '';
const effectiveScanId = (rangeParam === 'latest' && runParam) ? runParam : scanId;
const providerParam = Astro.url.searchParams.get('provider') || 'all';

// Perf 2026-07-18 : start the layout's header fetch NOW so it overlaps this
// page's own aggregated fetch below (page frontmatter runs BEFORE the layout
// renders - without this the two ran back-to-back). Same params the layout
// would use ; passed via the headerPromise prop.
const headerPromise = fetchScanHeader(effectiveScanId, token, rangeParam, fromParam || undefined, toParam || undefined, providerParam);

const useAggregated = rangeParam !== 'latest';
let resultsUrl = `http://api:8000/api/scans/${effectiveScanId}/results`;
if (useAggregated) {
  const aggParams = new URLSearchParams();
  if (fromParam) aggParams.set('from_date', fromParam);
  if (toParam) aggParams.set('to_date', toParam);
  // Perf 2026-07-18 : this tab reads details for citations/competitors but
  // never renders response_text - skip the multi-MB texts (only the
  // Questions tab needs them). And it only reads details[].runs rows of the
  // LATEST scan (cf. latestRows filter below) - details_scope=latest drops
  // the older runs' citation/mention arrays, the payload's real bulk.
  aggParams.set('include_responses', 'false');
  aggParams.set('details_scope', 'latest');
  resultsUrl = `http://api:8000/api/scans/${effectiveScanId}/results/aggregated${aggParams.toString() ? '?' + aggParams.toString() : ''}`;
}
const providerSuffix = providerParam !== 'all' ? `${resultsUrl.includes('?') ? '&' : '?'}provider=${providerParam}` : '';
resultsUrl += providerSuffix;

const headers = { Cookie: `token=${token}` };
let data: any = null;
let opportunitiesData: any = null;

try {
  const [resR, resO] = await Promise.all([
    fetch(resultsUrl, { headers }),
    fetch(`http://api:8000/api/scans/${effectiveScanId}/opportunities${providerParam !== 'all' ? '?provider=' + providerParam : ''}`, { headers }),
  ]);
  if (resR.ok) data = await resR.json();
  if (resO.ok) opportunitiesData = await resO.json();
} catch (_) {}

const o = data?.overview;
const competitors = data?.competitors || [];
const details = data?.details || [];
const oppsItems = opportunitiesData?.opportunities || [];
const isAggregated = data?.mode === 'aggregated';

const currentRate = o?.citation_rate ?? 0;
// N-runs (T3) - 95% CI on the headline mention rate, binomial over the run
// samples. Shown only when the scan multi-sampled (runs_depth > 1) : a
// poll-style "X% ± Y pts" instead of a fragile point estimate.
const runsDepth = o?.runs_depth ?? 1;
const delta = o?.delta ?? null;
// P3 model eras : delta_reason='model_changed' means the API suppressed the
// delta because the AI model mix changed between the last two runs - the
// chip replaces the delta instead of letting the comparison lie.
const deltaReason = o?.delta_reason ?? null;
const totalTests = o?.total_tests ?? 0;
const trendFromApi = o?.trend || [];
const lastPoint = trendFromApi[trendFromApi.length - 1] || null;
const prevPoint = trendFromApi[trendFromApi.length - 2] || null;
const eraChipLabel = deltaReason === 'model_changed'
  ? boundaryChipLabel(prevPoint?.models, lastPoint?.models)
  : null;
const eraChipTitle = deltaReason === 'model_changed'
  ? (modelChangeNote(prevPoint?.models, lastPoint?.models) || 'The AI model mix changed on this run - the previous run is not directly comparable.')
  : '';
const _p = (currentRate ?? 0) / 100;
const marginPts = (runsDepth > 1 && totalTests > 0)
  ? Math.round(1.96 * Math.sqrt(_p * (1 - _p) / totalTests) * 1000) / 10
  : null;

// ─── Refund + circuit breaker (kept, top-of-page safety rail) ───
const providerStatus: any = o?.provider_status || null;
const refundInfo: any = o?.refund_info || null;
const trippedProviders: string[] = providerStatus
  ? Object.entries(providerStatus).filter(([_, s]: any) => s.tripped).map(([p]) => p)
  : [];

// ─── KPI trends - one point per run, from the API's per-run aggregates.
// Sparkline shows when >= 2 points exist ; otherwise the tile shows a
// Goal-Gradient hint nudging the user toward Rescan / a schedule.
const mentionRateTrend: number[] = trendFromApi.map((t: any) => t.citation_rate).filter((v: any) => v != null);
// Sentiment is NOT comparable across the seo-llm import break (old analyzer
// ~+0.5 baseline vs v2 prompt ~+0.1) : on a mixed lineage the sparkline reads
// as a fake degradation, so we hide it and show the latest value only.
const hasImportedRuns = trendFromApi.some((t: any) => t.import_origin);
const hasNativeRuns = trendFromApi.some((t: any) => t.import_origin === false);
const sentimentComparable = !(hasImportedRuns && hasNativeRuns);
const sentimentTrend: number[] = sentimentComparable
  ? trendFromApi.map((t: any) => t.sentiment_score).filter((v: any) => v != null)
  : [];
const sovTrend: number[] = trendFromApi.map((t: any) => t.sov).filter((v: any) => v != null);
const hasTrend = mentionRateTrend.length > 1;

function trendTone(vals: number[]): 'up' | 'down' | 'flat' {
  if (vals.length < 2) return 'flat';
  const d = vals[vals.length - 1] - vals[vals.length - 2];
  return d > 0 ? 'up' : d < 0 ? 'down' : 'flat';
}

// ─── Editorial narrative - generated by a Claude job at every scan
// completion (worker/handlers/generate_editorial.py), stored in
// scans.summary.editorial. hook + interpretation open the page ;
// competitor_insight lands in the Share-of-voice panel.
const editorial: any = o?.editorial || null;

// ─── Current-run answer rows : one entry per (question × AI) answer of the
// LATEST completed run. Aggregated mode groups details by question with the
// whole lineage in d.runs - filter on the newest scan id (included_runs is
// sorted oldest → newest) so lineage history never pollutes "current state".
// Single-run mode already ships one row per (question × provider) pair.
const latestRunScanId = (data?.included_runs || []).slice(-1)[0]?.id || null;
interface CurRow { question: string; persona: string; topic: string | null; provider: string; mentioned: boolean; analysis: any; mentions: any[]; lineageMentions: number; lineageRuns: number; }
const currentRows: CurRow[] = [];
details.forEach((d: any) => {
  const push = (r: any) => currentRows.push({
    question: d.question, persona: d.persona, topic: d.topic_name || null,
    provider: r.provider, mentioned: !!r.brand_mentioned,
    analysis: r.brand_analysis || {}, mentions: r.brand_mentions || [],
    lineageMentions: isAggregated ? (d.mention_count || 0) : 0,
    lineageRuns: isAggregated ? (d.total_runs || 1) : (d.runs_total || 1),
  });
  if (isAggregated) {
    const latestRows = (d.runs || []).filter((r: any) => r.scan_id === latestRunScanId);
    (latestRows.length ? latestRows : (d.latest ? [d.latest] : [])).forEach(push);
  } else {
    push(d);
  }
});
const isTargetMention = (bm: any) => !!(bm?.est_marque_cible || bm?.is_target_brand || bm?.classification === 'my_brand');

// ─── KPI 2 : Recommendation funnel (Mentioned → Recommended → First choice).
// Replaces the raw citations counter : a 40% mention rate can hide 90%
// passive name-drops - the funnel says whether the AIs actually PUSH the
// brand (brand_analysis.recommandation_marque_cible + per-mention
// type_recommandation='premiere_option').
const answersTotal = currentRows.length;
let funMentioned = 0, funRecommended = 0, funFirst = 0;
currentRows.forEach(r => {
  // Monotonic by construction (first ⊆ recommended ⊆ mentioned) : the raw
  // brand_analysis.recommandation_marque_cible flag only reflects the FIRST
  // target mention, which can undercount below the premiere_option total -
  // derive all three stages from the same mentions[] source instead.
  const targetBms = r.mentions.filter((bm: any) => isTargetMention(bm));
  const first = targetBms.some((bm: any) => bm.type_recommandation === 'premiere_option');
  const reco = first || targetBms.some((bm: any) => bm.est_recommandation || bm.type_recommandation === 'alternative') || !!r.analysis?.recommandation_marque_cible;
  if (r.mentioned || targetBms.length > 0) funMentioned++;
  if (reco) funRecommended++;
  if (first) funFirst++;
});
const funnelRows = [
  { label: 'Mentioned', n: funMentioned, title: 'Answers naming your brand at all.' },
  { label: 'Recommended', n: funRecommended, title: 'Answers where the AI actively recommends your brand - not just names it.' },
  { label: 'First choice', n: funFirst, title: 'Answers presenting your brand as the first option to pick.' },
];
const funPct = (n: number) => answersTotal > 0 ? Math.round((n / answersTotal) * 100) : 0;

// ─── Panel C : brand rank in AI answers. position_distribution is computed
// at scan completion (generate_editorial) : rank of the focus brand among
// the brands each answer cites. Delta vs parent run is in percentage points.
const posDist: any = o?.position_distribution || null;
const posDelta: any = o?.position_distribution_delta || null;
const posTotal: number = posDist?.total || 0;
const POS_BUCKETS: Array<[string, string]> = [
  ['top1', 'Ranked 1st'],
  ['top2_3', '2nd - 3rd'],
  ['top4_5', '4th - 5th'],
  ['top6plus', '6th or later'],
  ['not_cited', 'Not mentioned'],
];

// ─── "Advised against" alert - an AI explicitly steering users AWAY from
// the brand is the most urgent signal of the dataset, previously drowned in
// the average sentiment scalar. Hidden when zero (the common case).
const avoidRows = currentRows.flatMap(r => {
  const bm = r.mentions.find((b: any) => isTargetMention(b) && b.type_recommandation === 'a_eviter');
  return bm ? [{ question: r.question, provider: r.provider, quote: (bm.contexte || '').trim(), why: (bm.sentiment_justification || '').trim() }] : [];
});

// ─── Verbatims : what the AIs literally say about the brand. contexte is
// the analyzer's extracted quote per mention (Sentiment Judge overlay
// already applied API-side). Proof beats a +0.53 scalar : pick the top
// "first choice" quote, the sharpest negative, then fill to 3.
interface Quote { text: string; sentiment: string; reco: string; why: string; provider: string; question: string; }
const quotePool: Quote[] = [];
const seenQuote = new Set<string>();
currentRows.forEach(r => {
  r.mentions.forEach((bm: any) => {
    if (!isTargetMention(bm)) return;
    const text = (bm.contexte || '').trim();
    if (text.length < 25 || seenQuote.has(text.toLowerCase())) return;
    seenQuote.add(text.toLowerCase());
    quotePool.push({ text, sentiment: (bm.sentiment || '').toLowerCase(), reco: bm.type_recommandation || '', why: (bm.sentiment_justification || '').trim(), provider: r.provider, question: r.question });
  });
});
const isPosQ = (q: Quote) => q.sentiment.startsWith('pos');
const isNegQ = (q: Quote) => q.sentiment.startsWith('neg') || q.sentiment.startsWith('nég');
const quotes: Quote[] = [];
{
  const firstQ = quotePool.find(q => q.reco === 'premiere_option' && isPosQ(q));
  const negQ = quotePool.filter(isNegQ).sort((a, b) => (b.why ? 1 : 0) - (a.why ? 1 : 0))[0];
  const posQ = quotePool.find(q => isPosQ(q) && q !== firstQ);
  const neuQ = quotePool.find(q => !isPosQ(q) && !isNegQ(q));
  [firstQ, negQ, posQ, neuQ].forEach(q => { if (q && quotes.length < 3 && !quotes.includes(q)) quotes.push(q); });
}

// ─── KPI 3 : Sentiment score (-1..+1 from brand_mentions[].sentiment on target) ───
let sentPos = 0, sentNeu = 0, sentNeg = 0;
details.forEach((d: any) => {
  const bms = (isAggregated ? (d.latest?.brand_mentions || []) : (d.brand_mentions || [])) as any[];
  bms.forEach(bm => {
    if (!bm?.est_marque_cible && !bm?.is_target_brand && bm?.classification !== 'target') return;
    const s = (bm.sentiment || '').toLowerCase();
    if (s.startsWith('pos')) sentPos++;
    else if (s.startsWith('neg') || s.startsWith('nég')) sentNeg++;
    else sentNeu++;
  });
});
const sentTotal = sentPos + sentNeu + sentNeg;
const sentScore = sentTotal > 0 ? Math.round(((sentPos - sentNeg) / sentTotal) * 100) / 100 : 0;

// ─── KPI 4 : Share of voice (my mentions / (my + competitors) × 100) ───
const myMentions = o?.target_cited ?? 0;
const competitorMentions = competitors.reduce((s: number, c: any) => s + (c.mentions || 0), 0);
const totalVoice = myMentions + competitorMentions;
const sovPct = totalVoice > 0 ? Math.round((myMentions / totalVoice) * 100) : 0;

// ─── Panel A : Mention rate by AI (group by provider ; computed on
// brand_mentioned - the old "Citation rate" title lied, citations are the
// cited SOURCES counted on the Citations tab) ───
const providerMap: Record<string, { cited: number; total: number }> = {};
details.forEach((d: any) => {
  const prov = (isAggregated ? d.latest?.provider : d.provider) || d.provider;
  if (!prov) return;
  if (!providerMap[prov]) providerMap[prov] = { cited: 0, total: 0 };
  providerMap[prov].total++;
  const mentioned = isAggregated ? d.latest?.brand_mentioned : d.brand_mentioned;
  if (mentioned) providerMap[prov].cited++;
});
const providerBars = Object.entries(providerMap)
  .map(([prov, r]) => ({ prov, rate: r.total > 0 ? Math.round((r.cited / r.total) * 100) : 0 }))
  .sort((a, b) => b.rate - a.rate);

const PROV_VIS: Record<string, { bg: string; ab: string; label: string }> = {
  openai:  { bg: '#10A37F', ab: 'O', label: 'OpenAI' },
  gemini:  { bg: '#4285F4', ab: 'G', label: 'Gemini' },
  claude:  { bg: '#D97757', ab: 'C', label: 'Claude' },
  mistral: { bg: '#FF7000', ab: 'M', label: 'Mistral' },
};
function provVis(p: string) {
  return PROV_VIS[(p || '').toLowerCase()] || { bg: 'var(--neutral-500)', ab: (p || '?').slice(0, 1).toUpperCase(), label: p };
}

// ─── Panel B : Share of voice (top 4 competitors + your brand) ───
// Case-insensitive merge first : the historical seo-llm runs emitted
// "La Roche-Posay" / "Bioderma" while sen-ai's BrandAnalyzer lowercases,
// so the API competitor list can carry the same brand twice. Merge on
// lower(name), keep the casing variant with the most uppercase (usually
// the brand's official spelling), sum the mentions.
type SovRow = { name: string; mentions: number; you: boolean };
const merged: Record<string, { name: string; mentions: number }> = {};
competitors.forEach((c: any) => {
  const key = (c.name || '').trim().toLowerCase();
  if (!key) return;
  if (!merged[key]) {
    merged[key] = { name: c.name, mentions: 0 };
  } else if ((c.name.match(/[A-Z]/g) || []).length > (merged[key].name.match(/[A-Z]/g) || []).length) {
    merged[key].name = c.name;
  }
  merged[key].mentions += c.mentions || 0;
});
const focusKey = (o?.focus_brand || '').trim().toLowerCase();
const sovItemsRaw: SovRow[] = Object.entries(merged)
  .filter(([k]) => k !== focusKey)
  .map(([, v]) => ({ name: v.name, mentions: v.mentions, you: false }))
  .sort((a, b) => b.mentions - a.mentions)
  .slice(0, 4);
sovItemsRaw.push({ name: o?.focus_brand || o?.domain || 'You', mentions: myMentions, you: true });
sovItemsRaw.sort((a, b) => b.mentions - a.mentions);
const sovMax = Math.max(1, ...sovItemsRaw.map(r => r.mentions));

// ─── Panel D : questions competitors own. A "steal" = the target brand is
// absent from every current-run answer to the question while a CLASSIFIED
// competitor (client_brands, never raw cited domains) is named instead.
// Ranked by competitor pressure. Falls back to weakest-first when the run
// has no nominal steal (nothing to attack by name).
interface GapRow { question: string; persona: string; topic: string | null; topComp: string; othersCount: number; compMentions: number; }
const gapAgg = new Map<string, any>();
currentRows.forEach(r => {
  if (!r.question) return;
  let g = gapAgg.get(r.question);
  if (!g) { g = { question: r.question, persona: r.persona, topic: r.topic, mentioned: false, comps: new Map<string, { name: string; n: number }>() }; gapAgg.set(r.question, g); }
  if (r.mentioned) g.mentioned = true;
  r.mentions.forEach((bm: any) => {
    if (bm?.classification !== 'competitor' || bm?.contexte_valide === false) return;
    const raw = (bm.brand_name_groupby || bm.brand_name || '').trim();
    if (!raw) return;
    const key = raw.toLowerCase();
    const cur = g.comps.get(key) || { name: raw, n: 0 };
    if ((raw.match(/[A-Z]/g) || []).length > (cur.name.match(/[A-Z]/g) || []).length) cur.name = raw;
    cur.n += bm.nb_mentions || 1;
    g.comps.set(key, cur);
  });
});
// brand_name_groupby is lowercased upstream - restore display casing when
// no properly-cased variant was seen ("la roche-posay" → "La Roche-Posay").
const displayBrand = (name: string) => name === name.toLowerCase()
  ? name.replace(/(^|[\s-])\p{L}/gu, (c: string) => c.toUpperCase())
  : name;
const gapRows: GapRow[] = [...gapAgg.values()]
  .filter((g: any) => !g.mentioned && g.comps.size > 0)
  .map((g: any) => {
    const sorted = [...g.comps.values()].sort((a: any, b: any) => b.n - a.n);
    return {
      question: g.question, persona: g.persona, topic: g.topic,
      topComp: displayBrand(sorted[0].name), othersCount: sorted.length - 1,
      compMentions: sorted.reduce((s: number, c: any) => s + c.n, 0),
    };
  })
  .sort((a, b) => b.compMentions - a.compMentions)
  .slice(0, 5);

// ─── Battlefield map : topics x brands. A global 5% share of voice hides
// "22% on sun care, 0% on anti-ageing" - this grid says which territories you
// hold and which a rival holds. Rows = topics (your presence first), columns =
// you + the top competitor BRANDS of the scan (classified only, never cited
// domains). Cell = share of that topic's brand mentions.
interface HeatCell { pct: number; n: number; }
const topicAgg = new Map<string, { total: number; byBrand: Map<string, number>; answers: number; mentioned: number }>();
const brandTotals = new Map<string, { name: string; n: number }>();
currentRows.forEach(r => {
  const topic = r.topic || 'Other';
  let t = topicAgg.get(topic);
  if (!t) { t = { total: 0, byBrand: new Map(), answers: 0, mentioned: 0 }; topicAgg.set(topic, t); }
  t.answers++;
  if (r.mentioned) t.mentioned++;
  r.mentions.forEach((bm: any) => {
    if (bm?.contexte_valide === false) return;
    const isYou = isTargetMention(bm);
    // Only YOU and classified competitors enter the grid - "discovered"
    // entities and cited domains would turn the map into noise.
    if (!isYou && bm?.classification !== 'competitor') return;
    const raw = (bm.brand_name_groupby || bm.brand_name || '').trim();
    if (!raw && !isYou) return;
    const key = isYou ? '__you__' : raw.toLowerCase();
    const n = bm.nb_mentions || 1;
    t.byBrand.set(key, (t.byBrand.get(key) || 0) + n);
    t.total += n;
    const bt = brandTotals.get(key) || { name: isYou ? (o?.focus_brand || 'You') : displayBrand(raw), n: 0 };
    bt.n += n;
    brandTotals.set(key, bt);
  });
});
const heatCompetitors = [...brandTotals.entries()]
  .filter(([k]) => k !== '__you__')
  .sort((a, b) => b[1].n - a[1].n)
  .slice(0, 5);
const heatColumns: Array<{ key: string; label: string; you: boolean }> = [
  { key: '__you__', label: brandTotals.get('__you__')?.name || o?.focus_brand || 'You', you: true },
  ...heatCompetitors.map(([k, v]) => ({ key: k, label: v.name, you: false })),
];
const heatRows = [...topicAgg.entries()]
  .filter(([, t]) => t.total > 0)
  .map(([topic, t]) => ({
    topic,
    answers: t.answers,
    cells: heatColumns.map(c => {
      const n = t.byBrand.get(c.key) || 0;
      return { pct: t.total > 0 ? Math.round((n / t.total) * 100) : 0, n } as HeatCell;
    }),
  }))
  // Weakest territories first : where you own the least is what to read first.
  .sort((a, b) => a.cells[0].pct - b.cells[0].pct);
// Colour ramp : your column reads green when you own the topic, competitor
// columns read orange when they do. Neutral below 10% so the grid stays calm.
function heatStyle(pct: number, you: boolean): string {
  if (pct <= 0) return 'background:var(--color-surface-muted);color:var(--color-text-muted)';
  const a = Math.min(0.14 + (pct / 100) * 0.72, 0.9);
  return you
    ? `background:rgba(16,185,129,${a.toFixed(2)});color:${pct > 45 ? '#fff' : 'var(--color-text-primary)'}`
    : `background:rgba(249,115,22,${(a * 0.82).toFixed(2)});color:${pct > 55 ? '#fff' : 'var(--color-text-primary)'}`;
}

// ─── Panel D fallback : Top buyer questions (dedup, sorted by ascending mention rate = weakest first) ───
interface QRow { question: string; rate: number; mention_count: number; total_runs: number; unit: string; }
const seenQ = new Set<string>();
const allQ: QRow[] = [];
details.forEach((d: any) => {
  const q = d.question;
  if (!q || seenQ.has(q)) return;
  seenQ.add(q);
  // N-runs (T3) : single-scan mode now carries intra-scan sampling stats
  // (runs_total / mention_rate, both 1|0-shaped on legacy N=1 scans) -
  // "0/10 runs" reads exactly like the lineage "0/5 scans" did.
  const runs = isAggregated ? (d.total_runs || 1) : (d.runs_total || 1);
  const mc = isAggregated
    ? (d.mention_count || 0)
    : Math.round((d.mention_rate ?? (d.brand_mentioned ? 1 : 0)) * (d.runs_total || 1));
  const rate = runs > 0 ? Math.round((mc / runs) * 100) : 0;
  // Unit disambiguates the two multiplicities : aggregated lineage points
  // are (scan x AI) pairs = "answers" (5 scans x 2 AIs = 10 answers, NOT
  // "10 scans"), intra-scan samples = "runs". Hidden when single.
  const unit = runs > 1 ? (isAggregated ? 'answers' : 'runs') : '';
  allQ.push({ question: q, rate, mention_count: mc, total_runs: runs, unit });
});
allQ.sort((a, b) => a.rate - b.rate);
const topQuestions = allQ.slice(0, 5);

function qStatus(rate: number): { label: string; sev: 'high' | 'medium' | 'low' } {
  if (rate < 15) return { label: 'Missing', sev: 'high' };
  if (rate < 60) return { label: 'Weak', sev: 'medium' };
  return { label: 'Cited', sev: 'low' };
}

// ─── Panel E : Recent activity (synthesised from available signals) ───
function timeAgo(iso?: string): string {
  if (!iso) return '';
  const t = new Date(iso).getTime();
  if (Number.isNaN(t)) return '';
  const now = Date.now();
  const sec = Math.max(0, Math.floor((now - t) / 1000));
  if (sec < 60) return 'Just now';
  if (sec < 3600) { const m = Math.floor(sec / 60); return `${m} min${m > 1 ? 's' : ''} ago`; }
  if (sec < 86400) { const h = Math.floor(sec / 3600); return `${h} hour${h > 1 ? 's' : ''} ago`; }
  const d = Math.floor(sec / 86400);
  if (d === 1) return 'Yesterday';
  if (d < 7) return `${d} days ago`;
  return new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
}
const discoveredBrands = data?.discovered_brands || [];

interface ActRow { tone: 'positive' | 'critical' | 'warning' | 'info' | 'neutral'; text: string; time: string; }
const activity: ActRow[] = [];
if (o?.scan_date) {
  activity.push({
    tone: 'positive',
    text: `Scan completed - ${totalTests} test${totalTests > 1 ? 's' : ''} across ${o.providers?.length || 0} AI${(o.providers?.length || 0) > 1 ? 's' : ''}`,
    time: timeAgo(o.scan_date),
  });
}
if (delta != null && delta !== 0) {
  activity.push({
    tone: delta > 0 ? 'positive' : 'critical',
    text: `Mention rate ${delta > 0 ? 'up' : 'down'} ${Math.abs(delta).toFixed(1)} pts vs last run`,
    time: timeAgo(o?.scan_date),
  });
}
if (discoveredBrands.length > 0) {
  const sample = discoveredBrands.slice(0, 2).map((b: any) => b.name).join(', ');
  activity.push({
    tone: 'info',
    text: `${discoveredBrands.length} brand${discoveredBrands.length > 1 ? 's' : ''} discovered by AI: ${sample}${discoveredBrands.length > 2 ? '...' : ''}`,
    time: timeAgo(o?.scan_date),
  });
}
if (trippedProviders.length > 0) {
  activity.push({
    tone: 'warning',
    text: `${trippedProviders.length} provider${trippedProviders.length > 1 ? 's' : ''} stopped mid-scan: ${trippedProviders.join(', ')}`,
    time: timeAgo(o?.scan_date),
  });
}
if (refundInfo) {
  activity.push({
    tone: 'warning',
    text: `${refundInfo.amount} credit${refundInfo.amount > 1 ? 's' : ''} refunded for undelivered runs`,
    time: timeAgo(o?.scan_date),
  });
}

// ─── Secondary section : Top Opportunities (kept) ───
// Opportunities are written one row per (question, provider) : count DISTINCT
// questions so this page and the Actions tab use the same unit (you write the
// FAQ once). Without this the Overview promised "406 opportunities" and Actions
// showed 228 - same data, two counting methods.
const oppQuestionKeys = new Set(
  oppsItems.map((o: any) => (o.question || o.id || '').trim().toLowerCase()).filter(Boolean),
);
const oppQuestionCount = oppQuestionKeys.size || oppsItems.length;
const actionableKeys = new Set(
  oppsItems
    .filter((o: any) => o.priority === 'critique' || o.priority === 'haute')
    .map((o: any) => (o.question || o.id || '').trim().toLowerCase())
    .filter(Boolean),
);
const actionableCount = actionableKeys.size;
const topActions = oppsItems.slice(0, 3);

// Sparkline rendering is shared with dashboard + agency overview
// (src/lib/sparkline.ts, imported above). Design notes live there.

// Tooltip labels per run : "23 Mar : <value>" built from trend dates.
// P3 model eras : boundary points get a ringed dot (markers) + the
// old → new detail appended to their tooltip.
const runDates: string[] = trendFromApi.map((t: any) => {
  const d = t.completed_at ? new Date(t.completed_at) : null;
  return d ? d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) : `Run ${(t.run_index ?? 0) + 1}`;
});
const eraNotes: string[] = trendFromApi.map((t: any, i: number) =>
  t.model_changed ? modelChangeNote(trendFromApi[i - 1]?.models, t.models) : '');
function runSeries(vals: (number | null | undefined)[], fmt: (v: number) => string): { labels: string[]; markers: boolean[] } {
  // vals is the RAW per-run series (may hold nulls) ; the filtered series
  // used for the path skips nulls, so build labels/markers on the same filter.
  const labels: string[] = [];
  const markers: boolean[] = [];
  vals.forEach((v, i) => {
    if (v != null) {
      labels.push(`${runDates[i] || ''} : ${fmt(v)}${eraNotes[i] ? '\n' + eraNotes[i] : ''}`);
      markers.push(!!trendFromApi[i]?.model_changed);
    }
  });
  return { labels, markers };
}
const mentionSeries = runSeries(trendFromApi.map((t: any) => t.citation_rate), v => `${v}%`);
const sentimentSeries = runSeries(trendFromApi.map((t: any) => t.sentiment_score), v => (v > 0 ? '+' : '') + v.toFixed(2));
const sovSeries = runSeries(trendFromApi.map((t: any) => t.sov), v => `${v}%`);
const mentionLabels = mentionSeries.labels;
const sentimentLabels = sentimentSeries.labels;
const sovLabels = sovSeries.labels;

const mentionTone: 'up' | 'down' | 'flat' = delta == null ? 'flat' : delta > 0 ? 'up' : delta < 0 ? 'down' : 'flat';
---

<ScanResultsLayout scanId={scanId} activeTab="overview" mobileReady headerPromise={headerPromise}>
  <style is:global>
    /* Overview-local layout - page-specific grids + bar primitives.
       Reused vocabulary from the design (.ovl .grid-12 col-* .panel
       .prov .crow .qrow .actrow .bignum) so the design ref is the
       canonical reading. */
    .ovl { display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:16px; margin-bottom:16px; }
    .ovl .stat { padding:16px 18px; }
    .ovl .stat__row { margin-top:8px; }
    .ovl .stat__value { font-size:28px; line-height:1; }
    .ovl .spark { margin-top:10px; height:34px; }
    .ovl .spark--empty { display:flex; align-items:center; font-size:11px; color:var(--color-text-muted); font-style:italic; }

    .grid-12 { display:grid; grid-template-columns:repeat(12,1fr); gap:16px; }
    .col-3 { grid-column:span 3; } .col-4 { grid-column:span 4; }
    .col-5 { grid-column:span 5; } .col-7 { grid-column:span 7; }

    .panel { background:var(--color-surface); border:1px solid var(--color-border); border-radius:var(--radius-lg); box-shadow:var(--shadow-xs); }
    .panel__head { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid var(--color-border); }
    .panel__title { font-size:14px; font-weight:650; }
    .panel__act { font-size:12px; font-weight:600; color:var(--coral-700); text-decoration:none; }
    .panel__act:hover { color:var(--coral-800); }
    .panel__body { padding:18px; }

    /* provider citation bars */
    .prov { display:flex; flex-direction:column; gap:14px; }
    .prov__row { display:grid; grid-template-columns:104px 1fr 42px; align-items:center; gap:12px; }
    .prov__name { font-size:13px; font-weight:600; display:flex; align-items:center; gap:7px; }
    .prov__ic { width:18px; height:18px; border-radius:5px; display:grid; place-items:center; color:#fff; font-size:10px; font-weight:700; flex:none; }
    .prov__track { height:8px; background:var(--color-surface-muted); border-radius:var(--radius-full); overflow:hidden; }
    .prov__fill { height:100%; border-radius:var(--radius-full); }
    .prov__val { font-size:13px; font-weight:700; text-align:right; }

    /* share-of-voice rows */
    .clist { display:flex; flex-direction:column; }
    .crow { display:flex; align-items:center; gap:10px; padding:10px 0; border-bottom:1px solid var(--color-border); }
    .crow:last-child { border-bottom:0; }
    .crow__rank { width:18px; font-size:13px; font-weight:700; color:var(--color-text-muted); }
    .crow__name { font-size:13.5px; font-weight:600; flex:1; min-width:0; }
    .crow__name.you { color:var(--coral-700); }
    .crow__bar { width:90px; height:7px; background:var(--color-surface-muted); border-radius:var(--radius-full); overflow:hidden; }
    .crow__fill { height:100%; background:var(--color-text-secondary); border-radius:var(--radius-full); }
    .crow__fill.you { background:var(--color-primary); }
    .crow__val { width:34px; text-align:right; font-size:12.5px; font-weight:700; }

    /* questions list */
    .qlist { display:flex; flex-direction:column; }
    .qrow { display:flex; align-items:center; gap:12px; padding:11px 0; border-bottom:1px solid var(--color-border); }
    .qrow:last-child { border-bottom:0; }
    .qrow__q { font-size:13.5px; color:var(--color-text-primary); flex:1; line-height:1.4; }
    .qrow__cited { font-size:12px; font-weight:600; color:var(--color-text-secondary); white-space:nowrap; }

    /* activity list */
    .actlist { display:flex; flex-direction:column; }
    .actrow { display:flex; gap:11px; padding:11px 0; border-bottom:1px solid var(--color-border); align-items:flex-start; }
    .actrow:last-child { border-bottom:0; }
    .actrow__dot { width:8px; height:8px; border-radius:50%; margin-top:6px; flex:none; }
    .actrow__dot.positive { background:var(--status-positive); }
    .actrow__dot.critical { background:var(--status-critical); }
    .actrow__dot.warning  { background:var(--sev-medium); }
    .actrow__dot.info     { background:var(--status-info); }
    .actrow__dot.neutral  { background:var(--color-text-muted); }
    .actrow__t { font-size:13px; color:var(--color-text-primary); line-height:1.4; }
    .actrow__time { font-size:11.5px; color:var(--color-text-muted); margin-top:1px; }

    .bignum { display:flex; align-items:baseline; gap:8px; }
    .bignum b { font-size:26px; font-weight:730; letter-spacing:-.02em; }

    /* recommendation funnel (KPI tile 2) */
    .fun { display:flex; flex-direction:column; gap:9px; }
    .fun__row { display:grid; grid-template-columns:86px 1fr 34px; align-items:center; gap:8px; cursor:help; }
    .fun__label { font-size:11.5px; font-weight:600; color:var(--color-text-secondary); }
    .fun__track { height:6px; background:var(--color-surface-muted); border-radius:var(--radius-full); overflow:hidden; }
    .fun__fill { display:block; height:100%; background:var(--color-text-secondary); border-radius:var(--radius-full); }
    .fun__val { font-size:12px; font-weight:700; text-align:right; }

    /* brand rank histogram (Panel C) */
    .poslist { display:flex; flex-direction:column; gap:11px; }
    .pos__row { display:grid; grid-template-columns:80px 1fr 32px 34px; align-items:center; gap:8px; }
    .pos__label { font-size:12px; font-weight:600; color:var(--color-text-secondary); }
    .pos__track { height:7px; background:var(--color-surface-muted); border-radius:var(--radius-full); overflow:hidden; }
    .pos__fill { display:block; height:100%; background:var(--color-text-secondary); border-radius:var(--radius-full); }
    .pos__fill--absent { background:var(--status-critical); opacity:.45; }
    .pos__val { font-size:12px; font-weight:700; text-align:right; }
    .pos__delta { font-size:10.5px; font-weight:700; text-align:right; }
    .pos__delta--good { color:var(--status-positive); }
    .pos__delta--bad { color:var(--status-critical); }

    /* gap rows are links */
    a.qrow { text-decoration:none; color:inherit; }
    a.qrow:hover .qrow__q { color:var(--coral-700); }

    /* battlefield heatmap : topics x brands */
    .heat { width:100%; border-collapse:separate; border-spacing:3px; }
    .heat th { font-size:11px; font-weight:650; color:var(--color-text-secondary); text-align:center; padding:0 4px 4px; }
    .heat th.heat__you { color:var(--coral-700); }
    .heat th.heat__topic { text-align:left; font-weight:600; }
    .heat td.heat__topic { font-size:12.5px; font-weight:600; color:var(--color-text-primary); white-space:nowrap; max-width:190px; overflow:hidden; text-overflow:ellipsis; padding-right:6px; }
    .heat td.heat__cell { text-align:center; font-size:12px; font-weight:700; border-radius:var(--radius-sm); padding:7px 4px; min-width:52px; }
    .heat tr td.heat__topic a { color:inherit; text-decoration:none; }
    .heat tr:hover td.heat__topic a { color:var(--coral-700); }
    .heat__wrap { overflow-x:auto; }

    /* fan-out query chips */
    .fanout { display:flex; flex-wrap:wrap; gap:7px; }
    .fanout__q { font-size:12px; padding:5px 10px; border-radius:var(--radius-full); border:1px solid var(--color-border); color:var(--color-text-secondary); background:var(--color-surface); }
    .fanout__q b { color:var(--color-text-primary); font-weight:700; }

    /* verbatim quote cards */
    .quotes { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
    .quote { border:1px solid var(--color-border); border-radius:var(--radius-md); padding:14px 16px; text-decoration:none; color:inherit; display:flex; flex-direction:column; gap:8px; transition:box-shadow .2s ease; }
    .quote:hover { box-shadow:var(--shadow-sm); }
    .quote__text { font-size:13px; line-height:1.55; color:var(--color-text-primary); }
    .quote__why { font-size:11.5px; color:var(--color-text-muted); font-style:italic; line-height:1.45; }
    .quote__meta { display:flex; align-items:center; gap:8px; margin-top:auto; }
    @media (max-width: 1024px) { .quotes { grid-template-columns:1fr; } }

    @media (max-width: 1024px) {
      .ovl { grid-template-columns:1fr 1fr; }
      .col-3, .col-4, .col-5, .col-7 { grid-column:span 12; }
    }
    /* Mobile P3 - phone pass. The page is the scan-complete email's
       deep-link target : tiles tighten, gaps shrink, nothing hidden. */
    @media (max-width: 639px) {
      .ovl { gap:10px; }
      .ovl .stat { padding:13px 14px; }
      .ovl .stat__value { font-size:24px; }
      .grid-12 { gap:12px; }
      .prov__row { grid-template-columns:84px 1fr 38px; gap:8px; }
    }
  </style>

  {o ? (
    <>
      {/* CIRCUIT BREAKER NOTICE (only on degraded runs) */}
      {(trippedProviders.length > 0 || refundInfo) && (
        <div class="panel" style="border-left:3px solid var(--sev-medium);margin-bottom:16px">
          <div class="panel__body" style="display:flex;align-items:flex-start;gap:12px;padding:14px 18px">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="var(--sev-medium)" stroke-width="1.7" style="flex:none;margin-top:1px"><path d="M8 1l7 13H1z"/><path d="M8 6v3.5M8 11.5v.1"/></svg>
            <div style="font-size:13px">
              <p style="font-weight:650;color:var(--color-text-primary)">Partial scan completion</p>
              <p style="color:var(--color-text-secondary);font-size:12.5px;margin-top:3px">
                {trippedProviders.length > 0 && (
                  <span>AI{trippedProviders.length > 1 ? 's' : ''} <b style="color:var(--color-text-primary)">{trippedProviders.join(', ')}</b> failed mid-scan and were stopped.</span>
                )}
                {refundInfo && (
                  <span>{trippedProviders.length > 0 ? ' ' : ''}{refundInfo.amount} credit{refundInfo.amount > 1 ? 's' : ''} refunded for undelivered runs.</span>
                )}
              </p>
            </div>
          </div>
        </div>
      )}

      {/* ADVISED-AGAINST ALERT (only when an AI steers users away from the brand) */}
      {avoidRows.length > 0 && (
        <div class="panel" style="border-left:3px solid var(--status-critical);margin-bottom:16px">
          <div class="panel__body" style="padding:14px 18px">
            <p style="font-size:13.5px;font-weight:650;color:var(--status-critical)">
              {avoidRows.length === 1 ? 'An AI advises against your brand in one answer' : `AIs advise against your brand in ${avoidRows.length} answers`}
            </p>
            <p style="font-size:12.5px;color:var(--color-text-secondary);margin-top:4px;line-height:1.5">
              "{avoidRows[0].quote}"{avoidRows[0].why ? <span style="color:var(--color-text-muted)"> - {avoidRows[0].why}</span> : null}
            </p>
            <a class="panel__act" style="display:inline-block;margin-top:6px" href={`/app/scans/${scanId}/questions?q=${encodeURIComponent(avoidRows[0].question)}`}>Read the full answer</a>
          </div>
        </div>
      )}

      {/* EDITORIAL HERO - the scan's own narrative (hook + interpretation),
          generated at completion and previously never rendered anywhere. */}
      {editorial?.hook && (
        <div class="panel" style="margin-bottom:16px">
          <div class="panel__body" style="padding:16px 20px">
            <div style="font-size:11px;font-weight:650;letter-spacing:.06em;text-transform:uppercase;color:var(--color-text-muted)">What this scan says</div>
            <h2 style="font-size:17px;font-weight:680;letter-spacing:-.015em;margin-top:6px;line-height:1.35">{editorial.hook}</h2>
            {editorial.interpretation && (
              <p style="font-size:13px;color:var(--color-text-secondary);margin-top:6px;line-height:1.55;max-width:78ch">{editorial.interpretation}</p>
            )}
          </div>
        </div>
      )}

      {/* ─── KPI ROW (4 tiles, design ref §ovl) ───
          Each tile carries a per-run sparkline when the scan has a
          lineage (>= 2 runs). Single-run scans show a Goal-Gradient
          hint instead : the user knows exactly what unlocks the trend. */}
      <div class="ovl">
        <div class="card card--flat stat">
          <div class="stat__label">Mention rate</div>
          <div class="stat__row">
            <div class="stat__value">{currentRate}%</div>
            {delta != null && (
              <span class={`stat__delta ${delta > 0 ? 'stat__delta--up' : delta < 0 ? 'stat__delta--down' : 'stat__delta--flat'}`}>
                {delta > 0 ? '↑' : delta < 0 ? '↓' : '·'} {delta === 0 ? 'flat' : Math.abs(delta).toFixed(1)}
              </span>
            )}
            {eraChipLabel && (
              <span class="stat__delta stat__delta--flat" style="cursor:help" title={eraChipTitle}>
                ⟳ {eraChipLabel}
              </span>
            )}
          </div>
          {marginPts !== null && (
            <div style="margin-top:4px;font-size:11px;color:var(--color-text-muted)" title={`95% confidence interval over ${totalTests} samples (${runsDepth} runs per question). AI answers vary between identical runs - the margin shows how solid this rate is.`}>
              ± {marginPts} pts · {runsDepth} runs per question
            </div>
          )}
          {mentionRateTrend.length > 1
            ? <div class="spark" set:html={sparkSvg(mentionRateTrend, mentionTone, mentionLabels, 120, 34, mentionSeries.markers)} />
            : <div class="spark spark--empty">Trend appears after your next rescan</div>}
        </div>

        <div class="card card--flat stat">
          <div class="stat__label">Recommendation funnel</div>
          <div class="fun" style="margin-top:10px">
            {funnelRows.map(f => (
              <div class="fun__row" title={f.title}>
                <span class="fun__label">{f.label}</span>
                <span class="fun__track"><span class="fun__fill" style={`width:${funPct(f.n)}%`}></span></span>
                <span class="fun__val">{funPct(f.n)}%</span>
              </div>
            ))}
          </div>
          <div style="margin-top:9px;font-size:11px;color:var(--color-text-muted)">of {answersTotal.toLocaleString('en-US')} answer{answersTotal > 1 ? 's' : ''} on the latest run</div>
        </div>

        <div class="card card--flat stat">
          <div class="stat__label">Avg. sentiment</div>
          <div class="stat__row">
            <div class="stat__value" style={sentScore < 0 ? 'color:var(--status-critical)' : ''}>
              {sentScore === 0 && sentTotal === 0 ? '-' : (sentScore > 0 ? '+' : '') + sentScore.toFixed(2)}
            </div>
            <span class="stat__delta stat__delta--flat">{sentTotal} mention{sentTotal > 1 ? 's' : ''}</span>
          </div>
          {sentimentTrend.length > 1
            ? <div class="spark" set:html={sparkSvg(sentimentTrend, trendTone(sentimentTrend), sentimentLabels, 120, 34, sentimentSeries.markers)} />
            : sentTotal > 0 && (
              <span class="sentiment" style="margin-top:10px;align-self:flex-start">
                {sentPos > 0 && <span class="pos">▲ {sentPos}</span>}
                {sentNeu > 0 && <span class="neu">{sentNeu}</span>}
                {sentNeg > 0 && <span class="neg">▼ {sentNeg}</span>}
              </span>
            )}
        </div>

        <div class="card card--flat stat">
          <div class="stat__label">Share of voice</div>
          <div class="stat__row">
            <div class="stat__value">{sovPct}%</div>
            <span class="stat__delta stat__delta--flat">vs {competitors.length} competitor{competitors.length > 1 ? 's' : ''}</span>
          </div>
          {sovTrend.length > 1
            ? <div class="spark" set:html={sparkSvg(sovTrend, trendTone(sovTrend), sovLabels, 120, 34, sovSeries.markers)} />
            : <div style="font-size:11.5px;color:var(--color-text-muted);margin-top:10px">{myMentions} mention{myMentions > 1 ? 's' : ''} for this brand, {competitorMentions} for competitors</div>}
        </div>
      </div>

      {/* ─── MAIN 5-PANEL GRID ─── */}
      <div class="grid-12">

        {/* Panel A : Mention rate by AI */}
        <div class="panel col-5">
          <div class="panel__head">
            <div class="panel__title" style="cursor:help" title="Share of each AI's answers that name your brand. Citations (the sources an AI links to) live on the Citations tab.">Mention rate by AI</div>
            <a class="panel__act" href={`/app/scans/${scanId}/questions`}>Details</a>
          </div>
          <div class="panel__body">
            {providerBars.length === 0 ? (
              <p style="font-size:13px;color:var(--color-text-muted)">No provider data yet.</p>
            ) : (
              <div class="prov">
                {providerBars.map(b => {
                  const v = provVis(b.prov);
                  const fillColour = b.rate >= 50 ? 'var(--status-positive)' : b.rate >= 30 ? 'var(--sev-low)' : b.rate >= 15 ? 'var(--sev-medium)' : 'var(--sev-high)';
                  return (
                    <div class="prov__row">
                      <div class="prov__name"><span class="prov__ic" style={`background:${v.bg}`}>{v.ab}</span>{v.label}</div>
                      <div class="prov__track"><div class="prov__fill" style={`width:${b.rate}%;background:${fillColour}`}></div></div>
                      <div class="prov__val">{b.rate}%</div>
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        </div>

        {/* Panel B : Share of voice */}
        <div class="panel col-4">
          <div class="panel__head">
            <div class="panel__title">Share of voice</div>
            <a class="panel__act" href={`/app/scans/${scanId}/competitors`}>Competitors</a>
          </div>
          <div class="panel__body">
            {sovItemsRaw.length === 0 ? (
              <p style="font-size:13px;color:var(--color-text-muted)">No competitor data yet.</p>
            ) : (
              <div class="clist">
                {sovItemsRaw.map((row, i) => {
                  const pct = Math.round((row.mentions / sovMax) * 100);
                  return (
                    <div class="crow">
                      <span class="crow__rank">{i + 1}</span>
                      <span class={`crow__name ${row.you ? 'you' : ''}`}>{row.name}</span>
                      <span class="crow__bar"><span class={`crow__fill ${row.you ? 'you' : ''}`} style={`width:${pct}%`}></span></span>
                      <span class="crow__val">{row.mentions}</span>
                    </div>
                  );
                })}
              </div>
            )}
            {editorial?.competitor_insight && (
              <p style="margin-top:12px;padding-top:10px;border-top:1px solid var(--color-border);font-size:12px;color:var(--color-text-secondary);font-style:italic;line-height:1.5">{editorial.competitor_insight}</p>
            )}
          </div>
        </div>

        {/* Panel C : Brand rank in answers. Replaces the old Sentiment panel,
            which duplicated KPI tile 3 verbatim on the same screen. */}
        <div class="panel col-3">
          <div class="panel__head">
            <div class="panel__title" style="cursor:help" title="Where your brand ranks among the brands each AI names in its answer, on the latest run. Deltas compare to the previous run, in percentage points.">Brand rank in answers</div>
          </div>
          <div class="panel__body">
            {(!posDist || posTotal === 0) ? (
              <p style="font-size:13px;color:var(--color-text-muted)">Rank data appears once the scan analysis completes.</p>
            ) : (
              <div class="poslist">
                {POS_BUCKETS.map(([k, label]) => {
                  const n = posDist[k] || 0;
                  const pct = Math.round((n / posTotal) * 100);
                  const d = posDelta ? (posDelta[k] ?? null) : null;
                  const good = k === 'not_cited' ? (d != null && d < 0) : (d != null && d > 0);
                  return (
                    <div class="pos__row" title={`${n} answer${n > 1 ? 's' : ''}`}>
                      <span class="pos__label">{label}</span>
                      <span class="pos__track"><span class={`pos__fill ${k === 'not_cited' ? 'pos__fill--absent' : ''}`} style={`width:${pct}%`}></span></span>
                      <span class="pos__val">{pct}%</span>
                      <span class={`pos__delta ${d != null && d !== 0 ? (good ? 'pos__delta--good' : 'pos__delta--bad') : ''}`} title={d != null && d !== 0 ? 'Change vs previous run, percentage points' : ''}>
                        {d != null && d !== 0 ? `${d > 0 ? '+' : ''}${d}` : ''}
                      </span>
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        </div>

        {/* Panel D : questions competitors own (nominal steals), falling back
            to the weakest-first list when no classified competitor took a
            question. Every row deep-links to the full answer (?q= prefill). */}
        <div class="panel col-7">
          <div class="panel__head">
            {gapRows.length > 0 ? (
              <div class="panel__title">Competitors own these questions <span style="color:var(--color-text-muted);font-weight:500;font-size:12.5px"> - they are cited, you are absent</span></div>
            ) : (
              <div class="panel__title">Top buyer questions <span style="color:var(--color-text-muted);font-weight:500;font-size:12.5px"> - weakest first</span></div>
            )}
            <a class="panel__act" href={`/app/scans/${scanId}/questions`}>All questions</a>
          </div>
          <div class="panel__body">
            {gapRows.length > 0 ? (
              <div class="qlist">
                {gapRows.map(g => (
                  <a class="qrow" href={`/app/scans/${scanId}/questions?q=${encodeURIComponent(g.question)}`}>
                    <span class="chip chip--sm chip--warning" style="flex:none;font-weight:650" title={g.othersCount > 0 ? `Cited on this question with ${g.othersCount} other competitor${g.othersCount > 1 ? 's' : ''} - your brand is absent` : 'Cited on this question - your brand is absent'}>{g.topComp}{g.othersCount > 0 ? ` +${g.othersCount}` : ''}</span>
                    <span class="qrow__q">{g.question}</span>
                    <span class="qrow__cited">{g.compMentions} competitor mention{g.compMentions > 1 ? 's' : ''}</span>
                  </a>
                ))}
              </div>
            ) : topQuestions.length === 0 ? (
              <p style="font-size:13px;color:var(--color-text-muted)">No questions in this scan yet.</p>
            ) : (
              <div class="qlist">
                {topQuestions.map(q => {
                  const s = qStatus(q.rate);
                  return (
                    <a class="qrow" href={`/app/scans/${scanId}/questions?q=${encodeURIComponent(q.question)}`}>
                      <span class={`sev sev--${s.sev}`} style="padding:3px 9px"><span class="sev__dot"></span>{s.label}</span>
                      <span class="qrow__q">{q.question}</span>
                      <span class="qrow__cited">{q.mention_count} / {q.total_runs}{q.unit ? ` ${q.unit}` : ''}</span>
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        </div>

        {/* Panel E : Recent activity */}
        <div class="panel col-5">
          <div class="panel__head"><div class="panel__title">Recent activity</div></div>
          <div class="panel__body">
            {activity.length === 0 ? (
              <p style="font-size:13px;color:var(--color-text-muted)">No recent activity to surface yet.</p>
            ) : (
              <div class="actlist">
                {activity.map(a => (
                  <div class="actrow">
                    <span class={`actrow__dot ${a.tone}`}></span>
                    <div>
                      <div class="actrow__t">{a.text}</div>
                      {a.time && <div class="actrow__time">{a.time}</div>}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>

      {/* ─── BATTLEFIELD MAP : which territories you hold, which a rival holds.
          The single view that a global share-of-voice number cannot give. */}
      {heatRows.length > 0 && heatColumns.length > 1 && (
        <div class="panel" style="margin-top:16px">
          <div class="panel__head">
            <div class="panel__title" style="cursor:help" title="Share of brand mentions per topic, on the latest run. Only your brand and classified competitors are counted - cited sources are excluded.">
              Who owns each topic <span style="color:var(--color-text-muted);font-weight:500;font-size:12.5px"> - your weakest territories first</span>
            </div>
            <a class="panel__act" href={`/app/scans/${scanId}/topics`}>All topics</a>
          </div>
          <div class="panel__body">
            <div class="heat__wrap">
              <table class="heat">
                <thead>
                  <tr>
                    <th class="heat__topic">Topic</th>
                    {heatColumns.map(c => (
                      <th class={c.you ? 'heat__you' : ''}>{c.label}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {heatRows.map(row => (
                    <tr>
                      <td class="heat__topic" title={`${row.topic} - ${row.answers} answer${row.answers > 1 ? 's' : ''} on the latest run`}>
                        <a href={`/app/scans/${scanId}/topics`}>{row.topic}</a>
                      </td>
                      {row.cells.map((cell, ci) => (
                        <td class="heat__cell" style={heatStyle(cell.pct, heatColumns[ci].you)}
                            title={`${heatColumns[ci].label} on ${row.topic} : ${cell.pct}% of brand mentions (${cell.n})`}>
                          {cell.pct > 0 ? `${cell.pct}%` : '-'}
                        </td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}

      {/* ─── VERBATIMS : the AI's own words about the brand. The proof layer
          that makes the KPIs believable - previously buried 2-3 clicks deep
          in the Questions tab expansions. */}
      {quotes.length > 0 && (
        <div class="panel" style="margin-top:16px">
          <div class="panel__head">
            <div class="panel__title">What the AIs say about your brand</div>
            <a class="panel__act" href={`/app/scans/${scanId}/questions`}>All answers</a>
          </div>
          <div class="panel__body">
            <div class="quotes">
              {quotes.map(q => {
                const v = provVis(q.provider);
                const tone = isPosQ(q) ? 'positive' : isNegQ(q) ? 'critical' : 'neutral';
                const recoLabel = q.reco === 'premiere_option' ? 'first choice'
                  : q.reco === 'a_eviter' ? 'advised against'
                  : q.reco === 'alternative' ? 'alternative'
                  : tone === 'positive' ? 'positive' : tone === 'critical' ? 'negative' : 'neutral';
                return (
                  <a class="quote" href={`/app/scans/${scanId}/questions?q=${encodeURIComponent(q.question)}`} title="Read the full AI answer">
                    <p class="quote__text">"{q.text}"</p>
                    {q.why && <p class="quote__why">{q.why}</p>}
                    <div class="quote__meta">
                      <span class="prov__ic" style={`background:${v.bg}`}>{v.ab}</span>
                      <span class={`chip chip--sm ${tone === 'positive' ? 'chip--positive' : tone === 'critical' ? 'chip--critical' : 'chip--neutral'}`}>{recoLabel}</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {/* ─── SECONDARY : Top Opportunities (kept - the page's primary CTA) ─── */}
      {topActions.length > 0 && (
        <div style="margin-top:24px">
          <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:14px">
            <h2 style="font-size:16px;font-weight:680;letter-spacing:-.015em">Top opportunities</h2>
            <a class="panel__act" href={`/app/scans/${scanId}/actions`}>View all {oppQuestionCount} question{oppQuestionCount === 1 ? '' : 's'}</a>
          </div>
          <div style="display:flex;flex-direction:column;gap:10px">
            {topActions.map((opp: any) => {
              const isCrit = opp.priority === 'critique';
              const isHigh = opp.priority === 'haute';
              const accent = isCrit ? 'var(--status-critical)' : isHigh ? 'var(--sev-high)' : 'var(--sev-medium)';
              const sev = isCrit ? 'critical' : isHigh ? 'high' : 'medium';
              return (
                <a href={`/app/scans/${scanId}/actions`} class="panel" style={`display:flex;align-items:flex-start;gap:14px;padding:14px 18px;border-left:3px solid ${accent};text-decoration:none;color:inherit`}>
                  <span class={`sev sev--${sev}`}><span class="sev__dot"></span>{opp.priority}</span>
                  <div style="flex:1;min-width:0">
                    <p style="font-size:14px;color:var(--color-text-primary)">{opp.question || 'Question not available'}</p>
                    <div style="display:flex;gap:10px;margin-top:5px;font-size:11.5px;color:var(--color-text-muted)">
                      {opp.persona_name && <span>{opp.persona_name}</span>}
                      {opp.topic_name && <span>· {opp.topic_name}</span>}
                    </div>
                  </div>
                  {opp.recommended_action && (
                    <span class="chip chip--sm chip--neutral" style="text-transform:capitalize">
                      {opp.recommended_action === 'faq' ? 'Create FAQ' : opp.recommended_action === 'netlinking' ? 'Netlinking' : opp.recommended_action}
                    </span>
                  )}
                </a>
              );
            })}
          </div>
          {actionableCount > 0 && (
            <div style="background:var(--color-primary-subtle);border-radius:var(--radius-lg);padding:16px 20px;display:flex;align-items:center;justify-content:space-between;margin-top:14px">
              <div>
                <p style="font-size:14px;font-weight:650;color:var(--color-text-primary)">
                  {actionableCount} content gap{actionableCount === 1 ? '' : 's'} identified by this scan
                </p>
                <p style="font-size:12.5px;color:var(--color-text-secondary);margin-top:2px">Generate FAQs and articles so the AIs cite your brand where competitors are cited today.</p>
              </div>
              <a class="btn btn--primary btn--md" href={`/app/scans/${scanId}/actions`}>Open Actions</a>
            </div>
          )}
        </div>
      )}
    </>
  ) : (
    <div class="empty" style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);box-shadow:var(--shadow-xs);padding:64px 24px">
      <div class="empty__art"><span>0 / 0</span></div>
      <div class="empty__title">No results yet</div>
      <div class="empty__body">The scan is running or has not been launched. Check the scan status to see where it's at.</div>
      <a class="btn btn--primary btn--md" href={`/app/scans/${scanId}`}>Check scan status</a>
    </div>
  )}
</ScanResultsLayout>
