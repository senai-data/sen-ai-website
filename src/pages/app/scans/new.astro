---
/**
 * New scan - redesign per 07-create-scan.html.
 *
 * One real step lives on this page (the domain form) ; everything after
 * (topics, brands, personas, launch) happens on the scan pipeline page,
 * so the steps bar shows the TRUE pipeline with step 1 active instead of
 * the ref's self-contained 4-step demo. Right rail = live scan summary
 * (.summary pattern) fed by Alpine state.
 *
 * UX Laws :
 *  - Zeigarnik : steps bar shows the journey ahead
 *  - Hick's Law : 3 depth presets, advanced options collapsed
 *  - Goal-Gradient : step 1 of 5 already lit
 *  - Doherty : loading state on the CTA, summary updates as you type
 */
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import Tip from '../../../components/Tip.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

// Get client ID
let clientId = null;
try {
  const activeOrgCookie = Astro.cookies.get('active_organization_id')?.value;
  const activeClientCookie = Astro.cookies.get('active_client_id')?.value;
  const upstreamCookie = [
    `token=${token}`,
    activeOrgCookie ? `active_organization_id=${activeOrgCookie}` : null,
    activeClientCookie ? `active_client_id=${activeClientCookie}` : null,
  ].filter(Boolean).join('; ');
  const res = await fetch('http://api:8000/api/clients/', {
    headers: { Cookie: upstreamCookie },
  });
  const clients = res.ok ? await res.json() : [];
  clientId = clients[0]?.id;
} catch {}

const COUNTRIES = [
  ['fr', 'France'], ['us', 'United States'], ['uk', 'United Kingdom'],
  ['de', 'Germany'], ['es', 'Spain'], ['it', 'Italy'], ['nl', 'Netherlands'],
  ['be', 'Belgium'], ['ch', 'Switzerland'], ['ca', 'Canada'],
];
---

<DashboardLayout title="New scan" activeSection="scan-new">
  <style is:global>
    /* Page-local vocabulary from 07-create-scan.html (.wrap .whead .wgrid
       .stepsbar .stepcard .wnav .summary .cost .optcard). Steps / field /
       input primitives come from components.css. */
    .nsw { padding: var(--space-7) var(--space-6) var(--space-9); max-width: 1080px; margin: 0 auto; }
    .nsw .whead { margin-bottom: var(--space-6); }
    .nsw .whead h1 { font-size: 26px; font-weight: 700; letter-spacing: -.025em; color: var(--color-text-primary); }
    .nsw .whead p { font-size: 14px; color: var(--color-text-secondary); margin-top: 5px; max-width: 68ch; }

    .nsw .stepsbar { display: flex; align-items: center; margin-bottom: var(--space-5); padding: 16px 20px; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-xs); overflow-x: auto; }
    .nsw .stepsbar .steps__line { flex: 1; width: auto; }

    .nsw .wgrid { display: grid; grid-template-columns: 1fr 296px; gap: 24px; align-items: start; }
    @media (max-width: 899px) { .nsw .wgrid { grid-template-columns: 1fr; } }

    .nsw .stepcard { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-xs); padding: var(--space-6); }
    .nsw .stepcard__title { font-size: 18px; font-weight: 680; letter-spacing: -.015em; color: var(--color-text-primary); }
    .nsw .stepcard__desc { font-size: 13.5px; color: var(--color-text-secondary); margin-top: 5px; margin-bottom: var(--space-5); max-width: 62ch; }
    .nsw .form2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .nsw .span2 { grid-column: 1 / -1; }
    @media (max-width: 639px) { .nsw .form2 { grid-template-columns: 1fr; } .nsw .span2 { grid-column: auto; } }

    /* selectable option cards (scan type + depth) - .schedopt pattern */
    .nsw .optrow { display: flex; gap: 10px; }
    .nsw .optcard { flex: 1; padding: 13px 15px; border: 1.5px solid var(--color-border); border-radius: var(--radius-md); cursor: pointer; transition: .12s; background: var(--color-surface); text-align: left; font-family: var(--font-sans); }
    .nsw .optcard:hover { border-color: var(--color-border-strong); }
    .nsw .optcard.on { border-color: var(--color-primary); background: var(--color-primary-subtle); }
    .nsw .optcard__name { font-size: 13.5px; font-weight: 650; display: flex; align-items: center; gap: 8px; color: var(--color-text-primary); }
    .nsw .optcard__meta { font-size: 11.5px; color: var(--color-text-muted); margin-top: 3px; }
    .nsw .optcard__radio { width: 15px; height: 15px; border-radius: 50%; border: 1.5px solid var(--color-border-strong); display: inline-grid; place-items: center; flex: none; }
    .nsw .optcard.on .optcard__radio { border-color: var(--color-primary); }
    .nsw .optcard.on .optcard__radio::after { content: ""; width: 7px; height: 7px; border-radius: 50%; background: var(--color-primary); }

    .nsw .adv summary { font-size: 13px; color: var(--color-text-muted); cursor: pointer; }
    .nsw .adv summary:hover { color: var(--color-text-primary); }
    .nsw .adv[open] summary { margin-bottom: 14px; }
    .nsw .adv__body { display: flex; flex-direction: column; gap: 14px; padding-left: 14px; border-left: 2px solid var(--color-border); }

    .nsw .wnav { display: flex; align-items: center; justify-content: flex-end; gap: 16px; margin-top: var(--space-5); }
    .nsw .wnav__hint { font-size: 12.5px; color: var(--color-text-muted); }

    .nsw .summary { position: sticky; top: var(--space-6); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
    .nsw .summary__head { padding: 16px 18px; border-bottom: 1px solid var(--color-border); font-size: 14px; font-weight: 680; color: var(--color-text-primary); }
    .nsw .summary__body { padding: 18px; display: flex; flex-direction: column; gap: 14px; }
    .nsw .srow { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; font-size: 13px; }
    .nsw .srow__k { color: var(--color-text-muted); }
    .nsw .srow__v { font-weight: 600; text-align: right; color: var(--color-text-primary); overflow-wrap: anywhere; }
    .nsw .srow__v.muted { color: var(--color-text-muted); font-weight: 500; font-style: italic; }
    .nsw .cost { background: var(--color-surface-sunken); border-top: 1px solid var(--color-border); padding: 16px 18px; }
    .nsw .cost__l { font-size: 12.5px; font-weight: 650; color: var(--color-text-primary); }
    .nsw .cost__body { font-size: 12px; color: var(--color-text-secondary); margin-top: 6px; line-height: 1.5; }

    .nsw .errbox { margin-top: 16px; background: var(--status-critical-bg); border: 1px solid #FAD9D5; border-radius: var(--radius-md); padding: 12px 14px; font-size: 13px; color: var(--status-critical); }
  </style>

  <main class="nsw" x-data={`scanWizard('${clientId}')`}>
    <div class="whead">
      <h1>New scan</h1>
      <p>Tell us which site to analyze. We discover its topics, generate the questions real buyers ask, and measure how often each AI mentions the brand.</p>
    </div>

    {/* Steps bar - the TRUE pipeline. Only step 1 lives on this page ;
        the rest happens on the scan page after the redirect. */}
    <div class="stepsbar">
      <div class="steps" style="width:100%">
        <div class="steps__node is-active"><div class="steps__num">1</div><div class="steps__lbl">Domain</div></div>
        <div class="steps__line"></div>
        <div class="steps__node is-todo"><div class="steps__num">2</div><div class="steps__lbl">Topics</div></div>
        <div class="steps__line"></div>
        <div class="steps__node is-todo"><div class="steps__num">3</div><div class="steps__lbl">Brands</div></div>
        <div class="steps__line"></div>
        <div class="steps__node is-todo"><div class="steps__num">4</div><div class="steps__lbl">Personas</div></div>
        <div class="steps__line"></div>
        <div class="steps__node is-todo"><div class="steps__num">5</div><div class="steps__lbl">Launch</div></div>
      </div>
    </div>

    <div class="wgrid">
      {/* LEFT : the domain step */}
      <div>
        <div class="stepcard">
          <div class="stepcard__title">About the site</div>
          <div class="stepcard__desc">The domain you want to measure. We pull its Google rankings to map what buyers search for, then test those questions against the AIs.</div>

          <div class="form2">
            <div class="field span2">
              <label class="field__label">Scan name <span class="opt">- how you'll recognize it later</span></label>
              <input class="input" type="text" x-model="scanName" :placeholder="domain || 'e.g. Avène tracking Q2 2026'" />
              <span class="field__help">Defaults to the domain if left empty. Each scan tracks one brand over time via rescans.</span>
            </div>

            <div class="field span2">
              <label class="field__label"><Tip id="domain_input" position="bottom">Domain</Tip></label>
              <input class="input" type="text" x-model="domain" placeholder="e.g. eau-thermale-avene.fr" @keydown.enter="createScan()" />
              <span class="field__help">Used to detect when an AI cites the brand's own pages.</span>
            </div>

            <div class="field span2">
              <label class="field__label">This domain is</label>
              <div class="optrow">
                <button type="button" class="optcard" :class="scanType === 'own' ? 'on' : ''" @click="scanType = 'own'">
                  <div class="optcard__name"><span class="optcard__radio"></span>Your site</div>
                  <div class="optcard__meta">Track your own brand's AI visibility.</div>
                </button>
                <button type="button" class="optcard" :class="scanType === 'competitor' ? 'on' : ''" @click="scanType = 'competitor'">
                  <div class="optcard__name"><span class="optcard__radio"></span>Competitor site</div>
                  <div class="optcard__meta">Audit how a competitor shows up.</div>
                </button>
              </div>
            </div>

            <div class="field span2">
              <label class="field__label"><Tip id="country" position="bottom">Country</Tip></label>
              <select class="select" x-model="country">
                {COUNTRIES.map(([code, label]) => <option value={code}>{label}</option>)}
              </select>
              <span class="field__help">Where the buyers you care about are searching.</span>
            </div>

            <div class="field span2">
              <label class="field__label"><Tip id="analysis_depth" position="bottom">Analysis depth</Tip></label>
              <div class="optrow">
                <button type="button" class="optcard" :class="depth === 'light' ? 'on' : ''" @click="depth = 'light'">
                  <div class="optcard__name"><span class="optcard__radio"></span>Light</div>
                  <div class="optcard__meta">1 persona per topic</div>
                </button>
                <button type="button" class="optcard" :class="depth === 'balanced' ? 'on' : ''" @click="depth = 'balanced'">
                  <div class="optcard__name"><span class="optcard__radio"></span>Balanced</div>
                  <div class="optcard__meta">3 personas per topic</div>
                </button>
                <button type="button" class="optcard" :class="depth === 'deep' ? 'on' : ''" @click="depth = 'deep'">
                  <div class="optcard__name"><span class="optcard__radio"></span>Deep</div>
                  <div class="optcard__meta">6 personas per topic</div>
                </button>
              </div>
              <span class="field__help">Each persona generates 15 buyer questions. More personas means broader coverage and higher cost.</span>
            </div>

            <details class="adv span2">
              <summary>Advanced options</summary>
              <div class="adv__body">
                <div class="field">
                  <label class="field__label" style="font-size:12px"><Tip id="ranking_filter" position="bottom">Google ranking filter</Tip></label>
                  <div class="optrow" style="max-width:340px">
                    <button type="button" class="optcard" style="padding:9px 12px" :class="maxPosition === 10 ? 'on' : ''" @click="maxPosition = 10"><div class="optcard__name" style="font-size:12.5px">Top 10</div></button>
                    <button type="button" class="optcard" style="padding:9px 12px" :class="maxPosition === 30 ? 'on' : ''" @click="maxPosition = 30"><div class="optcard__name" style="font-size:12.5px">Top 30</div></button>
                    <button type="button" class="optcard" style="padding:9px 12px" :class="maxPosition === 50 ? 'on' : ''" @click="maxPosition = 50"><div class="optcard__name" style="font-size:12.5px">Top 50</div><div class="optcard__meta">recommended</div></button>
                  </div>
                </div>
                <div class="field" style="max-width:220px">
                  <label class="field__label" style="font-size:12px"><Tip id="max_keywords" position="bottom">Max keywords</Tip></label>
                  <input class="input" type="number" x-model.number="maxUrls" min="100" max="5000" />
                  <span class="field__help">Recommended : 2000.</span>
                </div>
              </div>
            </details>
          </div>
        </div>

        <div class="wnav">
          <span class="wnav__hint" x-show="!loading">Discovery takes about 1 to 2 minutes</span>
          {/* text + icons as DIRECT children of the inline-flex .btn -
              wrapper spans lose their inline display when x-show restores
              them, which dropped the arrow onto a second line. */}
          <button class="btn btn--primary btn--md" @click="createScan()" :disabled="!domain || loading">
            <span x-show="!loading">Analyze this site</span>
            <svg x-show="!loading" class="ic" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            <svg x-show="loading" x-cloak class="ic nsw-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" opacity=".25"/><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" opacity=".75"/></svg>
            <span x-show="loading" x-cloak>Analyzing...</span>
          </button>
        </div>

        <div class="errbox" x-show="error" x-cloak x-text="error"></div>
      </div>

      {/* RIGHT : live summary rail */}
      <div class="summary">
        <div class="summary__head">Scan summary</div>
        <div class="summary__body">
          <div class="srow"><span class="srow__k">Scan name</span><span class="srow__v" :class="(scanName || domain) ? '' : 'muted'" x-text="scanName || domain || 'Not set'"></span></div>
          <div class="srow"><span class="srow__k">Domain</span><span class="srow__v" :class="domain ? '' : 'muted'" x-text="domain || 'Not set'"></span></div>
          <div class="srow"><span class="srow__k">Type</span><span class="srow__v" x-text="scanType === 'own' ? 'Your site' : 'Competitor site'"></span></div>
          <div class="srow"><span class="srow__k">Country</span><span class="srow__v" x-text="countryLabel()"></span></div>
          <div class="srow"><span class="srow__k">Depth</span><span class="srow__v" x-text="depth === 'light' ? 'Light (1 persona/topic)' : depth === 'deep' ? 'Deep (6 personas/topic)' : 'Balanced (3 personas/topic)'"></span></div>
          <div class="srow"><span class="srow__k">Ranking filter</span><span class="srow__v" x-text="'Top ' + maxPosition"></span></div>
        </div>
        <div class="cost">
          <div class="cost__l">Cost</div>
          <div class="cost__body">
            Discovery (keywords + topics) is free. AI testing is charged per active topic when you launch it - you pick the topics first.
          </div>
        </div>
      </div>
    </div>
  </main>

  <style>
    .nsw-spin { animation: nswspin .7s linear infinite; }
    @keyframes nswspin { to { transform: rotate(360deg); } }
  </style>

  <script is:inline>
    document.addEventListener('alpine:init', () => {
      Alpine.data('scanWizard', (clientId) => ({
        domain: '',
        scanName: '',
        scanType: 'own',
        depth: 'balanced',
        country: 'fr',
        maxPosition: 50,
        maxUrls: 2000,
        loading: false,
        error: null,

        countryLabel() {
          const map = { fr: 'France', us: 'United States', uk: 'United Kingdom', de: 'Germany', es: 'Spain', it: 'Italy', nl: 'Netherlands', be: 'Belgium', ch: 'Switzerland', ca: 'Canada' };
          return map[this.country] || this.country;
        },

        async createScan() {
          if (!this.domain || this.loading) return;
          this.loading = true;
          this.error = null;
          try {
            const res = await fetch('/api/scans/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                client_id: clientId,
                domain: this.domain,
                name: (this.scanName || '').trim() || null,
                max_position: this.maxPosition,
                max_urls: this.maxUrls,
                target_domains: this.scanType === 'competitor' ? [] : [this.domain],
                scan_type: this.scanType === 'competitor' ? 'competitor_audit' : 'own_brand',
                config: {
                  country: this.country,
                  personas_per_topic: this.depth === 'light' ? 1 : this.depth === 'deep' ? 6 : 3,
                },
              }),
            });
            const rawText = await res.text();
            let scan;
            try {
              scan = JSON.parse(rawText);
            } catch (parseErr) {
              throw new Error('Unexpected response from the API');
            }
            if (!res.ok) throw new Error(scan.detail || 'Failed to create scan');

            // Domain brief generation runs in parallel with the keyword
            // fetch (~10s OpenAI web search) - fire and forget.
            fetch(`/api/scans/${scan.id}/generate-brief`, { method: 'POST' });
            await fetch(`/api/scans/${scan.id}/fetch-keywords`, { method: 'POST' });

            // The scan page owns every later pipeline state (processing
            // spinner, topics, brands, personas, launch).
            window.location.href = '/app/scans/' + scan.id;
            return;
          } catch (e) {
            this.error = e.message;
          }
          this.loading = false;
        },
      }));
    });
  </script>
</DashboardLayout>
