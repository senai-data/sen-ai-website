---
export const prerender = false;
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Forgot Password">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/">
          <img src="/logo-sen-ai-fr.png" alt="sen-ai.fr" class="h-10 mx-auto mb-4" />
        </a>
        <h1 class="text-2xl font-bold text-charcoal-dark">Reset your password</h1>
        <p class="text-charcoal-light mt-1">Enter your email and we'll send you a reset link.</p>
      </div>

      <div class="bg-white rounded-2xl shadow-lg p-8">

        <div id="form-section">
          <form id="forgot-form" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-charcoal mb-1">Email</label>
              <input
                type="email" id="email" name="email" required
                class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-coral/50 focus:border-coral"
                placeholder="you@company.com"
              />
            </div>
            <button
              type="submit"
              id="submit-btn"
              class="w-full py-3 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark transition-colors"
            >
              Send reset link
            </button>
          </form>
        </div>

        <div id="success-section" class="hidden text-center py-4">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-emerald-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <p class="text-sm text-charcoal-dark font-medium">Check your email</p>
          <p class="text-xs text-charcoal-light mt-1">If an account exists for that email, we've sent a reset link.</p>
        </div>

        <p class="text-center text-sm text-charcoal-light mt-6">
          <a href="/login" class="text-coral hover:text-coral-dark font-medium">&larr; Back to login</a>
        </p>
      </div>
    </div>
  </div>

  <script type="module">
    document.getElementById('forgot-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submit-btn');
      btn.disabled = true;
      btn.textContent = 'Sending...';

      try {
        await fetch('/api/auth/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: document.getElementById('email').value }),
        });
      } catch {}

      document.getElementById('form-section').classList.add('hidden');
      document.getElementById('success-section').classList.remove('hidden');
    });
  </script>
</AppLayout>
