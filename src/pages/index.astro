---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SolutionsIntro from '../components/SolutionsIntro.astro';
import AiScan from '../components/AiScan.astro';
import StoreImpact from '../components/StoreImpact.astro';
import Comparison from '../components/Comparison.astro';
import Engagement from '../components/Engagement.astro';
import Story from '../components/Story.astro';
import Footer from '../components/Footer.astro';
import WhatsApp from '../components/WhatsApp.astro';
---

<BaseLayout>
  <Nav />
  <main id="main-content">
    <Hero />
    <SolutionsIntro />
    <AiScan />
    <StoreImpact />
    <Comparison />
    <Engagement />
    <Story />
  </main>
  <Footer />
  <WhatsApp />
</BaseLayout>
