---
/**
 * Log in - redesign per 12-marketing.html (auth frame, mobile-first).
 * Logic unchanged : POST /api/auth/login, client-set token cookie,
 * ?next= post-login destination (relative paths only - open-redirect
 * guard), ?error=invalid banner.
 */
export const prerender = false;
import AppLayout from '../layouts/AppLayout.astro';

const error = Astro.url.searchParams.get('error');
// Phase E.C.4 — preserve a post-login destination across the login form.
// Used by /invite/[token] to send unauthed visitors here then return them
// to the accept page once signed in. Only relative paths are honored to
// avoid open-redirect vulns.
const rawNext = Astro.url.searchParams.get('next') || '';
const safeNext = (rawNext.startsWith('/') && !rawNext.startsWith('//')) ? rawNext : '';
---

<AppLayout title="Log in">
  <style is:global>
    /* Auth frame from 12-marketing.html (.auth .sso .divider .f), fluid
       from phone width up to a centred desktop card. */
    .auth-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--color-surface-sunken); padding: var(--space-6) var(--space-4); }
    .auth { width: 100%; max-width: 400px; }
    .auth__brand { display: flex; align-items: center; gap: 9px; justify-content: center; margin-bottom: 28px; text-decoration: none; }
    .auth .brand__mark { width: 26px; height: 26px; border-radius: 8px; background: var(--color-primary); position: relative; flex: none; }
    .auth .brand__mark::after { content: ""; position: absolute; inset: 7px; border-radius: 50%; border: 2.5px solid #fff; }
    .auth .brand__name { font-size: 15px; font-weight: 700; letter-spacing: -.01em; color: var(--color-text-primary); }
    .auth .brand__name span { color: var(--color-text-muted); font-weight: 500; }
    .auth h1 { font-size: 23px; font-weight: 700; letter-spacing: -.02em; text-align: center; color: var(--color-text-primary); }
    .auth__sub { font-size: 13.5px; color: var(--color-text-secondary); text-align: center; margin-top: 7px; margin-bottom: 24px; }
    .auth__card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); padding: 24px; }
    .sso__btn { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; height: 48px; border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); background: var(--color-surface); font: 600 14px var(--font-sans); color: var(--color-text-primary); cursor: pointer; text-decoration: none; transition: .12s; }
    .sso__btn:hover { background: var(--color-surface-sunken); }
    .divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; color: var(--color-text-muted); font-size: 12px; }
    .divider::before, .divider::after { content: ""; flex: 1; height: 1px; background: var(--color-border); }
    .auth .fieldset { display: flex; flex-direction: column; gap: 16px; }
    .auth .f label { font-size: 13px; font-weight: 600; display: block; margin-bottom: 7px; color: var(--color-text-primary); }
    .auth .f input { width: 100%; height: 48px; border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); padding: 0 14px; font-size: 15px; font-family: var(--font-sans); background: var(--color-surface); color: var(--color-text-primary); }
    .auth .f input:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 3px var(--coral-100); }
    .auth .f__row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 7px; }
    .auth .f__row label { margin-bottom: 0; }
    .auth .f__row a { font-size: 12px; color: var(--coral-700); font-weight: 600; text-decoration: none; }
    .auth__cta { display: flex; align-items: center; justify-content: center; width: 100%; height: 50px; border-radius: var(--radius-md); font: 650 15px var(--font-sans); background: var(--color-primary); color: #fff; border: 0; cursor: pointer; margin-top: 22px; transition: .12s; }
    .auth__cta:hover { background: var(--color-primary-hover); }
    .auth__error { background: var(--status-critical-bg); border: 1px solid #FAD9D5; border-radius: var(--radius-md); padding: 11px 13px; font-size: 13px; color: var(--status-critical); margin-bottom: 16px; }
    .auth__switch { font-size: 13px; color: var(--color-text-secondary); text-align: center; margin-top: 22px; }
    .auth__switch a { color: var(--coral-700); font-weight: 650; text-decoration: none; }
    .auth__back { display: block; text-align: center; font-size: 12.5px; color: var(--color-text-muted); margin-top: 18px; text-decoration: none; }
    .auth__back:hover { color: var(--color-text-primary); }
  </style>

  <div class="auth-page">
    <div class="auth">
      <a href="/" class="auth__brand">
        <span class="brand__mark"></span>
        <span class="brand__name">sen-ai<span>.fr</span></span>
      </a>
      <h1>Log in</h1>
      <div class="auth__sub">Access your AI visibility dashboard.</div>

      <div class="auth__card">
        <a href="/api/auth/google" class="sso__btn">
          <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.6 9.2c0-.6-.1-1.2-.2-1.8H9v3.4h4.8a4.1 4.1 0 0 1-1.8 2.7v2.2h2.9c1.7-1.6 2.7-3.9 2.7-6.5z"/><path fill="#34A853" d="M9 18c2.4 0 4.5-.8 6-2.2l-2.9-2.2c-.8.5-1.8.9-3.1.9-2.4 0-4.4-1.6-5.1-3.8H.9v2.3A9 9 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.9 10.7a5.4 5.4 0 0 1 0-3.4V5H.9a9 9 0 0 0 0 8z"/><path fill="#EA4335" d="M9 3.6c1.3 0 2.5.5 3.4 1.3l2.6-2.6A9 9 0 0 0 .9 5l3 2.3C4.6 5.2 6.6 3.6 9 3.6z"/></svg>
          Continue with Google
        </a>

        <div class="divider">or</div>

        {error && (
          <div class="auth__error">
            {error === 'invalid' ? 'Invalid email or password.' : error}
          </div>
        )}

        <form id="login-form" class="fieldset">
          <div class="f">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="you@company.com" inputmode="email" autocomplete="email" />
          </div>
          <div class="f">
            <div class="f__row">
              <label for="password">Password</label>
              <a href="/forgot-password">Forgot password?</a>
            </div>
            <input type="password" id="password" name="password" required placeholder="••••••••" autocomplete="current-password" />
          </div>
          <button type="submit" class="auth__cta" style="margin-top:6px">Log in</button>
        </form>

        <p class="auth__switch">
          Don't have an account yet?
          <a href="/register">Create one - first scan free</a>
        </p>
      </div>

      <a href="/" class="auth__back">&larr; Back to website</a>
    </div>
  </div>

  <script is:inline define:vars={{ safeNext }}>
    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;

      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      if (res.ok) {
        const data = await res.json();
        document.cookie = `token=${data.access_token}; path=/; max-age=86400; SameSite=Lax`;
        window.location.href = safeNext || '/app/dashboard';
      } else {
        const errorRedirect = safeNext
          ? `/login?error=invalid&next=${encodeURIComponent(safeNext)}`
          : '/login?error=invalid';
        window.location.href = errorRedirect;
      }
    });
  </script>
</AppLayout>
