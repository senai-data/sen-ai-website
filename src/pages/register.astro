---
/**
 * Registration - redesign per 12-marketing.html (auth frame, mobile-first).
 *
 * Logic unchanged from the Sprint 15 self-serve reopen :
 *  - POST /api/auth/register ; on 503 (registration_open kill-switch OFF)
 *    the "inscriptions fermées" banner surfaces inline, no redeploy needed
 *  - ?intent=agency banner + intent forwarded to the API (persisted on
 *    users.signup_intent) and to the welcome wizard
 *  - required ToS checkbox (kept over the ref's passive legal line)
 *  - ?next= guarded to relative paths
 */
export const prerender = false;
import AppLayout from '../layouts/AppLayout.astro';

const error = Astro.url.searchParams.get('error');
const intentRaw = (Astro.url.searchParams.get('intent') || '').toLowerCase();
const isAgencyIntent = intentRaw === 'agency';
const rawNext = Astro.url.searchParams.get('next') || '';
const safeNext = (rawNext.startsWith('/') && !rawNext.startsWith('//')) ? rawNext : '/welcome';
---

<AppLayout title="Create your account">
  <style is:global>
    /* Auth frame from 12-marketing.html - same vocabulary as login.astro. */
    .auth-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--color-surface-sunken); padding: var(--space-6) var(--space-4); }
    .auth { width: 100%; max-width: 400px; }
    .auth__brand { display: flex; align-items: center; gap: 9px; justify-content: center; margin-bottom: 28px; text-decoration: none; }
    .auth .brand__mark { width: 26px; height: 26px; border-radius: 8px; background: var(--color-primary); position: relative; flex: none; }
    .auth .brand__mark::after { content: ""; position: absolute; inset: 7px; border-radius: 50%; border: 2.5px solid #fff; }
    .auth .brand__name { font-size: 15px; font-weight: 700; letter-spacing: -.01em; color: var(--color-text-primary); }
    .auth .brand__name span { color: var(--color-text-muted); font-weight: 500; }
    .auth h1 { font-size: 23px; font-weight: 700; letter-spacing: -.02em; text-align: center; color: var(--color-text-primary); }
    .auth__sub { font-size: 13.5px; color: var(--color-text-secondary); text-align: center; margin-top: 7px; margin-bottom: 24px; }
    .auth__card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); padding: 24px; }
    .sso__btn { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; height: 48px; border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); background: var(--color-surface); font: 600 14px var(--font-sans); color: var(--color-text-primary); cursor: pointer; text-decoration: none; transition: .12s; }
    .sso__btn:hover { background: var(--color-surface-sunken); }
    .divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; color: var(--color-text-muted); font-size: 12px; }
    .divider::before, .divider::after { content: ""; flex: 1; height: 1px; background: var(--color-border); }
    .auth .fieldset { display: flex; flex-direction: column; gap: 16px; }
    .auth .f label { font-size: 13px; font-weight: 600; display: block; margin-bottom: 7px; color: var(--color-text-primary); }
    .auth .f input { width: 100%; height: 48px; border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); padding: 0 14px; font-size: 15px; font-family: var(--font-sans); background: var(--color-surface); color: var(--color-text-primary); }
    .auth .f input:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 3px var(--coral-100); }
    .auth .f__hint { font-size: 11.5px; color: var(--color-text-muted); margin-top: 6px; }
    .auth__tos { display: flex; align-items: flex-start; gap: 9px; font-size: 12px; color: var(--color-text-secondary); line-height: 1.5; cursor: pointer; }
    .auth__tos input { width: 15px; height: 15px; margin-top: 2px; accent-color: var(--color-primary); flex: none; }
    .auth__tos a { color: var(--coral-700); font-weight: 600; text-decoration: none; }
    .auth__cta { display: flex; align-items: center; justify-content: center; width: 100%; height: 50px; border-radius: var(--radius-md); font: 650 15px var(--font-sans); background: var(--color-primary); color: #fff; border: 0; cursor: pointer; transition: .12s; }
    .auth__cta:hover { background: var(--color-primary-hover); }
    .auth__cta[disabled] { opacity: .5; cursor: not-allowed; }
    .auth__error { background: var(--status-critical-bg); border: 1px solid #FAD9D5; border-radius: var(--radius-md); padding: 11px 13px; font-size: 13px; color: var(--status-critical); margin-bottom: 16px; }
    .auth__notice { border-radius: var(--radius-md); padding: 13px 14px; font-size: 12.5px; margin-bottom: 16px; line-height: 1.5; }
    .auth__notice--agency { background: var(--color-primary-subtle); border: 1px solid var(--coral-200); color: var(--color-text-primary); }
    .auth__notice--closed { background: var(--status-warning-bg); border: 1px solid #F2E2C4; color: var(--color-text-primary); }
    .auth__notice--closed a { color: var(--coral-700); font-weight: 650; text-decoration: none; }
    .auth__switch { font-size: 13px; color: var(--color-text-secondary); text-align: center; margin-top: 22px; }
    .auth__switch a { color: var(--coral-700); font-weight: 650; text-decoration: none; }
    .auth__back { display: block; text-align: center; font-size: 12.5px; color: var(--color-text-muted); margin-top: 18px; text-decoration: none; }
    .auth__back:hover { color: var(--color-text-primary); }
    .hidden { display: none !important; }
  </style>

  <div class="auth-page">
    <div class="auth">
      <a href="/" class="auth__brand">
        <span class="brand__mark"></span>
        <span class="brand__name">sen-ai<span>.fr</span></span>
      </a>
      <h1>Create your account</h1>
      <div class="auth__sub">Your first scan is free. No card required.</div>

      {isAgencyIntent && (
        <div class="auth__notice auth__notice--agency">
          <strong>Agency sign-up</strong>
          <p style="font-size:12px;color:var(--color-text-secondary);margin-top:3px">
            Your workspace will be configured for multi-brand tracking. We'll reach out about
            volume pricing once you've launched your first scan.
          </p>
        </div>
      )}

      <div id="closed-banner" class="hidden auth__notice auth__notice--closed">
        <p style="font-weight:650;margin-bottom:3px">Inscriptions temporairement fermées</p>
        <p style="font-size:12px;color:var(--color-text-secondary);margin-bottom:8px">
          La création de compte est en pause. Vous pouvez tout de même demander un audit IA gratuit pendant ce temps.
        </p>
        <a href="/#engagement">Demander un audit gratuit &rarr;</a>
      </div>

      <div class="auth__card">
        <a href={`/api/auth/google${isAgencyIntent ? '?intent=agency' : ''}`} class="sso__btn">
          <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.6 9.2c0-.6-.1-1.2-.2-1.8H9v3.4h4.8a4.1 4.1 0 0 1-1.8 2.7v2.2h2.9c1.7-1.6 2.7-3.9 2.7-6.5z"/><path fill="#34A853" d="M9 18c2.4 0 4.5-.8 6-2.2l-2.9-2.2c-.8.5-1.8.9-3.1.9-2.4 0-4.4-1.6-5.1-3.8H.9v2.3A9 9 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.9 10.7a5.4 5.4 0 0 1 0-3.4V5H.9a9 9 0 0 0 0 8z"/><path fill="#EA4335" d="M9 3.6c1.3 0 2.5.5 3.4 1.3l2.6-2.6A9 9 0 0 0 .9 5l3 2.3C4.6 5.2 6.6 3.6 9 3.6z"/></svg>
          Continue with Google
        </a>

        <div class="divider">or</div>

        {error && (
          <div id="error-banner" class="auth__error">
            {error === 'invalid' ? 'Please check the form and try again.' :
             error === 'exists' ? 'An account already exists for this email. Try logging in instead.' :
             error === 'weak_password' ? 'Password must be at least 8 characters with a letter and a number.' :
             error === 'network' ? 'Network error. Please try again.' :
             decodeURIComponent(error)}
          </div>
        )}

        <form id="register-form" class="fieldset">
          <div class="f">
            <label for="name">Full name</label>
            <input type="text" id="name" name="name" required minlength="2" maxlength="120"
                   placeholder="Jane Doe" autocomplete="name" />
          </div>
          <div class="f">
            <label for="email">Work email</label>
            <input type="email" id="email" name="email" required placeholder="you@company.com"
                   inputmode="email" autocomplete="email" />
          </div>
          <div class="f">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required minlength="8"
                   placeholder="At least 8 characters" autocomplete="new-password" />
            <p class="f__hint">Use 8+ characters with a mix of letters and numbers.</p>
          </div>

          <label class="auth__tos">
            <input type="checkbox" id="tos" required />
            <span>
              I accept the <a href="/terms" target="_blank">Terms of Service</a>
              and <a href="/privacy" target="_blank">Privacy Policy</a>.
            </span>
          </label>

          <button id="submit-btn" type="submit" class="auth__cta">Create my account</button>
        </form>

        <p class="auth__switch">
          Already have an account?
          <a href="/login">Log in</a>
        </p>
      </div>

      <a href="/" class="auth__back">&larr; Back to website</a>
    </div>
  </div>

  <script is:inline define:vars={{ safeNext, intentRaw }}>
    const form = document.getElementById('register-form');
    const submitBtn = document.getElementById('submit-btn');
    const closedBanner = document.getElementById('closed-banner');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const tos = document.getElementById('tos').checked;
      if (!tos) {
        window.location.href = '/register?error=' + encodeURIComponent('Please accept the terms');
        return;
      }
      submitBtn.disabled = true;
      submitBtn.textContent = 'Creating account...';

      try {
        const res = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          // Forward the intent (currently 'agency' only) so it's
          // persisted on the user record - keeps the agency framing
          // sticky across re-logins.
          body: JSON.stringify({ name, email, password, intent: intentRaw || null }),
        });

        if (res.status === 503) {
          // Kill-switch ON — surface the "fermées" inline (no redirect)
          // so the user gets an honest answer + audit fallback.
          closedBanner.classList.remove('hidden');
          form.style.opacity = '.5';
          form.style.pointerEvents = 'none';
          submitBtn.disabled = true;
          submitBtn.textContent = 'Inscriptions fermées';
          return;
        }

        if (res.ok) {
          // Cookie is set server-side (HttpOnly) — go to onboarding.
          // Pass the intent so the welcome wizard can surface the agency
          // hint when set.
          const dest = intentRaw
            ? `${safeNext}${safeNext.includes('?') ? '&' : '?'}intent=${encodeURIComponent(intentRaw)}`
            : safeNext;
          window.location.href = dest;
          return;
        }

        let detail = 'invalid';
        try {
          const body = await res.json();
          if (body?.detail && typeof body.detail === 'string') {
            const d = body.detail.toLowerCase();
            if (d.includes('already')) detail = 'exists';
            else if (d.includes('password')) detail = 'weak_password';
            else detail = encodeURIComponent(body.detail.slice(0, 140));
          }
        } catch {}
        window.location.href = `/register?error=${detail}${intentRaw ? `&intent=${intentRaw}` : ''}`;
      } catch {
        window.location.href = `/register?error=network${intentRaw ? `&intent=${intentRaw}` : ''}`;
      }
    });
  </script>
</AppLayout>
