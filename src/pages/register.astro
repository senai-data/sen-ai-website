---
export const prerender = false;
import AppLayout from '../layouts/AppLayout.astro';

const error = Astro.url.searchParams.get('error');
---

<AppLayout title="Inscriptions fermées">
  <div class="min-h-screen flex items-center justify-center px-4 py-12 bg-gradient-to-br from-white via-white to-coral/5">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/">
          <img src="/logo-sen-ai-fr.png" alt="sen-ai.fr" class="h-10 mx-auto mb-4" />
        </a>
      </div>

      <div class="bg-white rounded-2xl shadow-lg p-8 text-center">
        <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-coral/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/>
          </svg>
        </div>

        <h1 class="text-xl sm:text-2xl font-bold text-charcoal-dark mb-2">
          Inscriptions temporairement fermées
        </h1>
        <p class="text-sm text-charcoal-light mb-6">
          La création de compte est en pause le temps qu'on prépare la prochaine vague d'onboarding. En attendant, vous pouvez tout de même <strong class="text-charcoal-dark">demander un audit IA gratuit</strong> de votre marque.
        </p>

        <div class="bg-gray-50 rounded-xl p-4 text-left mb-6">
          <p class="text-xs font-semibold text-charcoal-dark uppercase tracking-wide mb-2.5">L'audit gratuit, sans compte</p>
          <ul class="space-y-1.5 text-xs text-charcoal-light">
            <li class="flex items-start gap-2">
              <svg class="w-3.5 h-3.5 text-coral mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>3 personas, 6 questions, ChatGPT et Gemini</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-3.5 h-3.5 text-coral mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>Mini-rapport actionable en 24h</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-3.5 h-3.5 text-coral mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>Aucune CB, aucun engagement</span>
            </li>
          </ul>
        </div>

        <a
          href="/#engagement"
          class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark transition-colors text-sm shadow-lg shadow-coral/20"
        >
          Demander mon audit gratuit
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
          </svg>
        </a>

        <p class="text-center text-xs text-charcoal-light mt-6">
          Déjà un compte ?
          <a href="/login" class="text-coral hover:text-coral-dark font-medium">Se connecter</a>
        </p>
      </div>

      <p class="text-center text-xs text-charcoal-light mt-6">
        <a href="/" class="hover:text-coral transition-colors">&larr; Retour à l'accueil</a>
      </p>
    </div>
  </div>
</AppLayout>
