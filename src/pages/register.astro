---
export const prerender = false;
import AppLayout from '../layouts/AppLayout.astro';

const error = Astro.url.searchParams.get('error');
---

<AppLayout title="Sign up">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/">
          <img src="/logo-sen-ai-fr.png" alt="sen-ai.fr" class="h-10 mx-auto mb-4" />
        </a>
        <h1 class="text-2xl font-bold text-charcoal-dark">Create your account</h1>
        <p class="text-charcoal-light mt-1">Start measuring your AI visibility</p>
      </div>

      <div class="bg-white rounded-2xl shadow-lg p-8">
        <!-- Google OAuth -->
        <a
          href="/api/auth/google"
          class="w-full flex items-center justify-center gap-3 px-4 py-3 border-2 border-gray-200 rounded-lg hover:border-gray-300 hover:bg-gray-50 transition-colors mb-6"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span class="font-medium text-charcoal">Sign up with Google</span>
        </a>

        <div class="flex items-center gap-4 mb-6">
          <div class="flex-1 h-px bg-gray-200"></div>
          <span class="text-sm text-charcoal-light">or</span>
          <div class="flex-1 h-px bg-gray-200"></div>
        </div>

        {error && (
          <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
            {error === 'exists' ? 'This email is already registered.' : error}
          </div>
        )}

        <form id="register-form" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-charcoal mb-1">Name</label>
            <input
              type="text" id="name" name="name" required
              class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-coral/50 focus:border-coral"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-charcoal mb-1">Email</label>
            <input
              type="email" id="email" name="email" required
              class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-coral/50 focus:border-coral"
              placeholder="you@company.com"
            />
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-charcoal mb-1">Password</label>
            <input
              type="password" id="password" name="password" required minlength="8"
              class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-coral/50 focus:border-coral"
              placeholder="Min 8 chars, 1 uppercase, 1 digit"
            />
          </div>
          <button
            type="submit"
            class="w-full py-3 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark transition-colors"
          >
            Create account
          </button>
        </form>

        <p class="text-center text-sm text-charcoal-light mt-6">
          Already have an account?
          <a href="/login" class="text-coral hover:text-coral-dark font-medium">Log in</a>
        </p>
      </div>

      <p class="text-center text-sm text-charcoal-light mt-6">
        <a href="/" class="hover:text-coral transition-colors">&larr; Back to website</a>
      </p>
    </div>
  </div>

  <script type="module">
    document.getElementById('register-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('name').value;
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;

      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password, name }),
      });

      if (res.ok) {
        // Server-side /register sets the HttpOnly cookie; the JS line below is a
        // no-op fallback for environments where Set-Cookie didn't apply. New users
        // go to /welcome (onboarding wizard), not /app/dashboard (empty for them).
        const data = await res.json();
        document.cookie = `token=${data.access_token}; path=/; max-age=86400; SameSite=Lax`;
        window.location.href = '/welcome';
      } else {
        const err = await res.json();
        window.location.href = `/register?error=${encodeURIComponent(err.detail || 'exists')}`;
      }
    });
  </script>
</AppLayout>
